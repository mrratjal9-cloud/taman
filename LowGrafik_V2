    MainBorder.Position        = UDim2.new(0, 20, 0.5, -25)
    MainBorder.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    MainBorder.BorderSizePixel = 0
    MainBorder.ZIndex          = 10
    Instance.new("UICorner", MainBorder).CornerRadius = UDim.new(0.15, 0)

    local Main = Instance.new("Frame")
    Main.Parent          = MainBorder
    Main.AnchorPoint     = Vector2.new(0.5, 0.5)
    Main.Position        = UDim2.fromScale(0.5, 0.5)
    Main.Size            = UDim2.fromScale(0.95, 0.85)
    Main.BackgroundColor3 = Color3.fromRGB(112, 112, 112)
    Main.BorderSizePixel = 0
    Main.ZIndex          = 11
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0.15, 0)

    local UIGradient = Instance.new("UIGradient", Main)
    UIGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(140, 140, 140)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(81, 81, 81))
    })
    UIGradient.Rotation = 90

    local Label = Instance.new("TextLabel")
    Label.Parent              = Main
    Label.BackgroundTransparency = 1
    Label.Position            = UDim2.fromScale(0.05, 0)
    Label.Size                = UDim2.fromScale(0.55, 1)
    Label.Text                = config.Text
    Label.Font                = Enum.Font.GothamBold
    Label.TextScaled          = true
    Label.TextColor3          = Color3.fromRGB(255, 255, 255)
    Label.ZIndex              = 12

    local SwitchBorder = Instance.new("Frame")
    SwitchBorder.Parent          = Main
    SwitchBorder.Size            = UDim2.fromScale(0.3, 0.55)
    SwitchBorder.Position        = UDim2.fromScale(0.65, 0.225)
    SwitchBorder.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    SwitchBorder.BorderSizePixel = 0
    SwitchBorder.ZIndex          = 12
    Instance.new("UICorner", SwitchBorder).CornerRadius = UDim.new(1, 0)

    local Switch = Instance.new("Frame")
    Switch.Parent          = SwitchBorder
    Switch.Size            = UDim2.fromScale(0.85, 0.75)
    Switch.AnchorPoint     = Vector2.new(0.5, 0.5)
    Switch.Position        = UDim2.fromScale(0.5, 0.5)
    Switch.BackgroundColor3 = Color3.fromRGB(112, 112, 112)
    Switch.BorderSizePixel = 0
    Switch.ZIndex          = 13
    Instance.new("UICorner", Switch).CornerRadius = UDim.new(1, 0)

    local SwitchGrad = Instance.new("UIGradient", Switch)
    SwitchGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(140, 140, 140)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(81, 81, 81))
    })
    SwitchGrad.Rotation = 90

    local Knob = Instance.new("Frame")
    Knob.Parent          = Switch
    Knob.Size            = UDim2.fromScale(0.4, 0.9)
    Knob.Position        = state and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05)
    Knob.BackgroundColor3 = state and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    Knob.BorderSizePixel = 0
    Knob.ZIndex          = 14
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

    local Button = Instance.new("TextButton")
    Button.Parent              = Switch
    Button.Size                = UDim2.fromScale(1, 1)
    Button.BackgroundTransparency = 1
    Button.Text                = ""
    Button.ZIndex              = 15

    Button.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(Knob, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
            Position        = state and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05),
            BackgroundColor3 = state and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        }):Play()
        config.Callback(state)
    end)

    -- Drag support
    local dragging, dragStart, frameStart
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging   = true
            dragStart  = input.Position
            frameStart = MainBorder.Position
        end
    end)
    Main.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainBorder.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)

    return function(v)
        state = v
        Knob.Position        = v and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05)
        Knob.BackgroundColor3 = v and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        config.Callback(state)
    end
end

