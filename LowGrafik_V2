-- ║                    DATA TRACKER SYSTEM                    ║
-- ║   (PERMANEN: tetap berjalan walau toggle OFF, agar        ║
-- ║    counter / playtime / total seed terus akumulasi.)      ║
-- ╚══════════════════════════════════════════════════════════╝
local function updateTracker()
    local pGui = player:FindFirstChild("PlayerGui")
    if not pGui then return end

    -- ── 1) Ambil SEED + deteksi GameEnd (dari GameGui) ─────
    local gameGui = pGui:FindFirstChild("GameGui")
    if gameGui then
        local screen = gameGui:FindFirstChild("Screen")
        if screen then

            -- Ambil nilai seed
            local bottom = screen:FindFirstChild("Bottom")
            if bottom then
                local currencyDisplay = bottom:FindFirstChild("CurrencyDisplay")
                if currencyDisplay then
                    local seedsDisplay = currencyDisplay:FindFirstChild("SeedsDisplay")
                    if seedsDisplay then
                        local title = seedsDisplay:FindFirstChild("Title")
                        if title and title.Text ~= "" then
                            -- Hapus koma/titik/spasi -> jadi murni angka
                            local pureNumberString = string.gsub(title.Text, "[,%.%s]", "")
                            local num = tonumber(pureNumberString)
                            if num then
                                currentSeed = num
                                if initialSeed == nil then
                                    initialSeed     = currentSeed
                                    roundStartTime  = os.clock()  -- baseline waktu ronde pertama
                                end
                                stats.SeedText = tostring(currentSeed)
                            end
                        end
                    end
                end
            end

            -- Cek status GameEnd & update counter / playtime / seed earned
            local middle = screen:FindFirstChild("Middle")
            if middle then
                local gameEnd = middle:FindFirstChild("GameEnd")
                if gameEnd and gameEnd.Visible == true then
                    -- Ronde baru saja selesai
                    if not gameEndedHandled and initialSeed ~= nil then
                        -- Hitung seed earned ronde ini
                        earnedThisMatch  = currentSeed - initialSeed
                        if earnedThisMatch < 0 then earnedThisMatch = 0 end
                        lastRoundSeed    = earnedThisMatch
                        totalEarnedSeed  = totalEarnedSeed + earnedThisMatch

                        -- Hitung waktu ronde ini
                        lastGameTime     = os.clock() - roundStartTime
                        if lastGameTime < 0 then lastGameTime = 0 end
                        totalPlayTime    = totalPlayTime + lastGameTime

                        -- Counter ronde selesai (PERMANEN)
                        totalGamesPlayed = totalGamesPlayed + 1
                        gameEndedHandled = true
                    end
                else
                    -- GameEnd hilang -> ronde baru sudah mulai, reset baseline
                    if gameEndedHandled then
                        initialSeed     = currentSeed
                        earnedThisMatch = 0
                        roundStartTime  = os.clock()
                        gameEndedHandled = false
                    end
                end
            end
        end
    end

    -- ── 2) Ambil WAVE (dari GameGuiNoInset) ────────────────
    local gameGuiNoInset = pGui:FindFirstChild("GameGuiNoInset")
    if gameGuiNoInset then
        local screenNoInset = gameGuiNoInset:FindFirstChild("Screen")
        if screenNoInset then
            local top = screenNoInset:FindFirstChild("Top")
            if top then
                local gameInfo = top:FindFirstChild("GameInfo")
                if gameInfo then
                    local content = gameInfo:FindFirstChild("Content")
                    if content then
                        local waves = content:FindFirstChild("Waves")
                        if waves then
                            local title = waves:FindFirstChild("Title")
                            if title and title:IsA("TextLabel") and title.Text ~= "" then
                                stats.Wave = title.Text
                            end
                        end
                    end
                end
            end
        end
    end
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║                      UPDATE LOOP                          ║
-- ║   Tracker JALAN TERUS (tidak peduli isOptimized).         ║
-- ║   UI hanya di-redraw saat textContainer.Visible = true.   ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    while task.wait(UPDATE_INTERVAL) do
        -- 1) Tracker selalu jalan -> counter/playtime/seed permanen
        local ok, err = pcall(updateTracker)
        if not ok then warn("[LowGrafikV2] tracker error: " .. tostring(err)) end

        -- 2) Update UI hanya saat overlay ditampilkan
        if isOptimized then
            -- Header dinamis dengan counter ronde (PERMANEN)
            if locationStatus == "IN GAME" then
                headerLabel.Text = "IN GAME (" .. tostring(totalGamesPlayed) .. ")"
            else
                headerLabel.Text = locationStatus
            end

            -- Format display seed saat ini (tampilkan +N kalau lagi naik)
            local seedDisplay = formatNumber(stats.SeedText)
            if earnedThisMatch > 0 then
                seedDisplay = seedDisplay .. " (+" .. formatNumber(earnedThisMatch) .. ")"
            end

            -- Hitung playtime ronde berjalan (live)
            local liveRoundTime = 0
            if initialSeed ~= nil and not gameEndedHandled then
                liveRoundTime = os.clock() - roundStartTime
            end

            -- Susun text panel stats
            statsLabel.Text = string.format(
                "🌊 %s\n\n" ..
                "🌱 Seed Now      : %s\n" ..
                "🌱 Last Round    : +%s\n" ..
                "🌱 Total Earned  : +%s\n\n" ..
                "⏱ Round Time    : %s\n" ..
                "⏱ Last Game     : %s\n" ..
                "⏱ Total Playtime: %s\n\n" ..
                "===============================\n" ..
                "Tinggalkan perangkat dengan tenang.",
                stats.Wave,
                seedDisplay,
                formatNumber(lastRoundSeed),
                formatNumber(totalEarnedSeed),
                formatTime(liveRoundTime),
                formatTime(lastGameTime),
                formatTime(totalPlayTime)
            )

            -- Refresh nama player (kalau berubah, mis. setelah display name update)
            local nm = (player and player.DisplayName ~= "" and player.DisplayName) or (player and player.Name) or "Player"
            if playerNameLabel.Text ~= nm then
                playerNameLabel.Text = nm
            end
        end
    end
end)


