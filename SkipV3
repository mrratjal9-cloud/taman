-- ==========================================================
-- SKIP V3 (Perbaikan dari V2 yang bikin game crash)
-- ==========================================================
-- Apa yang diperbaiki dari V2:
--
--   [BUG V2] "Script bikin game crash instant"
--   Kemungkinan penyebab di V2:
--     a) Saat startup, V2 nge-spam `ChangeTickSpeed:InvokeServer()`
--        sampai 10x retry + resync tiap 5 detik. Banyak game TD
--        Roblox punya anti-exploit yang detect remote ini di-call
--        berulang-ulang -> langsung kick/crash client.
--     b) V2 toggle `ScreenGui.Enabled = false/true` tepat saat
--        VirtualInputManager nge-fire mouse event. Di executor /
--        device mobile tertentu ini bisa bikin renderer crash.
--     c) V2 pakai `IgnoreGuiInset = true` yang kadang bentrok di
--        mobile.
--
--   FIX di V3:
--     1) GameSpeed TIDAK lagi di-paksa saat startup.
--        User harus klik tombol speed di panel kalau mau ubah.
--        Tiap klik = 1x InvokeServer (no spam, no retry agresif).
--     2) RESYNC LOOP DIHAPUS TOTAL.
--     3) ScreenGui.Enabled tidak pernah di-toggle.
--        Sebagai gantinya, panel di-default di POJOK KIRI BAWAH
--        (jauh dari posisi tombol AutoSkip game yang ada di atas)
--        supaya VIM click gak nyangkut ke panel sendiri.
--     4) `IgnoreGuiInset` dihapus.
--     5) Tombol PAUSE ALL ditambahkan: kalau script misbehave,
--        tinggal pencet sekali -> semua loop berhenti aman.
--     6) Click method "VIM" di-NON-aktifkan default. Kalau perlu,
--        toggle pakai tombol "Allow VIM" di panel.
--     7) Cooldown lebih longgar + "in-game state detection"
--        (cuma klik kalau WaveControls beneran ada di GameGui).
-- ==========================================================


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       CONFIGURATION                       ║
-- ╚══════════════════════════════════════════════════════════╝

-- ── [1] FITUR UTAMA ────────────────────────────────────────
-- Pengaturan utama: fitur mana yang aktif saat script di-load.
local Config = {
    AutoSkip   = true,    -- true = aktifkan tombol "Auto Skip" otomatis di game (klik AutoSkip kalau lagi Off). false = jangan otak-atik.
    ManualSkip = true,    -- true = otomatis klik tombol "Skip Wave" tiap kali muncul di tengah ronde.
    AllowVIM   = false,   -- true = boleh pakai VirtualInputManager (klik mouse fisik) sebagai fallback. false = HANYA pakai firesignal/connections (paling aman, anti-crash).
}

-- ── [2] GAME SPEED (manual / opt-in) ───────────────────────
-- PENTING: speed TIDAK di-set otomatis di awal load. Ini sengaja
-- biar script gak nge-trigger anti-exploit. Set speed dari panel
-- ya kalau perlu (klik tombol 1x / 2x / 3x).
local DEFAULT_SPEED        = 2     -- nilai default yang di-highlight di panel (cuma highlight, tidak di-invoke). Pilihan: 1 / 2 / 3.

-- ── [3] LOOP TIMING ────────────────────────────────────────
local LOOP_INTERVAL        = 0.7   -- detik. Jeda antar iterasi loop utama. Lebih besar = lebih ringan & lebih aman dari spam.
local AUTOSKIP_COOLDOWN    = 2.0   -- detik. Setelah klik AutoSkip, tunggu sekian detik sebelum nyoba lagi.
local MANUAL_COOLDOWN      = 1.0   -- detik. Setelah klik Skip Wave, tunggu sekian detik (cegah double-click bertubi-tubi).

-- ── [4] DEBUG ──────────────────────────────────────────────
local DEBUG_PRINT          = false -- true = print log ke F9 console.


