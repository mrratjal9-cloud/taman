-- ║                   SAFE PATH HELPERS                       ║
-- ╚══════════════════════════════════════════════════════════╝
local function safeChild(parent, name)
    if not parent then return nil end
    return parent:FindFirstChild(name)
end

-- Path: PlayerGui.GameGuiNoInset.Screen.Top.WaveControls.AutoSkip
local function getAutoSkipButton()
    local gui = safeChild(PlayerGui, "GameGuiNoInset")
    local scr = safeChild(gui, "Screen")
    local top = safeChild(scr, "Top")
    local wc  = safeChild(top, "WaveControls")
    return safeChild(wc, "AutoSkip"), wc
end

-- Path: PlayerGui.GameGuiNoInset.Screen.Top.SkipWave (frame), Button di dalamnya
local function getSkipWaveFrame()
    local gui = safeChild(PlayerGui, "GameGuiNoInset")
    local scr = safeChild(gui, "Screen")
    local top = safeChild(scr, "Top")
    return safeChild(top, "SkipWave")
end

-- Cek apakah game sedang aktif (WaveControls eksis = ada di gameplay).
-- Kalau lagi di lobby/menu, jangan klik apa-apa biar tidak trigger
-- anti-exploit dan tidak ada "ghost click" ke koordinat random.
local function isInGameplay()
    local _, wc = getAutoSkipButton()
    return wc ~= nil
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║              REMOTE: ChangeTickSpeed (manual)             ║
-- ╚══════════════════════════════════════════════════════════╝
local function getTickSpeedRemote()
    local rf = safeChild(ReplicatedStorage, "RemoteFunctions")
    if not rf then return nil end
    return safeChild(rf, "ChangeTickSpeed")
end

-- DIPANGGIL CUMA SAAT USER KLIK TOMBOL SPEED. Tidak ada retry agresif.
-- 1x panggil. Kalau gagal, user bisa klik ulang.
local function setGameSpeedOnce(value)
    local r = getTickSpeedRemote()
    if not r then
        dprint("Remote ChangeTickSpeed tidak ditemukan.")
        return false, "remote belum siap"
    end
    local ok, err = pcall(function() r:InvokeServer(value) end)
    if not ok then
        dprint("Invoke gagal:", err)
        return false, tostring(err)
    end
    return true
end


