-- ║                       MAIN LOOP                           ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(LOOP_INTERVAL)

        if isPausedByUser then
            -- jangan ngapa-ngapain saat di-pause
            -- (continue kosong, lanjut iterasi berikutnya)
        elseif not isInGameplay() then
            -- Hanya jalan kalau benar-benar lagi di gameplay
            setStatus("Bukan di gameplay. Loop standby.")
            autoSkipAttempt = 0
            manualSkipAttempt = 0
        else
            local now = os.clock()
            local statusParts = {}

            -- ── [A] AUTO SKIP ──
            if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AUTOSKIP_COOLDOWN then
                local btn = getAutoSkipButton()
                local titleLabel = btn and btn:FindFirstChild("Title")
                if btn and titleLabel and string.find(titleLabel.Text, "Off") then
                    autoSkipAttempt = autoSkipAttempt + 1
                    if autoSkipAttempt > 3 then autoSkipAttempt = 1 end
                    table.insert(statusParts, "AutoSkip m" .. autoSkipAttempt)
                    virtualClick(btn, autoSkipAttempt)
                    lastAutoSkipClickAt = os.clock()
                else
                    autoSkipAttempt = 0
                end
            end

            -- ── [B] MANUAL SKIP ──
            if Config.ManualSkip and (now - lastManualClickAt) >= MANUAL_COOLDOWN then
                local frame = getSkipWaveFrame()
                if frame and frame.Visible then
                    local mbtn = frame:FindFirstChild("Button")
                    if mbtn then
                        manualSkipAttempt = manualSkipAttempt + 1
                        if manualSkipAttempt > 3 then manualSkipAttempt = 1 end
                        table.insert(statusParts, "SkipWave m" .. manualSkipAttempt)
                        virtualClick(mbtn, manualSkipAttempt)
                        lastManualClickAt = os.clock()
                    end
                else
                    manualSkipAttempt = 0
                end
            end

            if #statusParts == 0 then
                setStatus("In game. Watching UI...")
            else
                setStatus(table.concat(statusParts, " | "))
            end
        end
    end
    dprint("Loop berhenti.")
end)

