end)

-- ==========================================
-- SHUFFLE-BAG (Fisher-Yates) -- pakai math.random
-- ==========================================
local function refillBag()
    slotBag = {}
    for i = 1, #SLOTS do slotBag[i] = i end
    for i = #slotBag, 2, -1 do
        local j = randInt(1, i)
        slotBag[i], slotBag[j] = slotBag[j], slotBag[i]
    end
end

local function pickSlot()
    if #slotBag == 0 then refillBag() end
    return table.remove(slotBag, 1)
end

-- ==========================================
-- ROTATION GENERATOR
-- ==========================================
local function pickRotationDeg()
    local m = CONFIG.ROTATION_MODE
    if m == "off" then
        return 0
    elseif m == "fixed" then
        return CONFIG.FIXED_ROTATION_DEG or 0
    elseif m == "smooth" then
        return randFloat(0, 360)
    else
        local steps = { 0, 90, 180, 270 }
        return steps[randInt(1, 4)]
    end
end

-- ==========================================
-- BUILD PLACEMENT ARGS
-- ==========================================
local function buildArgs(slotIdx)
    local s = SLOTS[slotIdx]
    local off = CONFIG.POSITION_OFFSET or 0
    local dx = 0
    local dz = 0
    if off > 0 then
        dx = randFloat(-off, off)
        dz = randFloat(-off, off)
    end

    local x = s[1] + dx
    local y = s[2]
    local z = s[3] + dz

    local rotDeg = pickRotationDeg()
    local cf = CFrame.new(x, y, z) * CFrame.Angles(0, math.rad(rotDeg), 0)
    local pos = Vector3.new(x, y, z)

    local args = {
        CONFIG.TARGET_UNIT,
        {
            CF       = cf,
            Rotation = rotDeg,
            Valid    = true,
            Position = pos,
        }
    }
    return args, slotIdx, rotDeg
end

-- ==========================================
-- PLACEMENT REMOTE
-- ==========================================
local placeUnitRemote
local function getPlaceUnitRemote()
    if placeUnitRemote and placeUnitRemote.Parent then return placeUnitRemote end
    local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if rf then placeUnitRemote = rf:FindFirstChild("PlaceUnit") end
    return placeUnitRemote
end

local function isSuccessReturn(ok, ret)
    if not ok then return false end
    if ret == false then return false end
    if type(ret) == "string" and strContains(strLower(ret), "fail") then
        return false
    end
    if type(ret) == "table" and ret.success == false then
        return false
    end
    return true
end

local function tryPlaceOnce()
    local remote = getPlaceUnitRemote()
    if not remote then
        return false, "PlaceUnit remote belum ready"
    end
    local args, slotIdx, rotDeg = buildArgs(pickSlot())
    local ok, ret = pcall(function()
        return remote:InvokeServer(_unpack(args))
    end)
    local success = isSuccessReturn(ok, ret)
    local detail = string.format("slot=%d rot=%s ret=%s",
        slotIdx, tostring(rotDeg), tostring(ret))
    return success, detail
end

local function placeWithRetry()
    local lastDetail = ""
    for attempt = 1, CONFIG.MAX_RETRY_PER_LOOP do
        local ok, detail = tryPlaceOnce()
        lastDetail = detail
        if ok then
            stats.placed = stats.placed + 1
            stats.ok    = stats.ok + 1
            lastResult  = string.format("OK (try %d) %s", attempt, detail)
            if CONFIG.VERBOSE then print("[AutoPlaceV3] " .. lastResult) end
            return true
        end
        task.wait(0.05)
    end
    stats.placed = stats.placed + 1
    stats.fail   = stats.fail + 1
    lastResult   = "FAIL after " .. CONFIG.MAX_RETRY_PER_LOOP .. " tries: " .. lastDetail
    if CONFIG.VERBOSE then warn("[AutoPlaceV3] " .. lastResult) end
    return false
end

-- ==========================================
-- WAVE DETECTOR
-- ==========================================
task.spawn(function()
    while true do
        task.wait(1)
        if CONFIG.WAVE_CONTROL then
            pcall(function()
                local pGui = LocalPlayer:FindFirstChild("PlayerGui")
                if pGui then
                    local ggn     = pGui:FindFirstChild("GameGuiNoInset")
                    local screen  = ggn and ggn:FindFirstChild("Screen")
                    local top     = screen and screen:FindFirstChild("Top")
                    local info    = top and top:FindFirstChild("GameInfo")
                    local content = info and info:FindFirstChild("Content")
                    local waves   = content and content:FindFirstChild("Waves")
                    local title   = waves and waves:FindFirstChild("Title")

                    if title and title.Text and title.Text ~= "" then
                        local match = string.match(title.Text, "[Ww][Aa][Vv][Ee]%s*(%d+)")
                        if match then
                            local cur = tonumber(match)
                            WaveLbl.Text = string.format(
                                "Wave: %d  |  Auto: %s",
                                cur,
                                CONFIG.WAVE_CONTROL and "ON" or "OFF"
                            )
                            if cur ~= lastWaveNum then
                                lastWaveNum = cur
                                if cur == CONFIG.START_WAVE and not isRunning then
                                    print("[AutoPlaceV3] Reach START_WAVE -> ON")
                                    setScriptState(true)
                                elseif cur == CONFIG.STOP_WAVE and isRunning then
                                    print("[AutoPlaceV3] Reach STOP_WAVE -> OFF")
                                    setScriptState(false)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

