-- WAVE DETECTOR (BACKGROUND, no `continue`)
-- ==========================================
task.spawn(function()
    while true do
        task.wait(1)
        if CONFIG.WAVE_CONTROL then
            pcall(function()
                local pGui = LocalPlayer:FindFirstChild("PlayerGui")
                if pGui then
                    local ggn     = pGui:FindFirstChild("GameGuiNoInset")
                    local screen  = ggn and ggn:FindFirstChild("Screen")
                    local top     = screen and screen:FindFirstChild("Top")
                    local info    = top and top:FindFirstChild("GameInfo")
                    local content = info and info:FindFirstChild("Content")
                    local waves   = content and content:FindFirstChild("Waves")
                    local title   = waves and waves:FindFirstChild("Title")

                    if title and title.Text and title.Text ~= "" then
                        local match = string.match(title.Text, "[Ww][Aa][Vv][Ee]%s*(%d+)")
                        if match then
                            local cur = tonumber(match)
                            WaveLbl.Text = string.format("Wave: %d  |  Auto: %s",
                                cur, CONFIG.WAVE_CONTROL and "ON" or "OFF")
                            if cur ~= lastWaveNum then
                                lastWaveNum = cur
                                if cur == CONFIG.START_WAVE and not isRunning then
                                    print("[AutoPlaceV2] Reach START_WAVE, ON")
                                    setScriptState(true)
                                elseif cur == CONFIG.STOP_WAVE and isRunning then
                                    print("[AutoPlaceV2] Reach STOP_WAVE, OFF")
                                    setScriptState(false)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- MAIN LOOP (with timing jitter + global pcall)
-- ==========================================
refillBag()
refreshStats()

task.spawn(function()
    while true do
        local base   = CONFIG.LOOP_DELAY
        local jit    = CONFIG.LOOP_DELAY_JITTER or 0
        local delay  = math.max(0.01, base + ((jit > 0) and rng:NextNumber(-jit, jit) or 0))
        task.wait(delay)

        if isRunning then
            local ok, err = pcall(placeWithRetry)
            if not ok then
                warn("[AutoPlaceV2] Iterasi error: " .. tostring(err))
                lastResult = "ERROR: " .. tostring(err)
            end
            refreshStats()
        end
    end
end)

