-- ╔══════════════════════════════════════════════════════════╗
-- ║                REMOTE: ChangeTickSpeed                    ║
-- ╚══════════════════════════════════════════════════════════╝
local function getTickSpeedRemote()
    local rf = safeChild(ReplicatedStorage, "RemoteFunctions")
    if not rf then return nil end
    return safeChild(rf, "ChangeTickSpeed")
end

-- nge-fire ChangeTickSpeed dengan retry sampai sukses atau habis attempt.
-- DIPAKAI saat: load awal + saat user pencet tombol speed di GUI.
local function setGameSpeed(value, retries)
    retries = retries or 1
    for i = 1, retries do
        local r = getTickSpeedRemote()
        if r then
            local ok, err = pcall(function() r:InvokeServer(value) end)
            if ok then
                dprint("ChangeTickSpeed sukses ->", value, "(attempt " .. i .. ")")
                return true
            else
                dprint("ChangeTickSpeed error:", err)
            end
        else
            dprint("Remote ChangeTickSpeed belum ready, attempt " .. i)
        end
        task.wait(0.5)
    end
    return false
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║              VIRTUAL CLICK (3-method, panel-safe)         ║
-- ╚══════════════════════════════════════════════════════════╝
local _ScreenGuiRef = nil   -- akan di-set setelah ScreenGui dibuat (dipakai utk hide panel saat VIM click)

local function clickViaConnections(button)
    if typeof(getconnections) ~= "function" then return false end
    local fired = false
    local signals = { "MouseButton1Click", "Activated", "MouseButton1Down", "MouseButton1Up" }
    for _, sig in ipairs(signals) do
        pcall(function()
            local ev = button[sig]
            if ev then
                local conns = getconnections(ev)
                if conns then
                    for _, c in ipairs(conns) do
                        local ok = pcall(function() c:Fire() end)
                        if not ok and typeof(firesignal) == "function" then
                            pcall(function() firesignal(c) end)
                        end
                        fired = true
                    end
                end
            end
        end)
    end
    return fired
end

local function clickViaFiresignal(button)
    if typeof(firesignal) ~= "function" then return false end
    local signals = { "MouseButton1Down", "MouseButton1Up", "MouseButton1Click", "Activated" }
    local fired = false
    for _, sig in ipairs(signals) do
        pcall(function()
            if button[sig] then
                firesignal(button[sig])
                fired = true
            end
        end)
    end
    return fired
end

-- VIM click yang AMAN: panel script di-hide dulu, klik dilakukan,
-- lalu panel di-show lagi. Ini mencegah klik VIM nyangkut ke panel.
local function clickViaVIM(button)
    if not VirtualInputManager then return false end
    if not button or not button.Parent then return false end
    local ok = pcall(function()
        local pos  = button.AbsolutePosition
        local size = button.AbsoluteSize
        local x = pos.X + size.X / 2
        local y = pos.Y + size.Y / 2

        -- KUNCI ANTI-FREEZE: hide panel sebelum klik fisik
        local prevEnabled
        if _ScreenGuiRef then
            prevEnabled = _ScreenGuiRef.Enabled
            _ScreenGuiRef.Enabled = false
        end

        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true,  game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)

        if _ScreenGuiRef then
            _ScreenGuiRef.Enabled = (prevEnabled ~= false)  -- balikin state semula (default true)
        end
    end)
    return ok
end

local function virtualClick(button, attempt)
    if not button then return end
    attempt = attempt or 1

    local targets = { button }
    local title = button:FindFirstChild("Title")
    if title and (title:IsA("TextLabel") or title:IsA("ImageLabel") or title:IsA("TextButton") or title:IsA("ImageButton")) then
        table.insert(targets, title)
    end

    for _, t in ipairs(targets) do
        if attempt == 1 then
            clickViaConnections(t)
            clickViaFiresignal(t)
        elseif attempt == 2 then
            clickViaFiresignal(t)
            clickViaVIM(t)
        else
            clickViaVIM(t)
            clickViaConnections(t)
            clickViaFiresignal(t)
        end
    end
end


