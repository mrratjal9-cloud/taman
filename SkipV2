-- ╔══════════════════════════════════════════════════════════╗
-- ║          INITIAL GAME SPEED (dengan retry asinkron)       ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    -- Tunggu remote eksis dulu (game baru loading)
    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions", 15)
    if rf then
        rf:WaitForChild("ChangeTickSpeed", 10)
    end
    -- Lalu retry sampai sukses (atau habis budget)
    local ok = setGameSpeed(Config.GameSpeed, SPEED_INIT_RETRIES)
    if ok then
        setStatus("GameSpeed di-set ke " .. Config.GameSpeed .. "x")
    else
        setStatus("GameSpeed gagal di-set (remote belum siap)")
    end
    lastSpeedSyncAt = os.clock()
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       MAIN LOOP                           ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(LOOP_INTERVAL)

        local now = os.clock()
        local statusParts = {}

        -- ── [A] Re-sync GameSpeed periodik ────────────────
        -- Kalau game/round restart, kadang server reset ke 1x.
        -- Jadi tiap SPEED_RESYNC_EVERY detik kita push ulang.
        if (now - lastSpeedSyncAt) >= SPEED_RESYNC_EVERY then
            task.spawn(function() setGameSpeed(Config.GameSpeed, 1) end)
            lastSpeedSyncAt = now
            table.insert(statusParts, "Resync " .. Config.GameSpeed .. "x")
        end

        -- ── [B] AUTO SKIP: hidupkan kalau lagi Off ────────
        if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AUTOSKIP_COOLDOWN then
            local btn = getAutoSkipButton()
            local titleLabel = btn and btn:FindFirstChild("Title")
            if btn and titleLabel and string.find(titleLabel.Text, "Off") then
                autoSkipAttempt = autoSkipAttempt + 1
                if autoSkipAttempt > 3 then autoSkipAttempt = 1 end
                table.insert(statusParts, "AutoSkip method " .. autoSkipAttempt)
                virtualClick(btn, autoSkipAttempt)
                lastAutoSkipClickAt = os.clock()
            else
                autoSkipAttempt = 0
            end
        end

        -- ── [C] MANUAL SKIP: klik kalau frame SkipWave muncul ──
        if Config.ManualSkip and (now - lastManualClickAt) >= MANUAL_COOLDOWN then
            local frame = getSkipWaveFrame()
            if frame and frame.Visible then
                local mbtn = frame:FindFirstChild("Button")
                if mbtn then
                    manualSkipAttempt = manualSkipAttempt + 1
                    if manualSkipAttempt > 3 then manualSkipAttempt = 1 end
                    table.insert(statusParts, "SkipWave method " .. manualSkipAttempt)
                    virtualClick(mbtn, manualSkipAttempt)
                    lastManualClickAt = os.clock()
                end
            else
                manualSkipAttempt = 0
            end
        end

        if #statusParts == 0 then
            setStatus("Watching UI... | Speed=" .. Config.GameSpeed .. "x")
        else
            setStatus(table.concat(statusParts, " | "))
        end
    end
    dprint("Loop berhenti (panel ditutup atau script dimatikan).")
end)

print(string.format(
