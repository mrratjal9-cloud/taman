-- ==========================================================
-- SKIP V2 (Perbaikan dari V1)
-- ==========================================================
-- Apa yang diperbaiki dari SkipV1:
--   1) BUG "GUI freeze / semua tombol gak bisa diklik"
--      ->  V1 spam VirtualInputManager (klik mouse fisik)
--          tiap 0.5 detik tanpa cooldown. Posisi tombol
--          AutoSkip di game sering overlap dengan panel
--          script -> kliknya nyangkut ke panel sendiri.
--      ->  V2: panel SELALU di-hide dulu sebelum VIM click,
--          ada cooldown per-action, dan ada state-tracking
--          biar gak nge-fire klik berulang kalau udah ON.
--
--   2) BUG "GameSpeed config = 2 tapi in-game tetap 1x"
--      ->  V1 cuma InvokeServer ChangeTickSpeed sekali di
--          awal dengan pcall, kalau remote belum ready -> diam.
--      ->  V2: tunggu remote ready, lalu retry beberapa kali
--          sampai sukses. Ada juga "enforce loop" yg setiap
--          beberapa detik nge-resync speed ke nilai config.
--
--   3) Tambahan: semua config dikomentari di sebelah kanan
--      dan dikelompokkan biar mudah dimengerti.
-- ==========================================================


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       CONFIGURATION                       ║
-- ╚══════════════════════════════════════════════════════════╝

-- ── [1] FITUR UTAMA (yang sering kamu ubah) ────────────────
-- Pengaturan utama: fitur mana yang aktif & speed game default.
local Config = {
    AutoSkip   = true,    -- true = aktifkan tombol "Auto Skip" otomatis di game (klik tombol AutoSkip kalau lagi Off). false = jangan otak-atik.
    ManualSkip = true,    -- true = otomatis klik tombol "Skip Wave" tiap kali muncul di tengah ronde. false = nonaktif.
    GameSpeed  = 2,       -- nilai 1 / 2 / 3. Speed gameplay yang dipaksakan ke server. 1=normal, 2=2x, 3=3x. Kalau set 2 -> game beneran 2x (dengan retry sampe sukses).
}

-- ── [2] LOOP TIMING (kalau gak tau, biarkan default) ───────
-- Kontrol seberapa cepat script ngecek state UI game.
local LOOP_INTERVAL        = 0.6   -- detik. Jeda antar iterasi loop utama. Lebih besar = lebih ringan.
local AUTOSKIP_COOLDOWN    = 1.5   -- detik. Setelah klik tombol AutoSkip, tunggu sekian detik sebelum nyoba lagi (biar game sempat update state Off->On).
local MANUAL_COOLDOWN      = 0.8   -- detik. Setelah klik Skip Wave, tunggu sekian detik (biar gak spam VIM bertubi-tubi).
local SPEED_RESYNC_EVERY   = 5     -- detik. Tiap berapa detik script re-invoke ChangeTickSpeed ke server biar speed gak balik ke 1x.
local SPEED_INIT_RETRIES   = 10    -- jumlah retry. Berapa kali script coba InvokeServer di awal load (kalau remote belum ready). Tiap retry jaraknya 0.5 detik.

-- ── [3] DEBUG ──────────────────────────────────────────────
local DEBUG_PRINT          = false -- true = print log ke F9 console (untuk debug). false = silent.


