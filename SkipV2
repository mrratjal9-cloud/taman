    local scr = safeChild(gui, "Screen")
    local top = safeChild(scr, "Top")
    local wc  = safeChild(top, "WaveControls")
    return safeChild(wc, "AutoSkip")
end

-- ambil tombol Skip Wave (yang muncul di tengah ronde)
