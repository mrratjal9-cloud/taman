local function safeChild(parent, name)
    if not parent then return nil end
    return parent:FindFirstChild(name)
end

-- ambil tombol AutoSkip di UI game.
-- Path: PlayerGui.GameGuiNoInset.Screen.Top.WaveControls.AutoSkip
local function getAutoSkipButton()
