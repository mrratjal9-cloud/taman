-- Logika ini COPY 1:1 dari LowGrafik_V9 (sebelah "IN GAME")
-- yang TERBUKTI bekerja:
--   - parse timer "⏱" di TopbarStandard
--   - deteksi match-end via GameEnd.Visible OR timer < 2 (lobby)
--   - increment counter SEKALI per match END (bukan per
--     RestartGame fired). Anti double-count setelah reset.
--   - filter highestSecThisMatch > 10 supaya ronde "ghost"
--     (cuma loading) tidak terhitung.
local cachedTimerLabel = nil
local function getInGameTimer()
    if cachedTimerLabel and cachedTimerLabel.Parent then return cachedTimerLabel.Text end
    local pcallOk, text = pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        local tbs = pGui and pGui:FindFirstChild("TopbarStandard")
        if not tbs then return nil end
        for _, desc in ipairs(tbs:GetDescendants()) do
            if desc:IsA("TextLabel") and desc.Text and string.find(desc.Text, "⏱") then
                cachedTimerLabel = desc
                return desc.Text
            end
        end
        return nil
    end)
    return pcallOk and text or nil
end

local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then return (tonumber(m) or 0) * 60 + (tonumber(s) or 0) end
    end
    local n = string.match(t, "(%d+)")
    if n then return tonumber(n) end
    return nil
end


