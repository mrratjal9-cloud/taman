-- ║              CLEANUP TERPUSAT (V4 hard-kill)              ║
-- ╚══════════════════════════════════════════════════════════╝
-- Dipanggil saat tombol Close (X) ditekan. Tugasnya:
--   1) Set semua flag ke false -> semua loop background exit di
--      iterasi berikutnya (paling lambat ~0.5s).
--   2) Cancel in-flight Humanoid:MoveTo() -> karakter freeze
--      INSTAN di posisi sekarang, gak ada sisa langkah.
--   3) Disconnect connection di service (UserInputService) yang
--      gak auto-clean waktu ScreenGui:Destroy().
--   4) Destroy ScreenGui -> semua child connection (TopBar dsb)
--      ikut auto-disconnect.
local function cleanupAndDestroy()
    -- (1) Stop semua loop
    isRunning              = false
    replayRunning          = false
    autoJalanState.enabled = false
    autoJalanState.running = false

    -- (2) Hard-kill movement: cancel MoveTo karakter
    stopHumanoidMovement()

    -- (3) Disconnect listener service-level
    for _, conn in ipairs(activeConnections) do
        pcall(function() conn:Disconnect() end)
    end
    activeConnections = {}

    -- (4) Hancurkan GUI
    if ScreenGui and ScreenGui.Parent then
        ScreenGui:Destroy()
    end

    dprint("Cleanup selesai. Script TOTAL OFF.")
end

