-- ╔══════════════════════════════════════════════════════════╗
-- ║      LAYER 3: UserInputService global manual hit-test     ║
-- ╚══════════════════════════════════════════════════════════╝
-- Ini failsafe: kalau Layer 2 gak fire (executor weird,
-- input ke-block), Layer 3 PASTI jalan karena UserInputService
-- global ALWAYS menerima input.
--
-- Cara kerja: tiap user klik layar, kita cek apakah koordinat
-- klik berada di atas tombol panel (pakai AbsolutePosition +
-- AbsoluteSize). Kalau iya, panggil handler-nya.
-- Drag panel juga di-handle di sini.

local function pointInButton(btn, x, y)
    if not btn or not btn.Parent or not btn.Visible then return false end
    local ap = btn.AbsolutePosition
    local as = btn.AbsoluteSize
    return x >= ap.X and x <= ap.X + as.X
       and y >= ap.Y and y <= ap.Y + as.Y
end

local function isVisibleClickable(btn)
    if not btn or not btn.Parent then return false end
    local p = btn.Parent
    while p and p ~= ScreenGui do
        if p == ContentFrame and not ContentFrame.Visible then return false end
        p = p.Parent
    end
    return true
end

-- DRAG state untuk Layer 3
local L3_dragging = false
local L3_dragStart = Vector2.new()
local L3_panelStart = UDim2.new()

trackConnection(UserInputService.InputBegan:Connect(function(input, processed)
    if not isRunning then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1
       and input.UserInputType ~= Enum.UserInputType.Touch then
        return
    end

    local x = input.Position.X
    local y = input.Position.Y

    -- 1) Close (paling penting - selalu bisa dimatikan)
    if isVisibleClickable(CloseBtn) and pointInButton(CloseBtn, x, y) then
        dprint("L3 hit: Close")
        handleClose()
        return
    end
    -- 2) Minimize
    if isVisibleClickable(MinimizeBtn) and pointInButton(MinimizeBtn, x, y) then
        dprint("L3 hit: Minimize")
        handleMinimize()
        return
    end
    -- 3) Speed buttons
    for n, b in pairs(speedButtons) do
        if isVisibleClickable(b) and pointInButton(b, x, y) then
            dprint("L3 hit: Speed " .. n)
            handleSpeedClick(n)
            return
        end
    end
    -- 4) Pause
    if isVisibleClickable(PauseBtn) and pointInButton(PauseBtn, x, y) then
        dprint("L3 hit: Pause")
        handlePause()
        return
    end
    -- 5) Auto skip toggle
    if isVisibleClickable(AutoSkipBtnUI) and pointInButton(AutoSkipBtnUI, x, y) then
        dprint("L3 hit: AutoSkip toggle")
        handleAutoSkipToggle()
        return
    end
    -- 6) Manual skip toggle
    if isVisibleClickable(ManualSkipBtnUI) and pointInButton(ManualSkipBtnUI, x, y) then
        dprint("L3 hit: ManualSkip toggle")
        handleManualSkipToggle()
        return
    end
    -- 7) Drag (klik di topbar tapi BUKAN di tombol close/minimize)
    if pointInButton(TopBar, x, y) then
        L3_dragging = true
        L3_dragStart = Vector2.new(x, y)
        L3_panelStart = MainFrame.Position
        dprint("L3 drag start")
    end
end))

trackConnection(UserInputService.InputChanged:Connect(function(input)
    if not isRunning then return end
    if not L3_dragging then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement
       and input.UserInputType ~= Enum.UserInputType.Touch then
        return
    end
    local x = input.Position.X
    local y = input.Position.Y
    local dx = x - L3_dragStart.X
    local dy = y - L3_dragStart.Y
    MainFrame.Position = UDim2.new(
        L3_panelStart.X.Scale, L3_panelStart.X.Offset + dx,
        L3_panelStart.Y.Scale, L3_panelStart.Y.Offset + dy
    )
end))

trackConnection(UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
       or input.UserInputType == Enum.UserInputType.Touch then
        if L3_dragging then
            L3_dragging = false
            dprint("L3 drag end")
        end
    end
end))


-- ╔══════════════════════════════════════════════════════════╗
-- ║   AUTO-APPLY GameSpeed di awal eksekusi (sesuai Config)   ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    local startedAt = os.clock()
    while isRunning and (os.clock() - startedAt) < WatchdogConfig.SpeedApplyTimeout do
        if applyGameSpeed(SpeedConfig.GameSpeed) then
            setStatus("Initial Speed -> " .. SpeedConfig.GameSpeed .. "x ter-apply.")
            return
        end
        task.wait(1)
    end
    setStatus("Initial speed timeout. Akan retry saat round mulai.",
        Color3.fromRGB(220, 200, 120))
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       MAIN LOOP                           ║
-- ╚══════════════════════════════════════════════════════════╝
math.randomseed(tick() % 1 * 1e7 + os.time())

task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        local jitter = AntiFlagConfig.LoopIntervalMin
            + math.random() * (AntiFlagConfig.LoopIntervalMax - AntiFlagConfig.LoopIntervalMin)
        task.wait(jitter)

        if not isRunning then break end

        if isPausedByUser then
            -- skip
        else
            local now = os.clock()
            local statusParts = {}
            local wc = getWaveControls()

            -- Re-apply speed saat round baru
            if wc and wc ~= lastSeenWaveControls then
                if lastSeenWaveControls ~= nil then
                    dprint("Round baru, re-apply speed.")
                    task.spawn(function()
                        task.wait(0.5)
                        applyGameSpeed(SpeedConfig.GameSpeed)
                    end)
                    table.insert(statusParts, "Re-apply " .. SpeedConfig.GameSpeed .. "x")
                end
                lastSeenWaveControls = wc
                pathMissingCounter = 0
            end

            if not wc then
                pathMissingCounter = pathMissingCounter + 1
                if pathMissingCounter >= WatchdogConfig.PathMissingWarnAt then
                    setStatus("Path WaveControls hilang. Game di lobby? atau path UI berubah?",
                        Color3.fromRGB(220, 130, 130))
                else
                    setStatus("Standby (bukan di gameplay).")
                end
            else
                pathMissingCounter = 0

                -- AUTO SKIP
                if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AntiFlagConfig.AutoSkipCooldown then
                    local btn = getAutoSkipButton()
                    local titleLabel = btn and btn:FindFirstChild("Title")
                    local titleText = (titleLabel and titleLabel:IsA("TextLabel")) and titleLabel.Text or ""
                    if btn and string.find(string.lower(titleText), "off") then
                        if safeClick(btn) then
                            lastAutoSkipClickAt = os.clock()
                            table.insert(statusParts, "AutoSkip clicked")
                        end
                    end
                end

                -- MANUAL SKIP
                if Config.ManualSkip then
                    local cd = AntiFlagConfig.ManualCooldownMin
                        + math.random() * (AntiFlagConfig.ManualCooldownMax - AntiFlagConfig.ManualCooldownMin)
                    if (now - lastManualClickAt) >= cd then
                        local frame = getSkipWaveFrame()
                        if frame and frame.Visible then
                            local mbtn = frame:FindFirstChild("Button")
                            if mbtn then
                                if safeClick(mbtn) then
                                    table.insert(statusParts, "SkipWave clicked")
                                    lastManualClickAt = os.clock()
                                end
                            end
                        end
                    end
                end

                if #statusParts == 0 then
                    setStatus("Watching... | AS=" .. tostring(Config.AutoSkip)
                        .. "  MS=" .. tostring(Config.ManualSkip)
                        .. "  Speed=" .. SpeedConfig.GameSpeed .. "x")
                else
                    setStatus(table.concat(statusParts, " | "), Color3.fromRGB(255, 220, 120))
                end
            end
        end
    end
    dprint("Main loop berhenti.")
end)

print(string.format(
    "[SkipV6] Loaded. AutoSkip=%s | ManualSkip=%s | GameSpeed=%dx | Parent=%s",
    tostring(Config.AutoSkip),
    tostring(Config.ManualSkip),
    SpeedConfig.GameSpeed,
    tostring(ScreenGui.Parent and ScreenGui.Parent.Name or "?")
))
print("[SkipV6] Coba klik tombol di panel - kalau Layer 2 gak fire, Layer 3 (UIS global) akan handle.")
