-- Logic dipisah dari event-binding biar bisa di-trigger dari
-- LAYER 2 (MouseButton1Click) maupun LAYER 3 (UserInputService
-- global manual hit-test).

local function flashClick(btn)
    if not CLICK_FLASH then return end
    if not btn or not btn.Parent then return end
    local original = btn.BackgroundColor3
    btn.BackgroundColor3 = Color3.fromRGB(60, 180, 255)
    task.delay(0.12, function()
        if btn and btn.Parent then
            btn.BackgroundColor3 = original
        end
    end)
end

local function refreshToggle(btn, label, state)
    btn.BackgroundColor3 = state and Color3.fromRGB(50, 160, 70) or Color3.fromRGB(160, 50, 50)
    btn.Text = label .. (state and "  :  ON" or "  :  OFF")
end

local handleMinimize, handleClose, handlePause,
      handleAutoSkipToggle, handleManualSkipToggle,
      handleSpeedClick

handleMinimize = function()
    isMinimized = not isMinimized
    ContentFrame.Visible = not isMinimized
    MainFrame.Size = isMinimized and UDim2.new(0, 280, 0, 32) or UDim2.new(0, 280, 0, 320)
    flashClick(MinimizeBtn)
    dprint("Minimize ->", isMinimized)
end

handleClose = function()
    dprint("Close pressed. Killing script...")
    isRunning = false
    for _, c in ipairs(_connections) do
        pcall(function() c:Disconnect() end)
    end
    _connections = {}
    pcall(function() ScreenGui:Destroy() end)
end

handlePause = function()
    isPausedByUser = not isPausedByUser
    flashClick(PauseBtn)
    if isPausedByUser then
        PauseBtn.Text = "RESUME (sekarang PAUSED)"
        PauseBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        PauseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        setStatus("PAUSED oleh user.", Color3.fromRGB(220, 160, 40))
    else
        PauseBtn.Text = "PAUSE ALL (kalau ngebug, pencet ini)"
        PauseBtn.BackgroundColor3 = Color3.fromRGB(220, 160, 40)
        PauseBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        setStatus("Resumed.")
    end
end

