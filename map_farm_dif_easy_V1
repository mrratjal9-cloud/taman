    isRunning = false
    ScreenGui:Destroy()
end)

local function setScriptState(state)
    isRunning = state
    if isRunning then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        ToggleBtn.Text = "Status: ON"
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        ToggleBtn.Text = "Status: OFF"
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    setScriptState(not isRunning)
end)

-- ==========================================
-- AUTO WAVE DETECTOR (BACKGROUND)
-- ==========================================
local lastWaveNum = -1
task.spawn(function()
    while task.wait(1) do
        if WAVE_CONTROL then
            local pGui = LocalPlayer:FindFirstChild("PlayerGui")
            if not pGui then continue end
            
            local ggn = pGui:FindFirstChild("GameGuiNoInset")
            local screen = ggn and ggn:FindFirstChild("Screen")
            local top = screen and screen:FindFirstChild("Top")
            local info = top and top:FindFirstChild("GameInfo")
            local content = info and info:FindFirstChild("Content")
            local waves = content and content:FindFirstChild("Waves")
            local title = waves and waves:FindFirstChild("Title")

            if title and title.Text ~= "" then
                local match = string.match(title.Text, "Wave%s*(%d+)") or string.match(title.Text, "WAVE%s*(%d+)")
                
                if match then
                    local currentWaveNum = tonumber(match)
                    if currentWaveNum ~= lastWaveNum then
                        lastWaveNum = currentWaveNum
                        print("Wave saat ini: " .. currentWaveNum)
                        
                        if currentWaveNum == START_WAVE and not isRunning then
                            print("Mencapai Start Wave! Mengaktifkan Script...")
                            setScriptState(true)
                        elseif currentWaveNum == STOP_WAVE and isRunning then
                            print("Mencapai Stop Wave! Mematikan Script...")
                            setScriptState(false)
                        end
                    end
                end
            end
        end
    end
end)

