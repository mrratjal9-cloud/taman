-- MAIN LOOP (BACKGROUND PROCESS)
-- ==========================================
task.spawn(function()
    while task.wait(LOOP_DELAY) do
        if isRunning then
            pcall(function()
                -- Memilih salah satu data penempatan dari tabel secara acak
                local randomPlace = PLACEMENTS[math.random(1, #PLACEMENTS)]

                -- Payload disesuaikan khusus untuk TARGET_UNIT
                local args = {
                    TARGET_UNIT,
                    {
                        CF = randomPlace.CF,
                        Rotation = 0,
                        Valid = true,
                        Position = randomPlace.Position
                    }
                }
                ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("PlaceUnit"):InvokeServer(unpack(args))
            end)
        end
    end
end)
