-- ==========================================
-- HELPERS
-- ==========================================
local function safeFindChild(parent, name)
    if not parent then return nil end
    return parent:FindFirstChild(name)
end

local function getRemote(name)
    local remotes = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if not remotes then return nil end
    return remotes:FindFirstChild(name)
end

local function invokeRemote(name, ...)
    local r = getRemote(name)
    if not r then
        warn("[AutoReplayV4] Remote tidak ditemukan: " .. name)
        return false
    end
    local args = { ... }
    local ok, err = pcall(function() r:InvokeServer(unpack(args)) end)
    if not ok then warn("[AutoReplayV4] Invoke " .. name .. " gagal: " .. tostring(err)) end
    return ok
end

-- ==========================================
-- VIRTUAL CLICK (3-method robust) -- sama seperti V3
-- ==========================================
local function clickViaConnections(button)
    if typeof(getconnections) ~= "function" then return false end
    local fired = false
    local signals = { "MouseButton1Click", "Activated", "MouseButton1Down", "MouseButton1Up" }
    for _, sig in ipairs(signals) do
        pcall(function()
            local ev = button[sig]
            if ev then
                local conns = getconnections(ev)
                if conns then
                    for _, c in ipairs(conns) do
                        local ok = pcall(function() c:Fire() end)
                        if not ok and typeof(firesignal) == "function" then
                            pcall(function() firesignal(c) end)
                        end
                        fired = true
                    end
                end
            end
        end)
    end
    return fired
end

local function clickViaFiresignal(button)
    if typeof(firesignal) ~= "function" then return false end
    local signals = { "MouseButton1Down", "MouseButton1Up", "MouseButton1Click", "Activated" }
    local fired = false
    for _, sig in ipairs(signals) do
        pcall(function()
            if button[sig] then
                firesignal(button[sig])
                fired = true
            end
        end)
    end
    return fired
end

local function clickViaVIM(button)
    if not VirtualInputManager then return false end
    local ok = pcall(function()
        local pos  = button.AbsolutePosition
        local size = button.AbsoluteSize
        local x = pos.X + size.X / 2
        local y = pos.Y + size.Y / 2
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true,  game, 0)
        task.wait(0.07)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
    return ok
end

local function virtualClick(button, attempt)
    if not button then return end
    attempt = attempt or 1

    local targets = { button }
    local title = button:FindFirstChild("Title")
    if title and (title:IsA("TextLabel") or title:IsA("ImageLabel") or title:IsA("TextButton") or title:IsA("ImageButton")) then
        table.insert(targets, title)
    end

    for _, t in ipairs(targets) do
        if attempt == 1 then
            clickViaConnections(t)
            clickViaFiresignal(t)
        elseif attempt == 2 then
            clickViaFiresignal(t)
            clickViaVIM(t)
        else
            clickViaVIM(t)
            clickViaConnections(t)
            clickViaFiresignal(t)
        end
    end
end

-- ==========================================
-- PATH RESOLVERS
-- ==========================================
local function getAgainButton()
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local gameEnd = safeFindChild(middle, "GameEnd")
    local items1  = safeFindChild(gameEnd, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local actions = safeFindChild(frame, "Actions")
    local items2  = safeFindChild(actions, "Items")
    local again   = safeFindChild(items2, "Again")
    return again, gameEnd
end

-- Cari tombol difficulty berdasarkan nama yang diberikan (bukan TARGET_DIF konstan)
local function getDifficultyButtonByName(difName)
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local difVote = safeFindChild(middle, "DifficultyVote")
    local items1  = safeFindChild(difVote, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local items2  = safeFindChild(frame, "Items")
    local items3  = safeFindChild(items2, "Items")
    local btn     = safeFindChild(items3, difName)
    return btn, difVote
end

-- ==========================================
-- MAIN LOOP (PRIORITAS GameEnd) -- struktur sama seperti V3
-- ==========================================
task.spawn(function()
    setStatus(isRunning and "Running..." or "Paused")
    while true do
        task.wait(LOOP_INTERVAL)

        local ok, err = pcall(function()
            if not isRunning then return end
            local now = os.clock()

            -- ============================================
            -- PRIORITAS 1: GameEnd / Play Again
            -- ============================================
            local againBtn, gameEnd = getAgainButton()
            if gameEnd and gameEnd.Visible == true then
                if (now - lastAgainAt) < COOLDOWN_AGAIN then return end

                if not againBtn then
                    setStatus("GameEnd visible tapi tombol Again belum ready...")
                    return
                end

                clickAttempt = clickAttempt + 1
                if clickAttempt > 3 then clickAttempt = 1 end

                setStatus(string.format("Klik Play Again (method %d)...", clickAttempt))
                print("[AutoReplayV4] Klik Play Again, attempt =", clickAttempt)

                virtualClick(againBtn, clickAttempt)
                lastAgainAt = os.clock()

                task.wait(CLICK_VERIFY_T)
                local _, geAfter = getAgainButton()
                if (not geAfter) or (geAfter.Visible == false) then
                    setStatus("Play Again berhasil di-klik!")
                    clickAttempt = 0
                else
                    setStatus(string.format("Klik gagal (method %d), retry method berikutnya...", clickAttempt))
                end
                return
            end

            -- ============================================
            -- PRIORITAS 2: DifficultyVote (hanya jika GameEnd hilang)
            -- ============================================
            -- Cek visibility DifficultyVote terlebih dulu pakai
            -- nama difficulty apapun (untuk dapatkan reference difVote)
            local _, difVote = getDifficultyButtonByName(TARGET_DIF)
            if difVote and difVote.Visible == true then
                if (now - lastVoteAt) < COOLDOWN_VOTE then return end

                -- Tentukan difficulty utk ronde ini
                local chosenDif, isRandom = decideNextDif()
                local difBtn = getDifficultyButtonByName(chosenDif)

                -- Fallback: kalau button utk chosenDif belum muncul,
                -- coba pakai TARGET_DIF biar tetap aman (tidak stuck).
                if not difBtn and chosenDif ~= TARGET_DIF then
                    warn("[AutoReplayV4] Button " .. chosenDif .. " tidak ditemukan, fallback ke " .. TARGET_DIF)
                    chosenDif = TARGET_DIF
                    isRandom  = false
                    difBtn    = getDifficultyButtonByName(chosenDif)
                end

                if isRandom then
                    setStatus("[RANDOM #" .. (gameplayCount + 1) .. "] Vote " .. chosenDif .. " + RestartGame...")
                    print("[AutoReplayV4] RANDOM mode -> dif =", chosenDif)
                else
                    setStatus("Vote " .. chosenDif .. " + RestartGame...")
                    print("[AutoReplayV4] Vote difficulty:", chosenDif)
                end

                if difBtn then
                    virtualClick(difBtn, 1)
                    task.wait(0.25)
                end

                invokeRemote("PlaceDifficultyVote", chosenDif)
                task.wait(0.4)
                local restartOk = invokeRemote("RestartGame")

                lastVoteAt = os.clock()

                -- Hanya naikkan counter kalau restart berhasil di-fire
                if restartOk then
                    gameplayCount = gameplayCount + 1
                    lastVotedDif  = chosenDif
                    refreshCounterUI()
                end

                setStatus("RestartGame fired (" .. chosenDif .. "). Tunggu game restart...")
                task.wait(1)
                return
            end

            -- IDLE
            setStatus("Running... (menunggu GameEnd / DifficultyVote)")
        end)

        if not ok then
            warn("[AutoReplayV4] Iterasi error: " .. tostring(err))
            setStatus("Error: " .. tostring(err))
        end
    end
end)

print(string.format(
    "[AutoReplayV4] Loaded. Difficulty=%s | Status=%s | Randomness=%s every %d",
    TARGET_DIF,
    isRunning and "ON" or "OFF",
    RANDOMNESS_ENABLED and "ON" or "OFF",
    RANDOMNESS_INTERVAL
))
