local function refreshCounterUI()
    CounterLbl.Text = "Gameplay: " .. gameplayCount .. " | Last: " .. lastVotedDif
    if RANDOMNESS_ENABLED and RANDOMNESS_INTERVAL > 0 then
        local nextNum = gameplayCount + 1
        local untilRand = (RANDOMNESS_INTERVAL - (gameplayCount % RANDOMNESS_INTERVAL))
        if untilRand == RANDOMNESS_INTERVAL then untilRand = RANDOMNESS_INTERVAL end
        local isRandNext = (nextNum % RANDOMNESS_INTERVAL == 0)
        if isRandNext then
            NextLbl.Text = "Next (#" .. nextNum .. "): RANDOM"
            NextLbl.TextColor3 = Color3.fromRGB(255, 200, 120)
        else
            NextLbl.Text = "Next (#" .. nextNum .. "): " .. TARGET_DIF
                .. "  | random in " .. untilRand
            NextLbl.TextColor3 = Color3.fromRGB(180, 220, 180)
        end
    else
        NextLbl.Text = "Next: " .. TARGET_DIF .. " (random OFF)"
        NextLbl.TextColor3 = Color3.fromRGB(180, 220, 180)
    end
end
