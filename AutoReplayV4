-- ==========================================
-- AUTO REPLAY V4 (V3 + Randomness Mode)
-- Perubahan dari V3:
--   FITUR BARU:
--     a) RANDOMNESS_ENABLED  -> on/off fitur random difficulty.
--     b) RANDOMNESS_INTERVAL -> setiap N gameplay sekali, difficulty
--        di-pilih random dari list:
--          { dif_easy, dif_normal, dif_hard, dif_insane,
--            dif_impossible, dif_apocalypse }
--        Setelah itu kembali normal pakai TARGET_DIF.
--
--   CONTOH:
--     Misal RANDOMNESS_INTERVAL = 5, TARGET_DIF = "dif_easy".
--       Game 1 -> dif_easy
--       Game 2 -> dif_easy
--       Game 3 -> dif_easy
--       Game 4 -> dif_easy
--       Game 5 -> RANDOM (misal dif_insane)
--       Game 6 -> dif_easy
--       Game 7 -> dif_easy
--       ...
--       Game 10 -> RANDOM (misal dif_normal)
--       Game 11 -> dif_easy
--
--   Semua logika V3 (state machine GameEnd > DifficultyVote,
--   virtualClick 3-method, click verification) DIPERTAHANKAN.
-- ==========================================

-- ==========================================
-- CONFIGURATION
-- ==========================================
local AUTO_START          = true
local TARGET_DIF          = "dif_easy"
local LOOP_INTERVAL       = 0.4
local COOLDOWN_AGAIN      = 1.5    -- cooldown lebih kecil agar retry cepat
local COOLDOWN_VOTE       = 4
local CLICK_VERIFY_T      = 0.8    -- waktu tunggu verifikasi klik berhasil

-- Randomness Config (FITUR BARU V4)
local RANDOMNESS_ENABLED  = true   -- true = aktifkan fitur random difficulty
local RANDOMNESS_INTERVAL = 5      -- random terjadi setiap N gameplay

