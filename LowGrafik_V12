local function formatTime(sec)
    sec = math.floor(sec or 0)
    if sec < 0 then sec = 0 end
    local d = math.floor(sec / 86400)
    local h = math.floor((sec % 86400) / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60
    if d > 1 then return string.format("%d Days %02d:%02d:%02d", d, h, m, s)
    elseif d == 1 then return string.format("%d Day %02d:%02d:%02d", d, h, m, s)
    elseif h > 0 then return string.format("%02d:%02d:%02d", h, m, s)
    else return string.format("%02d:%02d", m, s) end
end

local function formatMMSS(sec)
    if sec <= 0 then return "00:00" end
    local h = math.floor(sec / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60
    if h > 0 then return string.format("%02d:%02d:%02d", h, m, s) end
    return string.format("%02d:%02d", m, s)
end

local function formatNumber(n)
    n = tostring(n or 0)
    local out, count = "", 0
    for i = #n, 1, -1 do
        out = string.sub(n, i, i) .. out
        count = count + 1
        if count % 3 == 0 and i > 1 then out = "," .. out end
    end
    return out
end

local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then return (tonumber(m) or 0) * 60 + (tonumber(s) or 0) end
    end
    local n = string.match(t, "(%d+)")
    if n then return tonumber(n) end
    return nil
end

local cachedTimerLabel = nil
local function getInGameTimer()
    if cachedTimerLabel and cachedTimerLabel.Parent then return cachedTimerLabel.Text end
    local pcallOk, text = pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        local tbs = pGui and pGui:FindFirstChild("TopbarStandard")
        if not tbs then return nil end
        for _, desc in ipairs(tbs:GetDescendants()) do
            if desc:IsA("TextLabel") and desc.Text and string.find(desc.Text, "⏱") then
                cachedTimerLabel = desc 
                return desc.Text
            end
        end
        return nil
    end)
    return pcallOk and text or nil
end

