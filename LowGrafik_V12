            local totalPlayTime = os.time() - SCRIPT_START_TIME
            waveLabel.Text = "🌊 " .. stats.Wave

            local currentTime = os.time()
            local sTime = math.max(0, getgenv().AkbarNerfEndTimes.SeedsMult - currentTime)
            local gTime = math.max(0, getgenv().AkbarNerfEndTimes.SpaceGemsMult - currentTime)
            local tTime = math.max(0, getgenv().AkbarNerfEndTimes.TicketsMult - currentTime)

            local nerfText = ""
            if sTime == 0 and gTime == 0 and tTime == 0 then
                if stats.IsFlagged then
                    nerfText = "\n🚨 Nerf Time      : <font color=\"#FF5555\"><b>Syncing...</b></font>"
                else
                    nerfText = "\n🚨 Nerf Time      : <font color=\"#55FF55\"><b>Safe (00:00)</b></font>"
                end
            elseif sTime == gTime and gTime == tTime then
                nerfText = "\n🚨 Nerf Time      : <font color=\"#FF5555\"><b>" .. formatMMSS(sTime) .. "</b></font>"
            else
                nerfText = string.format(
                    "\n🚨 Nerf Times     :\n" ..
                    "  🌱 Seeds        : <font color=\"#FF5555\"><b>%s</b></font>\n" ..
                    "  💎 Gems         : <font color=\"#FF5555\"><b>%s</b></font>\n" ..
                    "  🎫 Ticket       : <font color=\"#FF5555\"><b>%s</b></font>",
                    formatMMSS(sTime), formatMMSS(gTime), formatMMSS(tTime)
                )
            end

            -- TEKS STATISTIK MENGGUNAKAN GETGENV() TRACKER STATE AGAR BERTAMBAH
            statsLabel.Text = string.format(
                "🌱 Seed Now       : <font color=\"#FFFFFF\"><b>%s</b></font>\n" ..
                "🌱 Last Round     : <font color=\"#FFFFFF\"><b>+%s</b></font>\n" ..
                "🌱 Total Earned   : <font color=\"#FFFFFF\"><b>+%s</b></font>\n" ..
                "⏱️ Round Time     : <font color=\"#FFFFFF\"><b>%s</b></font>\n" ..
                "⏱️ Last Game      : <font color=\"#FFFFFF\"><b>%s</b></font>\n" ..
                "⏱️ Total Playtime : <font color=\"#FFFFFF\"><b>%s</b></font>%s",
                formatNumber(stats.SeedNow),
                formatNumber(state.LastRoundSeed),
                formatNumber(state.TotalEarnedSeed),
                formatMMSS(localMatchSec),
                formatMMSS(lastGameTime),
                formatTime(totalPlayTime),
                nerfText
            )

            footerLabel.Text = "===============================\nTinggalkan perangkat dengan tenang."

            local nm = (LocalPlayer and LocalPlayer.DisplayName ~= "" and LocalPlayer.DisplayName) or (LocalPlayer and LocalPlayer.Name) or "Player"
            if playerNameLabel.Text ~= nm then
                playerNameLabel.Text = nm
            end
        end
    end
end)

