local function SyncInitialTime()
    pcall(function()
        local boostHolder = LocalPlayer.PlayerGui.GameGui.Screen.BottomLeft:FindFirstChild("BoostHolder")
        if not boostHolder then return end
        
        for _, buffFrame in pairs(boostHolder:GetChildren()) do
            if buffFrame:IsA("ImageLabel") or buffFrame:IsA("Frame") then
                local btn = buffFrame:FindFirstChildWhichIsA("ImageButton")
                if btn then
                    if firesignal then firesignal(btn.MouseEnter) 
                    elseif getconnections then for _, c in pairs(getconnections(btn.MouseEnter)) do c:Fire() end end
                    
                    task.wait(0.1)
                    local info = buffFrame:FindFirstChild("Info")
                    if info then
                        for _, el in pairs(info:GetDescendants()) do
                            if el:IsA("TextLabel") and el.Text and string.find(el.Text, "Macro Nerf") then
                                local m, s = string.match(el.Text, "%((%d+):(%d+)%)")
                                if m and s then
                                    local totalSecs = (tonumber(m) * 60) + tonumber(s)
                                    local targetEndTime = os.time() + totalSecs
                                    getgenv().AkbarNerfEndTimes.SeedsMult = targetEndTime
                                    getgenv().AkbarNerfEndTimes.SpaceGemsMult = targetEndTime
                                    getgenv().AkbarNerfEndTimes.TicketsMult = targetEndTime
                                end
                            end
                        end
                    end
                    if firesignal then firesignal(btn.MouseLeave)
                    elseif getconnections then for _, c in pairs(getconnections(btn.MouseLeave)) do c:Fire() end end
                end
            end
        end
    end)
end
