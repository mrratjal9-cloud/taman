local function onNotificationAdded(child)
    local lbl = child:WaitForChild("Label", 5) 
    if lbl and lbl:IsA("TextLabel") then
        local function check()
            if state.ProcessedSeeds[child.Name] then return end 
            local amountStr = string.match(lbl.Text, "You got ([%d,]+) Seeds!")
            if amountStr then
                local num = tonumber((string.gsub(amountStr, ",", "")))
                if num then
                    state.ProcessedSeeds[child.Name] = true 
                    state.LastRoundSeed = num
                    state.TotalEarnedSeed = state.TotalEarnedSeed + num
                end
            end
        end
        check()
        lbl:GetPropertyChangedSignal("Text"):Connect(check)
    end
end

getgenv().AkbarTrackerConn = NotifyClient.ChildAdded:Connect(onNotificationAdded)
