            task.wait(0.3)

        elseif capReached then
            currentPhase = "cap-reached"
            local cnt = CONFIG.CAP_COUNT_ONLY_TARGET and lastUITargetCount or lastUIAllUnits
            setBanner(string.format("CAP REACHED: %d/%d", cnt, CONFIG.PlacementUnitMaxCap),
                Color3.fromRGB(120, 220, 120))
            refreshStats()
            task.wait(1.0)

        else
            local unlockOk, gateReason = unlockGateOk()
            if not unlockOk then
                currentPhase = "locked"
                setBanner("LOCKED: " .. gateReason, Color3.fromRGB(255, 100, 100))
                refreshStats()
                task.wait(0.10)
            else
                -- (V17) Putuskan: priority dulu atau langsung main?
                --   * Belum waveReady: prioritas dulu (random shuffle)
                --   * waveReady & MAIN_REQUIRES_PRIORITY_OK=true: prio block main (lama)
                --   * waveReady & MAIN_FORCE_AFTER_WAVE=false: prio masih dominan
                --   * waveReady & MAIN_FORCE_AFTER_WAVE=true (DEFAULT V17):
                --        MAIN dominan, tapi tiap iterasi ada peluang
                --        PRIORITY_INTERLEAVE_CHANCE utk coba priority
                --        sehingga slot yg pending tetap diberi kesempatan
                --        TANPA membuat main stuck.
                local pendingP   = hasPendingPriority()
                local waveReady  = (lastWaveNum >= CONFIG.MAIN_START_WAVE)
                local doPriority = false
                if pendingP then
                    if not waveReady then
                        doPriority = true
                    elseif CONFIG.MAIN_REQUIRES_PRIORITY_OK then
                        doPriority = true
                    elseif not CONFIG.MAIN_FORCE_AFTER_WAVE then
                        doPriority = true
                    else
                        -- DEFAULT: interleave kecil utk priority sambil main lanjut
                        local p = CONFIG.PRIORITY_INTERLEAVE_CHANCE or 0.25
                        if p > 0 and math.random() < p then
                            doPriority = true
                        end
                    end
                end

                if doPriority then
                    currentPhase = "priority (RANDOM)"
                    -- (V17 FIX #1) ambil slot priority dari shuffled bag (RANDOM)
                    local target = selectNextPrioritySlot()
                    if target then
                        local burst = inBurstMode()
                        setBanner(string.format("PRIORITY P%d  (try %d) [RANDOM]%s",
                            target, priorityAttempts[target] + 1,
                            burst and "  [BURST]" or ""),
                            burst and Color3.fromRGB(255, 240, 80)
                                  or  Color3.fromRGB(255, 220, 100))
                        local pOk = pcall(placePrioritySlot, target)
                        refreshStats()
                        local d
                        if not pOk or not prioritySatisfied[target] then
                            d = CONFIG.PRIORITY_FAIL_DELAY or 0.15
                        elseif burst then
                            d = CONFIG.FAST_PLACE_DELAY or 0
                        else
                            d = CONFIG.PRIORITY_DELAY or 0.1
                        end
                        safeYield(d)
                    else
                        -- tak ada slot pending priority valid -> fall through ke main next iter
                        task.wait(0.05)
                    end

                elseif waveReady then
                    -- (V17 FIX #3) MAIN WAJIB jalan
                    local canMain, reason = canStartMainPhase()
                    if not canMain then
                        currentPhase = "waiting-gate"
                        setBanner("WAIT: " .. reason, Color3.fromRGB(255, 200, 100))
                        refreshStats()
                        task.wait(0.15)
                    else
                        local burst = inBurstMode()
                        local pTag  = hasGivenUpPriority() and " (P-giveup)" or ""
                        if isBackupActive() then
