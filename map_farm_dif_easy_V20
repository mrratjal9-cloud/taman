                            local jit   = CONFIG.LOOP_JITTER or 0
                            local extra = (jit > 0) and randFloat(-jit, jit) or 0
                            safeYield(math.max(0.01, base + extra))
                        end
                    end
                else
                    -- belum waveReady & tidak ada priority pending -> tunggu wave
                    currentPhase = "waiting-wave"
                    setBanner(string.format("WAIT WAVE >=%d (now=%s)",
                        CONFIG.MAIN_START_WAVE,
                        (lastWaveNum >= 0 and tostring(lastWaveNum) or "-")),
                        Color3.fromRGB(255, 200, 100))
                    refreshStats()
                    task.wait(0.15)
                end
            end
        end
    end
end)

