-- ==========================================
-- TIMER READER (V20 - cached widget fast-path + dual-format parser)
-- ==========================================
-- (V20 FIX #1) parseMMSS sekarang menerima DUA format:
--   Format 1: "M:SS"   -> "⏱ 1:00", "⏱ 5:23", "0:45"
--   Format 2: detik   -> "⏱ 0", "⏱ 10", "⏱ 56", "⏱ 59"
-- Logika:
--   * Kalau text mengandung ":", parse pakai pola lama (M:SS).
--   * Kalau text TIDAK mengandung ":", ambil angka pertama
--     sebagai detik mentah (sanity range 0-99 supaya tidak
--     salah ambil angka dari widget non-timer yg kebetulan
--     punya angka besar).
-- Return: jumlah detik total (number) atau nil kalau tidak match.
local function parseMMSS(t)
    if type(t) ~= "string" then return nil end

    -- Format 1: ada ":" -> MM:SS
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then
            local mm = tonumber(m) or 0
            local ss = tonumber(s) or 0
            if ss <= 99 then
                return mm * 60 + ss
            end
        end
        return nil
    end

    -- Format 2: tanpa ":" -> ambil angka pertama, anggap detik
    -- (range 0-99 untuk safety: timer game tidak akan pernah
    -- nampilin detik 3-digit tanpa ":". Angka >=100 tanpa ":"
    -- biasanya widget lain yg kebetulan ada angkanya, jadi kita
    -- tolak supaya tidak salah identifikasi.)
    local n = string.match(t, "(%d+)")
    if n then
        local v = tonumber(n)
        if v and v >= 0 and v <= 99 then
            return v
        end
    end
    return nil
end

-- (V17) Holders.Right punya BANYAK Widget. Timer game ASLI selalu
-- diawali emoji ⏱ (clock). Widget tanpa emoji ⏱ kita ANGGAP BUKAN timer
-- sehingga tidak akan ke-deteksi sebagai waktu.
local function hasClockEmoji(t)
    if type(t) ~= "string" then return false end
    -- "⏱" = U+23F1, common variants juga di-cover via plain find
    return string.find(t, "⏱", 1, true) ~= nil
end

-- (V19) Validasi cached IconLabel: HANYA cek apakah widget reference
-- masih hidup di tree (Parent ada & masih TextLabel). TIDAK lagi
-- mempersyaratkan text saat ini berupa MM:SS atau ada emoji ⏱ -
-- alasannya: antar-game text bisa sementara blank/non-MM:SS, kalau
-- kita invalidate di sini maka script akan rescan ulang & rawan
-- nyasar ke widget lain. V19 mempertahankan reference yg sama
-- selama widget masih ada di tree.
local function isCachedTimerLabelAlive()
    if not cachedTimerLabel then return false end
    local ok, alive = pcall(function()
        if not cachedTimerLabel.Parent then return false end
        if not cachedTimerLabel:IsA("TextLabel") then return false end
        return true
    end)
