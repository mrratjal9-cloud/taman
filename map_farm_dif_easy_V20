local function detectRestartFromWave(prev, cur)
    if not CONFIG.AUTO_RESET then return nil end
    if prev <= 0 then return nil end
    if CONFIG.DETECT_WAVE_DECREASE and cur < prev and prev >= 2 then
        return string.format("wave decrease %d -> %d", prev, cur)
    end
    return nil
end

-- (V16) chooseLevel sudah benar-benar mencapai threshold start (X<=1)?
local function chooseLevelDone()
    return chooseLevelSeen
       and lastChooseLevel >= 0
       and lastChooseLevel <= (CONFIG.CHOOSE_LEVEL_UNLOCK_AT or 1)
end

local function tryUnlockPlacement(source, info)
    if placementUnlocked then return end

    -- (V16 FIX #1) Gate keras: kecuali source CHOOSE_LEVEL itu sendiri,
    -- semua sumber (TIMER/COUNTDOWN/INCOMING) hanya boleh unlock kalau:
    --   - vote sudah turun ke X<=UNLOCK_AT, ATAU
    --   - vote tidak pernah muncul DAN boot sudah expired (mid-game join)
    if CONFIG.UNLOCK_REQUIRES_CHOOSE_LEVEL_DONE and source ~= "CHOOSE_LEVEL" then
        if chooseLevelDone() then
            -- ok: vote selesai countdown
        elseif (not chooseLevelSeen) and bootCompleted then
            -- ok: tidak pernah ada vote dan boot expired -> mid-game join, fallback diizinkan
        else
            if CONFIG.DEBUG_GATE then
                print(string.format(
                    "[AutoPlaceV20] unlock(%s) DIBLOK: tunggu CHOOSE_LEVEL<=%d (sekarang X=%s, seen=%s)",
                    source, CONFIG.CHOOSE_LEVEL_UNLOCK_AT or 1,
                    tostring(lastChooseLevel), tostring(chooseLevelSeen)))
            end
            return
        end
    end

    placementUnlocked     = true
    placementsSinceUnlock = 0
    unlockSource = source .. (info and (" " .. info) or "")
    print(string.format("[AutoPlaceV20] PLACEMENT UNLOCKED via %s", unlockSource))
end

-- DifficultyVote handler (V16 baru)
local function processDifficultyVote(num, raw)
    if raw then lastChooseLevelRaw = raw end
    if num then
        lastChooseLevel = num

        -- Reset detect: kalau kita sudah pernah lewat satu game (gameCount > 0)
        -- dan vote muncul lagi di gameCount yang berbeda dari terakhir kali, restart
        if CONFIG.AUTO_RESET and CONFIG.DETECT_VOTE_REAPPEAR then
            if (placementUnlocked or chooseLevelSeen)
               and voteSeenAtGame ~= -1
               and voteSeenAtGame ~= gameCount then
                -- (already handled below; we set voteSeenAtGame each time)
            end
            -- Kalau placement sudah unlock dan kita lewat wave aktif lalu vote muncul lagi
            if placementUnlocked and lastWaveNum >= CONFIG.MAIN_START_WAVE then
                print("[AutoPlaceV20] DifficultyVote muncul lagi di tengah game -> RESTART")
                pendingReset = true
                return
            end
        end

        chooseLevelSeen = true
        voteSeenAtGame = gameCount

        if CONFIG.DEBUG_VOTE then
            print(string.format("[AutoPlaceV20][VOTE] X=%d raw=%s", num, tostring(raw)))
        end

        if CONFIG.UNLOCK_ON_CHOOSE_LEVEL then
            local at = CONFIG.CHOOSE_LEVEL_UNLOCK_AT or 1
            if CONFIG.UNLOCK_ON_CHOOSE_LEVEL_ANY or num <= at then
                tryUnlockPlacement("CHOOSE_LEVEL", "(X=" .. tostring(num) .. ")")
            end
        end
    end
end

local function processTimerSnapshot(sec, raw, src)
    if raw then lastTimerRaw = raw end
    if src then lastTimerSrc = src end

    if CONFIG.DEBUG_TIMER and (os.clock() - timerDebugAt) > 1.0 then
        timerDebugAt = os.clock()
        print(string.format("[AutoPlaceV20][TIMER] sec=%s raw=%s src=%s",
            tostring(sec), tostring(raw), tostring(src)))
    end

    if not sec then return end

    if CONFIG.AUTO_RESET and CONFIG.DETECT_TIMER_RESET
       and lastTimerSec >= 0
       and sec >= lastTimerSec + (CONFIG.TIMER_RESET_JUMP or 60) then
        print(string.format("[AutoPlaceV20] timer reset %d -> %d, restart!",
            lastTimerSec, sec))
        pendingReset = true
    end

    -- (V16) timer pertama kali ke-baca >0 = unlock
    if CONFIG.UNLOCK_ON_TIMER_FIRST and lastTimerSec < 0 and sec > 0 then
        tryUnlockPlacement("TIMER_FIRST", "(" .. fmtTimer(sec) .. ")")
    end

    lastTimerSec = sec

    if CONFIG.UNLOCK_ON_TIMER and sec >= (CONFIG.TIMER_UNLOCK_THRESHOLD or 1) then
        timerSeenHigh = true
        tryUnlockPlacement("TIMER", "(" .. fmtTimer(sec) .. ")")
    end
end

local function processWaveSnapshot(num, rawText, kind)
    if rawText then lastWaveTextRaw = rawText end

    if kind == "COUNTDOWN" then
        lastCountdownSeen = num
        if CONFIG.UNLOCK_ON_COUNTDOWN then
            tryUnlockPlacement("COUNTDOWN", "(" .. tostring(num) .. ")")
        end
        return
    end

    if kind == "INCOMING" then
        if CONFIG.AUTO_RESET
           and CONFIG.DETECT_INCOMING_AFTER_STOP
           and maxWaveSeen >= CONFIG.STOP_WAVE then
            print("[AutoPlaceV20] 'Enemies incoming!' setelah max wave -> RESTART")
            pendingReset = true
            return
        end
        if not enemiesIncomingSeen then
            enemiesIncomingSeen = true
            print("[AutoPlaceV20] 'Enemies incoming!' detected -> game tracked")
        end
        if CONFIG.UNLOCK_ON_INCOMING then
            tryUnlockPlacement("INCOMING", nil)
        end
        return
    end

    if kind == "WAVE" and num then
        if not (enemiesIncomingSeen or timerSeenHigh or chooseLevelSeen) then
            return
        end
        if num ~= lastWaveNum then
            local prev = lastWaveNum
            lastWaveNum = num
            if num > maxWaveSeen then maxWaveSeen = num end

            local restartReason = detectRestartFromWave(prev, num)
            if restartReason then
                print("[AutoPlaceV20] === RESTART DETECTED === " .. restartReason)
                pendingReset = true
                maxWaveSeen = num
                return
            end

            if num == CONFIG.START_WAVE and not isRunning then
                print("[AutoPlaceV20] Reach START_WAVE -> ON")
                setScriptState(true)
            elseif num == CONFIG.STOP_WAVE and isRunning then
                print("[AutoPlaceV20] Reach STOP_WAVE -> OFF")
                setScriptState(false)
            end
        end
    end
end

