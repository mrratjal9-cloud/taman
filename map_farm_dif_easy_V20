        end
        return au, tg
    end)
    if not ok then return 0, 0 end
    return allUnits or 0, target or 0
end

local function refreshUICounts()
    local au, tg = readPlacedUnits()
    lastUIAllUnits    = au
    lastUITargetCount = tg
    local cnt = CONFIG.CAP_COUNT_ONLY_TARGET and tg or au
    capReached = cnt >= CONFIG.PlacementUnitMaxCap
end

local function checkCapBeforePlacement()
    refreshUICounts()
    return capReached
end

-- ==========================================
-- (V16 FIX #4) RECONCILE PRIORITY FROM UI
-- Kalau UI sudah baca jumlah unit terpasang >= jumlah priority slot,
-- mark SEMUA priority sebagai satisfied. Ini menyelesaikan kasus
-- "stuck di priority" karena verify lag / ret unexpected setelah
-- placement priority sebenarnya sudah berhasil server-side.
-- ==========================================
local function reconcilePriorityFromUI()
    if not CONFIG.PRIORITY_RECONCILE_UI then return end
    if not CONFIG.PRIORITY_LOCK then return end
    if #SLOTS_PRIORITY == 0 then return end
    if lastUITargetCount < #SLOTS_PRIORITY then return end

    local changed = false
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] then
            prioritySatisfied[i] = true
            changed = true
        end
    end
    if changed and CONFIG.LOUD_PRIORITY then
        print(string.format(
            "[AutoPlaceV20] reconcilePriority: UI=%d >= P=%d, semua priority dimark satisfied",
            lastUITargetCount, #SLOTS_PRIORITY))
    end
end

