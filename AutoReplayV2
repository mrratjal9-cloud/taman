local DIFFICULTIES = {
    "dif_easy", "dif_normal", "dif_hard",
    "dif_insane", "dif_impossible", "dif_apocalypse",
}
local function nextDif(cur)
    for i, v in ipairs(DIFFICULTIES) do
        if v == cur then
            return DIFFICULTIES[(i % #DIFFICULTIES) + 1]
        end
    end
    return DIFFICULTIES[1]
end
DifBtn.MouseButton1Click:Connect(function()
    TARGET_DIF = nextDif(TARGET_DIF)
    DifBtn.Text = "Difficulty: " .. TARGET_DIF
end)

-- ==========================================
-- HELPERS
-- ==========================================
local function safeFindChild(parent, name)
    if not parent then return nil end
    return parent:FindFirstChild(name)
end

local function virtualClick(button)
    if not button then return end
    local signals = { "MouseButton1Click", "Activated", "MouseButton1Down" }
    if typeof(getconnections) == "function" then
        for _, sig in ipairs(signals) do
            pcall(function()
                if button[sig] then
                    for _, conn in next, getconnections(button[sig]) do
                        local ok = pcall(function() conn:Fire() end)
                        if not ok and typeof(firesignal) == "function" then
                            pcall(function() firesignal(conn) end)
                        end
                    end
                end
            end)
        end
    elseif typeof(firesignal) == "function" then
        pcall(function() firesignal(button.MouseButton1Click) end)
        pcall(function() firesignal(button.Activated) end)
    end
end

local function getRemote(name)
    local remotes = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if not remotes then return nil end
    return remotes:FindFirstChild(name)
end

local function invokeRemote(name, ...)
    local r = getRemote(name)
    if not r then
        warn("[AutoReplayV2] Remote tidak ditemukan: " .. name)
        return false
    end
    local args = { ... }
    local ok, err = pcall(function()
        r:InvokeServer(unpack(args))
    end)
    if not ok then
        warn("[AutoReplayV2] InvokeServer " .. name .. " gagal: " .. tostring(err))
    end
    return ok
end

-- ==========================================
-- PATH RESOLVERS (sesuai dump path user)
-- ==========================================
-- PlayerGui.GameGui.Screen.Middle.GameEnd.Items.Frame.Actions.Items.Again
local function getAgainButton()
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local gameEnd = safeFindChild(middle, "GameEnd")
    local items1  = safeFindChild(gameEnd, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local actions = safeFindChild(frame, "Actions")
    local items2  = safeFindChild(actions, "Items")
    local again   = safeFindChild(items2, "Again")
    return again, gameEnd
end

-- PlayerGui.GameGui.Screen.Middle.DifficultyVote.Items.Frame.Items.Items.<TARGET_DIF>
local function getDifficultyButton()
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local difVote = safeFindChild(middle, "DifficultyVote")
    local items1  = safeFindChild(difVote, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local items2  = safeFindChild(frame, "Items")
    local items3  = safeFindChild(items2, "Items")
    local btn     = safeFindChild(items3, TARGET_DIF)
    return btn, difVote
end

-- ==========================================
-- MAIN LOOP (STATE MACHINE)
-- ==========================================
task.spawn(function()
    setStatus(isRunning and "Running..." or "Paused")
    while true do
        task.wait(LOOP_INTERVAL)

        local ok, err = pcall(function()
            if not isRunning then return end
            local now = os.clock()

            -- ---- STATE A: DifficultyVote terlihat ----
            local difBtn, difVote = getDifficultyButton()
            if difVote and difVote.Visible == true then
                if (now - lastVoteAt) < COOLDOWN_VOTE then return end

                setStatus("DifficultyVote: vote " .. TARGET_DIF .. "...")
                print("[AutoReplayV2] Vote difficulty:", TARGET_DIF)

                -- 1) Klik tombol pilihan difficulty (animasi UI)
                if difBtn then
                    virtualClick(difBtn)
                    task.wait(0.25)
                else
                    warn("[AutoReplayV2] Tombol " .. TARGET_DIF .. " tidak ditemukan, lanjut remote saja.")
                end

                -- 2) Remote: PlaceDifficultyVote(TARGET_DIF)
                invokeRemote("PlaceDifficultyVote", TARGET_DIF)
                task.wait(0.4)

                -- 3) Remote: RestartGame()
                invokeRemote("RestartGame")

                lastVoteAt = os.clock()
                setStatus("RestartGame fired. Menunggu game restart...")
                task.wait(1)
                return
            end

            -- ---- STATE B: GameEnd terlihat (Play Again) ----
            local againBtn, gameEnd = getAgainButton()
            if gameEnd and gameEnd.Visible == true and againBtn then
                if (now - lastAgainAt) < COOLDOWN_AGAIN then return end

                setStatus("GameEnd: klik Play Again...")
                print("[AutoReplayV2] Klik Play Again")
                virtualClick(againBtn)
                lastAgainAt = os.clock()
                task.wait(0.8)
                return
            end

            -- ---- IDLE ----
            setStatus("Running... menunggu GameEnd / DifficultyVote")
        end)

        if not ok then
            warn("[AutoReplayV2] Iterasi error: " .. tostring(err))
        end
    end
end)

print("[AutoReplayV2] Loaded. Difficulty=" .. TARGET_DIF .. " | Status=" .. (isRunning and "ON" or "OFF"))
