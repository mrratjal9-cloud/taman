-- ==========================================
-- ROTATION & ARGS
-- ==========================================
local function pickRotationDeg()
    local m = CONFIG.ROTATION_MODE
    if m == "off"    then return 0 end
    if m == "fixed"  then return CONFIG.FIXED_ROT_DEG or 0 end
    if m == "smooth" then return randFloat(0, 360) end
    local steps = { 0, 90, 180, 270 }
    return steps[randInt(1, 4)]
end
local function buildArgs(slotXYZ)
    local off = CONFIG.POSITION_OFFSET or 0
    local dx, dz = 0, 0
    if off > 0 then dx = randFloat(-off, off); dz = randFloat(-off, off) end
    local x = slotXYZ[1] + dx
    local y = slotXYZ[2]
    local z = slotXYZ[3] + dz
    local rotDeg = pickRotationDeg()
    local cf  = CFrame.new(x, y, z) * CFrame.Angles(0, math.rad(rotDeg), 0)
    local pos = Vector3.new(x, y, z)
    local args = {
        CONFIG.TARGET_UNIT,
        { CF = cf, Rotation = rotDeg, Valid = true, Position = pos }
    }
    return args, rotDeg
end


-- ==========================================
-- PLACEMENT REMOTE
-- ==========================================
local placeUnitRemote
local function getPlaceUnitRemote()
    if placeUnitRemote and placeUnitRemote.Parent then return placeUnitRemote end
    local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if rf then placeUnitRemote = rf:FindFirstChild("PlaceUnit") end
    return placeUnitRemote
end
local function isSuccessReturn(ok, ret)
    if not ok then return false end
    if ret == false then return false end
    if type(ret) == "string" then
        local low = strLower(ret)
        if strContains(low, "fail") then return false end
        if strContains(low, "insufficient") then return false end
        if strContains(low, "not enough") then return false end
        if strContains(low, "cannot") then return false end
        if strContains(low, "error") then return false end
    end
    if type(ret) == "table" and ret.success == false then return false end
    return true
end

-- ==========================================
-- PRIORITY PLACEMENT (no cash gate, instant burst saat unlock T-1s)
-- ==========================================
local function placePrioritySlot(idx)
    if CONFIG.REQUIRE_PLACEMENT_GATE and not placementUnlocked then
        if CONFIG.DEBUG_GATE then
            print("[AutoPlaceV21] [GATE BLOCKED priority] placement locked")
        end
        lastResult = "GATE BLOCKED: placement locked"
        return false
    end
    local remote = getPlaceUnitRemote()
    if not remote then return false, "remote belum ready" end
    if checkCapBeforePlacement() then
        lastResult = "cap reached, abort priority"
        return false
    end

    local burst = inBurstMode()
    local _, beforeTarget = readPlacedUnits()
    priorityAttempts[idx] = priorityAttempts[idx] + 1
    local args, rotDeg = buildArgs(SLOTS_PRIORITY[idx])
    local ok, ret = pcall(function() return remote:InvokeServer(_unpack(args)) end)
    local serverOk = isSuccessReturn(ok, ret)


    local doVerify = CONFIG.PRIORITY_VERIFY_UI and not (burst and CONFIG.FAST_PLACE_SKIP_VERIFY)
    local success
    if doVerify then
        task.wait(CONFIG.PRIORITY_VERIFY_WAIT or 0.1)
        local _, afterTarget = readPlacedUnits()
        success = serverOk and (afterTarget > beforeTarget)
        lastUITargetCount = afterTarget
    else
        success = serverOk
    end

    local detail = string.format("[P%d try=%d] rot=%s ret=%s ui=%d burst=%s",
        idx, priorityAttempts[idx], tostring(rotDeg), tostring(ret),
        lastUITargetCount, tostring(burst))

    if success then
        prioritySatisfied[idx]  = true
        priorityGivenUp[idx]    = false
        stats.placed_p          = stats.placed_p + 1
        stats.ok_p              = stats.ok_p + 1
        placementsSinceUnlock   = placementsSinceUnlock + 1
        lastResult              = "OK " .. detail
        if CONFIG.LOUD_PRIORITY then print("[AutoPlaceV21] [PRIORITY OK] " .. detail) end
        return true
    else
        if priorityAttempts[idx] >= CONFIG.PRIORITY_MAX_TRIES then
            stats.placed_p           = stats.placed_p + 1
            stats.fail_p             = stats.fail_p + 1
            priorityGivenUp[idx]     = true
            priorityGiveupSince[idx] = os.clock()
            lastResult               = "FAIL (giveup -> main lanjut) " .. detail
            warn(string.format("[AutoPlaceV21] [PRIORITY GIVEUP] P%d after %d tries",
                idx, priorityAttempts[idx]))
        else
            stats.fail_p = stats.fail_p + 1
            lastResult   = "fail " .. detail
            if CONFIG.LOUD_PRIORITY and (priorityAttempts[idx] % 5 == 1) then
                print("[AutoPlaceV21] [priority retry] " .. detail)
            end
        end
        return false
    end
end


-- ==========================================
-- MAIN/BACKUP PLACEMENT
-- ==========================================
local function selectMainOrBackup()
    if isBackupActive() and math.random() < CONFIG.BACKUP_CHANCE then
        if #backupBag == 0 then refillBackupBag() end
        local idx = table.remove(backupBag, 1)
        return "B", idx, SLOTS_BACKUP[idx]
    end
    local pendingList = {}
    for i = 1, #SLOTS_MAIN do
        if not mainSatisfied[i] then pendingList[#pendingList + 1] = i end
    end
    if #pendingList > 0 then
        local idx = pendingList[randInt(1, #pendingList)]
        return "M", idx, SLOTS_MAIN[idx]
    end
    if #mainBag == 0 then refillMainBag() end
    local idx = table.remove(mainBag, 1)
    return "M", idx, SLOTS_MAIN[idx]
end

local function placeMainOrBackupOnce()
    if CONFIG.REQUIRE_PLACEMENT_GATE and not placementUnlocked then
        lastResult = "GATE BLOCKED: placement locked"
        return false
    end
    if CONFIG.MAIN_REQUIRES_PRIORITY_OK and hasPendingPriority() then return false end
    if lastWaveNum < CONFIG.MAIN_START_WAVE then return false end
    if CONFIG.REQUIRE_CASH_GATE then
        local okCash, need = canAfford(CONFIG.TARGET_UNIT)
        if not okCash then
            lastResult = string.format("WAIT cash %d < %d (M)", lastCash, need)
            return false
        end
    end
    local remote = getPlaceUnitRemote()
    if not remote then return false, "remote belum ready" end
    if checkCapBeforePlacement() then
        lastResult = "cap reached, abort main"
        return false
    end

    local phaseTag, slotIdx, slotXYZ = selectMainOrBackup()
    local args, rotDeg = buildArgs(slotXYZ)
    local ok, ret = pcall(function() return remote:InvokeServer(_unpack(args)) end)
    local success = isSuccessReturn(ok, ret)
    local detail  = string.format("[%s%d] rot=%s ret=%s",
        phaseTag, slotIdx, tostring(rotDeg), tostring(ret))


    if success then
        if phaseTag == "M" then
            mainSatisfied[slotIdx] = true
            stats.placed_m = stats.placed_m + 1
            stats.ok_m     = stats.ok_m + 1
        else
            stats.placed_b = stats.placed_b + 1
            stats.ok_b     = stats.ok_b + 1
        end
        placementsSinceUnlock = placementsSinceUnlock + 1
    else
        if phaseTag == "M" then
            stats.placed_m = stats.placed_m + 1
            stats.fail_m   = stats.fail_m + 1
        else
            stats.placed_b = stats.placed_b + 1
            stats.fail_b   = stats.fail_b + 1
        end
    end
    lastResult = (success and "OK " or "FAIL ") .. detail
    return success
end


-- ==========================================
-- OBSERVERS  (V21: timer-only unlock + simple wave reset)
-- ==========================================
local function processTimerSnapshot(sec, raw, src)
    if raw then lastTimerRaw = raw end
    if src then lastTimerSrc = src end

    if CONFIG.DEBUG_TIMER and (os.clock() - timerDebugAt) > 1.0 then
        timerDebugAt = os.clock()
        print(string.format("[AutoPlaceV21][TIMER] sec=%s raw=%s src=%s",
            tostring(sec), tostring(raw), tostring(src)))
    end
    if not sec then return end

    -- Reset detect: timer melonjak naik (game baru / round reset)
    if CONFIG.AUTO_RESET and CONFIG.DETECT_TIMER_RESET
       and lastTimerSec >= 0
       and sec >= lastTimerSec + (CONFIG.TIMER_RESET_JUMP or 60) then
        print(string.format("[AutoPlaceV21] timer reset %d -> %d, restart!",
            lastTimerSec, sec))
        pendingReset = true
        lastTimerSec = sec
        return
    end
    lastTimerSec = sec

    -- (V21 INTI) UNLOCK + INSTANT TRIGGER PRIORITY di T-1s.
    --   Begitu sec <= TIMER_UNLOCK_AT_SEC (default 1) dan sec > 0,
    --   placement langsung dibuka. Slot priority akan di-fire instant
    --   karena placementsSinceUnlock=0 -> burst mode aktif (FAST_PLACE_FIRST_N).
    if not placementUnlocked and sec >= 1 and sec <= (CONFIG.TIMER_UNLOCK_AT_SEC or 1) then
        placementUnlocked     = true
        placementsSinceUnlock = 0
        unlockSource          = string.format("TIMER@%ds", sec)
        print(string.format(
            "[AutoPlaceV21] PLACEMENT UNLOCKED via TIMER@%ds (instant priority burst armed)",
            sec))
        return
    end

    -- Mid-game fallback: kalau saat boot timer udah melewati TIMER_UNLOCK_AT_SEC
    -- (mis. join di tengah game), tetap unlock pertama kali timer ke-baca > 0.
    if not placementUnlocked and bootCompleted and sec > 0 then
        placementUnlocked     = true
        placementsSinceUnlock = 0
        unlockSource          = string.format("TIMER_FALLBACK@%ds", sec)
        print(string.format(
            "[AutoPlaceV21] PLACEMENT UNLOCKED via TIMER_FALLBACK@%ds (mid-game join)",
            sec))
    end
end


local function processWaveSnapshot(num, rawText)
    if rawText then lastWaveTextRaw = rawText end
    if not num then return end
    -- (V21) wave hanya valid SETELAH placementUnlocked, anti baca wave saat lobby
    if not placementUnlocked then return end

    if num ~= lastWaveNum then
        local prev = lastWaveNum
        lastWaveNum = num
        if num > maxWaveSeen then maxWaveSeen = num end

        -- Reset detect: wave decrease
        if CONFIG.AUTO_RESET and CONFIG.DETECT_WAVE_DECREASE
           and prev > 0 and num < prev and prev >= 2 then
            print(string.format("[AutoPlaceV21] wave decrease %d -> %d, restart!", prev, num))
            pendingReset = true
            maxWaveSeen = num
            return
        end

        if num == CONFIG.START_WAVE and not isRunning then
            print("[AutoPlaceV21] Reach START_WAVE -> ON")
            setScriptState(true)
        elseif num == CONFIG.STOP_WAVE and isRunning then
            print("[AutoPlaceV21] Reach STOP_WAVE -> OFF")
            setScriptState(false)
        end
    end
end


