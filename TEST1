            warn(string.format(
                "[AutoPlaceV21] Timer belum nyentuh %ds setelah %.1fs (mid-game fallback armed).",
                CONFIG.TIMER_UNLOCK_AT_SEC or 1, CONFIG.WAVE_BOOT_TIMEOUT))
        else
            print("[AutoPlaceV21] Placement ready (" .. unlockSource .. ")")
        end
        bootCompleted = true
    end


    while isAlive() do                                                    -- V22: cek instance setiap iterasi
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...", Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end
        pcall(refreshUICounts)
        pcall(reconcilePriorityFromUI)
        pcall(recoverGiveupPrioritySlots)

        if os.clock() < pausedUntil then
            task.wait(0.05)

        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)

        elseif capReached then
