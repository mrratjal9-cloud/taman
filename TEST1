local isMatchRunning      = false      -- true = sedang dlm match aktif
local highestSecThisMatch = 0          -- timer tertinggi yg pernah ke-baca di match ini (anti glitch 59:59 LowGrafik)
local matchEndSince       = 0          -- timestamp lobby/gameEnd MULAI muncul (utk debounce)
local lastMatchEndAt      = 0          -- timestamp counter terakhir di-increment (anti spam)

local function readGameEndVisible()
    local visible = false
    pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local gameGui = pGui    and pGui:FindFirstChild("GameGui")
        local screen  = gameGui and gameGui:FindFirstChild("Screen")
        local middle  = screen  and screen:FindFirstChild("Middle")
        local endUI   = middle  and middle:FindFirstChild("GameEnd")
        if endUI then
            -- Visible juga bisa false tapi Enabled true; cek kedua-duanya.
            local v1, v2 = false, false
            pcall(function() v1 = (endUI.Visible == true) end)
            pcall(function() v2 = (endUI.Enabled == true) end)
            visible = v1 or v2
        end
    end)
    return visible
end

local function updateMatchState(secOrNil)
    local timerKnown = (type(secOrNil) == "number" and secOrNil >= 0)
    local sec        = timerKnown and secOrNil or -1
    local isGameOver = readGameEndVisible()
    local isLobby    = (not timerKnown) or (sec < 2)

    if CONFIG.DEBUG_MATCH then
        print(string.format("[AutoPlaceV6][MATCH] sec=%s gameOver=%s lobby=%s running=%s highest=%d",
            tostring(secOrNil), tostring(isGameOver), tostring(isLobby),
            tostring(isMatchRunning), highestSecThisMatch))
    end

    if isGameOver or isLobby then
        if isMatchRunning then
            -- DEBOUNCE: lobby/GameEnd HARUS sustained sebelum dianggap match end.
            -- Antara wave timer kadang sentuh 0 sebentar, jangan langsung di-count.
            if matchEndSince == 0 then
                matchEndSince = os.clock()
            elseif (os.clock() - matchEndSince) >= (CONFIG.MATCH_END_DEBOUNCE_SEC or 2.0) then
                isMatchRunning = false
                local minSec = CONFIG.MATCH_MIN_SEC_TO_COUNT or 10
                if highestSecThisMatch >= minSec then
                    -- Anti spam: minimal 5 detik antar increment counter
                    if (os.clock() - lastMatchEndAt) >= 5 then
                        gameCount      = gameCount + 1
                        lastResetAt    = os.clock()
                        lastMatchEndAt = os.clock()
                        pendingReset   = true   -- minta orchestrator clear state
                        print(string.format(
                            "[AutoPlaceV6] MATCH END detected -> Game #%d (highestSec=%d, gameOver=%s)",
                            gameCount, highestSecThisMatch, tostring(isGameOver)))
                    elseif CONFIG.DEBUG_MATCH then
                        print("[AutoPlaceV6][MATCH] suppressed double-count (within 5s window)")
                    end
                else
                    if CONFIG.DEBUG_MATCH then
                        print(string.format("[AutoPlaceV6][MATCH] match too short (%d < %d), no count",
                            highestSecThisMatch, minSec))
                    end
                end
                highestSecThisMatch = 0
                matchEndSince       = 0
            end
        else
            matchEndSince = 0
        end
    else
        -- Timer & UI sehat (tidak lobby tidak gameEnd) -> reset debounce
        matchEndSince = 0
        if not isMatchRunning then
            -- Re-arm: timer ke-baca rendah (game baru/persiapan wave 1)
            local rearmMax = CONFIG.MATCH_REARM_MAX_SEC or 30
            if timerKnown and sec > 0 and sec <= rearmMax then
                isMatchRunning      = true
                highestSecThisMatch = sec
                if CONFIG.DEBUG_MATCH then
                    print(string.format("[AutoPlaceV6][MATCH] re-arm at sec=%d", sec))
                end
            end
        end
        if isMatchRunning and timerKnown and sec > highestSecThisMatch then
            highestSecThisMatch = sec
        end
    end
end


