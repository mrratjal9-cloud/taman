local function isBackupActive()
    if not CONFIG.USE_BACKUP then return false end
    if #SLOTS_BACKUP == 0 then return false end
    if lastWaveNum < CONFIG.BACKUP_AFTER_WAVE then return false end
    return true
end
local function setBanner(text, bgColor)
    PhaseBanner.Text = text
    if bgColor then PhaseBanner.BackgroundColor3 = bgColor end
end
local function fmtTime(t)
    if t <= 0 then return "-" end
    return string.format("%.1fs ago", os.clock() - t)
end
local function fmtTimer(sec)
    if not sec or sec < 0 then return "-" end
    if sec < 60 then return tostring(sec) end
    local m = math.floor(sec / 60)
    local s = sec % 60
    return string.format("%d:%02d", m, s)
end

local function refreshStats()
    local lines = {}
    for i = 1, #SLOTS_PRIORITY do
        local mark
        if prioritySatisfied[i] then mark = "OK"
        elseif priorityGivenUp[i] then mark = "GIVEUP" .. (priorityGiveupCycles[i] and ("("..priorityGiveupCycles[i]..")") or "")
        elseif priorityAttempts[i] >= CONFIG.PRIORITY_MAX_TRIES then mark = "GIVEUP"
        else mark = "trying(" .. priorityAttempts[i] .. ")" end
        lines[#lines + 1] = "P" .. i .. ":" .. mark
    end
    PrioListLbl.Text = "Priority(random):  " .. table.concat(lines, "  ")

    local cnt, lbl
    if CONFIG.CAP_COUNT_ONLY_TARGET then
        cnt = lastUITargetCount; lbl = CONFIG.TARGET_UNIT
    else
        cnt = lastUIAllUnits; lbl = "all units"
    end
    local capStr = string.format("%d/%d  %s", cnt, CONFIG.PlacementUnitMaxCap, lbl)
    if capReached then capStr = capStr .. "  [CAP]" end
    PlacedLbl.Text = "Placed: " .. capStr

    StatsLbl.Text = string.format("OK P:%d M:%d B:%d  |  Fail P:%d M:%d B:%d",
        stats.ok_p, stats.ok_m, stats.ok_b,
        stats.fail_p, stats.fail_m, stats.fail_b)

    local backupTxt = isBackupActive() and "ACTIVE" or "idle"
    WaveLbl.Text = string.format("Wave: %s  |  Gate>=%d  Backup:%s",
        (lastWaveNum >= 0 and tostring(lastWaveNum) or "-"),
        CONFIG.MAIN_START_WAVE or 1, backupTxt)


    if placementUnlocked then
        local burstTag = inBurstMode()
            and string.format(" [BURST %d/%d]", placementsSinceUnlock, CONFIG.FAST_PLACE_FIRST_N)
            or ""
        UnlockLbl.Text       = "Placement: UNLOCKED via " .. unlockSource .. burstTag
        UnlockLbl.TextColor3 = Color3.fromRGB(150, 230, 150)
    else
        UnlockLbl.Text       = "Placement: LOCKED (waiting TIMER@" .. (CONFIG.TIMER_UNLOCK_AT_SEC or 1) .. "s)"
        UnlockLbl.TextColor3 = Color3.fromRGB(255, 100, 100)
    end

    if cachedTimerLabel and lastTimerSec >= 0 then
        TimerLbl.Text       = "Timer: " .. fmtTimer(lastTimerSec)
        TimerLbl.TextColor3 = Color3.fromRGB(255, 230, 130)
    elseif lastTimerSec >= 0 then
        TimerLbl.Text       = "Timer: " .. fmtTimer(lastTimerSec)
        TimerLbl.TextColor3 = Color3.fromRGB(255, 230, 130)
    else
        TimerLbl.Text       = "Timer: Scanning..."
        TimerLbl.TextColor3 = Color3.fromRGB(180, 180, 180)
    end

    local price = getUnitPrice(CONFIG.TARGET_UNIT)
    if CONFIG.REQUIRE_CASH_GATE and price > 0 then
        CashLbl.Text = string.format("Cash: %s  /  need %d  (priority bypass cash)",
            (lastCash >= 0 and tostring(lastCash) or "-"), price)
        if lastCash >= 0 and lastCash < price then
            CashLbl.TextColor3 = Color3.fromRGB(255, 180, 100)
        else
            CashLbl.TextColor3 = Color3.fromRGB(140, 230, 140)
        end
    else
        CashLbl.Text = string.format("Cash: %s  (gate off)",
            (lastCash >= 0 and tostring(lastCash) or "-"))
        CashLbl.TextColor3 = Color3.fromRGB(180, 220, 180)
    end

    WaveRawLbl.Text = "WaveTxt: " .. tostring(lastWaveTextRaw)
