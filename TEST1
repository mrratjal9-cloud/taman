-- ==========================================
-- AUTO PLACE UNIT V6  (Parallel + Match-State Counter + Compact GUI)
-- ==========================================
-- Revisi V6 (lanjutan V5):
--
--   [V6 FIX #1] COUNTER GAMEPLAY (Game #N) -> di-port dari LowGrafik_V9
--      Masalah V5: setelah satu kali reset, counter sering naik 2x karena
--      DUA detector (DETECT_TIMER_RESET + DETECT_WAVE_DECREASE) bisa fire
--      berurutan dan masing2 nge-trigger performReset() -> gameCount += 2.
--      Solusi V6: pakai STATE MACHINE seperti LowGrafik_V9 (sebelah IN GAME):
--        - state isMatchRunning (true saat dlm match)
--        - highestSecThisMatch (best timer di match ini, anti glitch)
--        - lobbyStartedAt (debounce: lobby/gameEnd hrs bertahan X detik
--          sebelum dianggap match end -> menghindari false-positive saat
--          jeda antar wave timer drop ke 0 sebentar)
--      Counter SELALU naik PERSIS 1x per match end. Detector lama dimatikan.
--
--   [V6 FIX #2] PARALEL EXECUTE (multi-instance per UNIT)
--      Masalah V5: SCRIPT_ID singleton GLOBAL -> execute kedua langsung
--      mematikan instance pertama. Tidak bisa run 2 unit beda secara paralel.
--      Solusi V6: SINGLETON SCOPED KE TARGET_UNIT.
--        _G.__AutoPlace_BY_UNIT[TARGET_UNIT] = SCRIPT_ID
--      Instance dgn unit BERBEDA jalan paralel. Re-execute dgn unit SAMA =
--      menggantikan instance lama (perilaku V5 utk unit yg sama).
--      Registry global _G.__AutoPlace_INSTANCES dipakai utk tau urutan
--      tag GUI (1, 2, 3, ...).
--
--   [V6 FIX #3] DEFAULT GUI = COMPACT/MINIMIZED + NUMBERED + STACKED
--      Saat pertama kali execute, GUI muncul dlm bentuk MINIMIZED kecil
--      (cuma label "1", "2", "3", ...). Posisi default = KIRI TENGAH agak
--      BAWAH layar, ditumpuk vertikal antar instance. Klik tag = expand
--      ke GUI penuh utk lihat detail / atur status. Cocok utk execute
--      banyak instance (mis. 5+) tanpa GUI menutupi seluruh layar.
--
-- (semua fitur V5 tetap: timer-only unlock @ T-1s, persistent timer-cache,
--  random priority bag, giveup-retry, reconcile-from-UI, anti-macro,
--  cash gate, backup, kill-switch dll.)
-- ==========================================
-- AUTO PLACE UNIT V5  (lanjutan: Lean Timer-only Unlock + Instant Priority @ T-1s)
-- ==========================================
-- Revisi V1 (lanjutan dari V20, fokus: optimisasi & ringkas):
--
--   [V1 FIX #1] UNLOCK 100% BERBASIS TIMER ⏱
--      Sumber unlock placement sekarang TUNGGAL: ketika widget timer ⏱
--      ke-baca <= TIMER_UNLOCK_AT_SEC (default 1 detik) -> placementUnlocked=true,
--      slot priority langsung di-fire instant (BURST mode aktif).
--      Tidak ada lagi cek 'Enemies incoming!' / DifficultyVote / countdown.
--
--      Mid-game join: kalau saat boot timer sudah > TIMER_UNLOCK_AT_SEC
--      (artinya wave aktif), fallback unlock pertama kali timer ke-baca
--      setelah bootCompleted.
--
--   [V21 FIX #2] HAPUS METHOD LAMA -> SCRIPT LEBIH RINGAN
--      Yang dihapus dari V20:
--        * readDifficultyVoteOnce, processDifficultyVote (DELETED)
--        * vote loop (task.spawn) - hilang
--        * COUNTDOWN branch di readWaveOnce - hilang
--        * INCOMING branch di readWaveOnce - hilang (DETECT_INCOMING_AFTER_STOP juga off)
--        * State: lastChooseLevel/Raw, chooseLevelSeen, voteSeenAtGame,
--                 enemiesIncomingSeen, lastCountdownSeen, timerSeenHigh
--        * Config: UNLOCK_ON_CHOOSE_LEVEL*, UNLOCK_REQUIRES_CHOOSE_LEVEL_DONE,
--                 UNLOCK_ON_TIMER*, UNLOCK_ON_COUNTDOWN, UNLOCK_ON_INCOMING,
--                 COUNTDOWN_MIN/MAX, DETECT_VOTE_REAPPEAR,
--                 DETECT_INCOMING_AFTER_STOP, VOTE_POLL, DEBUG_VOTE
--        * GUI: VoteLbl, IncomingLbl - dihapus
--
--   [V21 FIX #3] WAVE READER DI-RAMPING
--      Hanya baca pola "Wave N". Tidak parse countdown / incoming / other.
--      Wave juga hanya di-track SETELAH placementUnlocked (anti
--      false-positive saat masih lobby).
--
--   [tetap dari V20] dual-format parseMMSS (terima "⏱ 56" & "⏱ 1:00"),
--      single-scan widget cache lock, persistent cache lintas game-reset.
--
--   [tetap dari V19/V18/V17] random priority bag, giveup-retry,
--      reconcile-from-UI, burst, anti-macro, cash gate, backup.
-- ==========================================

print("[AutoPlaceV6] Boot: starting...")

local _unpack = table.unpack or unpack
math.randomseed(tick() * 1000 % 2147483647)
for i = 1, 8 do math.random() end


-- ==========================================
-- [V6 FIX] SINGLETON PER-UNIT + INSTANCE REGISTRY (PARALEL)
-- ==========================================
-- V5 lama: 1 token global -> execute ke-2 selalu kill instance ke-1.
-- V6 baru: token DI-INDEX-KAN per TARGET_UNIT. Execute paralel dgn unit
-- BEDA = tidak saling kill. Execute ulang dgn unit SAMA = tetap kill yg lama
-- (mempertahankan perilaku safe utk unit yang sama).
--
-- _G.__AutoPlace_BY_UNIT[unit_name]  = SCRIPT_ID  (singleton per unit)
-- _G.__AutoPlace_INSTANCES[script_id] = { number=N, unit=..., isAliveFn=fn }
--   number = nomor tag GUI (1, 2, 3, ...) yang dipakai utk display compact.

local SCRIPT_ID = "APV6_" .. tostring(tick()) .. "_" .. tostring(math.random(1, 1e9))   -- token unik instance ini

-- TARGET_UNIT tertulis di CONFIG di bawah. Kita perlu nama unit DULU sebelum bikin SCRIPT_ID
-- key. Workaround: baca dari konfigurasi sederhana berikut, lalu CONFIG.TARGET_UNIT
-- DI BAWAH harus PERSIS sama dengan nilai ini. (Dijaga sinkron oleh user saat edit unit.)
local _BOOT_TARGET_UNIT = "unit_money_tree"   -- [BOOT] guna: nama unit utk scoping singleton paralel. | nilai: case-sensitive sama dgn CONFIG.TARGET_UNIT di bawah. | efek: dipakai utk key _G singleton per-unit.

_G.__AutoPlace_BY_UNIT   = _G.__AutoPlace_BY_UNIT   or {}
_G.__AutoPlace_INSTANCES = _G.__AutoPlace_INSTANCES or {}

-- (a) Bunuh instance LAMA dgn UNIT YG SAMA (instance unit lain dibiarkan)
local _oldOfThisUnit = _G.__AutoPlace_BY_UNIT[_BOOT_TARGET_UNIT]
if _oldOfThisUnit ~= nil and _oldOfThisUnit ~= SCRIPT_ID then
    print("[AutoPlaceV6] Found old instance for unit=" .. tostring(_BOOT_TARGET_UNIT)
        .. " (id=" .. tostring(_oldOfThisUnit) .. ") -> invalidating.")
    if _G.__AutoPlace_INSTANCES[_oldOfThisUnit] then
        _G.__AutoPlace_INSTANCES[_oldOfThisUnit] = nil
    end
end
_G.__AutoPlace_BY_UNIT[_BOOT_TARGET_UNIT] = SCRIPT_ID                   -- kunci unit di kita

-- (b) Helper cek instance: pakai SCRIPT_ID dlm map per-unit
local function isAlive()
    return _G.__AutoPlace_BY_UNIT[_BOOT_TARGET_UNIT] == SCRIPT_ID
end

-- (c) Bersihkan registry instance yg sudah mati (alive=false)
do
    local cleaned = {}
    for k, v in pairs(_G.__AutoPlace_INSTANCES) do
        if v and v.isAliveFn and v.isAliveFn() then cleaned[k] = v end
    end
    _G.__AutoPlace_INSTANCES = cleaned
end

-- (d) Tentukan nomor tag GUI (compact display): cari integer terkecil yg blm dipakai
local _takenNumbers = {}
for _, v in pairs(_G.__AutoPlace_INSTANCES) do
    if v and v.number then _takenNumbers[v.number] = true end
end
local myInstanceNumber = 1
while _takenNumbers[myInstanceNumber] do myInstanceNumber = myInstanceNumber + 1 end

-- (e) Daftar diri di registry global
_G.__AutoPlace_INSTANCES[SCRIPT_ID] = {
    number    = myInstanceNumber,
    unit      = _BOOT_TARGET_UNIT,
    isAliveFn = isAlive,
}
print(string.format("[AutoPlaceV6] Instance #%d unit=%s id=%s",
    myInstanceNumber, tostring(_BOOT_TARGET_UNIT), tostring(SCRIPT_ID)))

-- (f) Hapus GUI lama HANYA milik instance unit ini (jangan ganggu instance lain)
do
    local _CoreGui = game:GetService("CoreGui")
    -- Nama GUI baru pakai unit + number jadi unik per instance
    local myGuiName = "AutoPlaceGUI_" .. tostring(_BOOT_TARGET_UNIT) .. "_" .. tostring(myInstanceNumber)
    local oldMine = _CoreGui:FindFirstChild(myGuiName)
    if oldMine then pcall(function() oldMine:Destroy() end) end
    -- Cleanup nama GUI generik V5 (1x saja, agar tidak ada GUI orphan dari versi lama)
    for _, name in ipairs({ "AutoPlaceGUI", "AutoPlaceV21_GUI", "AutoPlaceV22_GUI" }) do
        local oldGui = _CoreGui:FindFirstChild(name)
        if oldGui then pcall(function() oldGui:Destroy() end) end
    end
end

-- (g) Pelacak koneksi -> dipakai utk disconnect saat CloseBtn dipencet
local _trackedConns = {}
local function trackConn(c)
    if c then table.insert(_trackedConns, c) end
    return c
end
local function disconnectAllConns()
    for _, c in ipairs(_trackedConns) do pcall(function() c:Disconnect() end) end -- putus semua koneksi
    _trackedConns = {}
end


