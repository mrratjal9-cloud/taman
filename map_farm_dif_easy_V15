-- ==========================================
local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
    if not m or not s then return nil end
    local mm = tonumber(m) or 0
    local ss = tonumber(s) or 0
    if ss > 99 then return nil end
    return mm * 60 + ss
end

local function tryDirectTimerPath(pGui)
    local tbs  = pGui  and pGui:FindFirstChild("TopbarStandard")
    local hold = tbs   and tbs:FindFirstChild("Holders")
    local rgt  = hold  and hold:FindFirstChild("Right")
    local wid  = rgt   and rgt:FindFirstChild("Widget")
    local ib   = wid   and wid:FindFirstChild("IconButton")
    local menu = ib    and ib:FindFirstChild("Menu")
    local spot = menu  and menu:FindFirstChild("IconSpot")
    local cnt  = spot  and spot:FindFirstChild("Contents")
    local cont = cnt   and cnt:FindFirstChild("IconLabelContainer")
    local lbl  = cont  and cont:FindFirstChild("IconLabel")
    if lbl and lbl.Text and lbl.Text ~= "" then
        local sec = parseMMSS(lbl.Text)
        if sec then return sec, lbl.Text, "DIRECT" end
        return nil, lbl.Text, "DIRECT(no-mm:ss)"
    end
    return nil, nil, "DIRECT(missing)"
end

-- Rekursif cari TextLabel dengan pola M:SS. Prioritas: nama "IconLabel"
-- atau parent path mengandung "Topbar"/"Widget".
local function findTimerLabel(root, depth)
    depth = depth or 0
    if depth > 8 then return nil end
    local best, bestScore = nil, -1
    local ok, children = pcall(function() return root:GetChildren() end)
    if not ok or not children then return nil end
    for _, c in ipairs(children) do
        local pass, isText = pcall(function() return c:IsA("TextLabel") end)
        if pass and isText and c.Text and c.Text ~= "" then
            local sec = parseMMSS(c.Text)
            if sec then
                local score = 0
                if c.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = c:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if string.find(c.Text, "⏱", 1, true) then score = score + 4 end
                if score > bestScore then
                    best, bestScore = c, score
                end
            end
        end
        local childBest = findTimerLabel(c, depth + 1)
        if childBest then
            local sec = parseMMSS(childBest.Text)
            if sec then
                local score = 0
                if childBest.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = childBest:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if string.find(childBest.Text, "⏱", 1, true) then score = score + 4 end
                if score > bestScore then
                    best, bestScore = childBest, score
                end
            end
        end
    end
    return best
end

local function readTimerOnce()
    local ok, sec, raw, src = pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not pGui then return nil, nil, "NO_GUI" end
        -- 1) Direct path
        local s1, r1, src1 = tryDirectTimerPath(pGui)
        if s1 then return s1, r1, src1 end
        -- 2) Recursive search di PlayerGui
        local lbl = findTimerLabel(pGui, 0)
        if lbl and lbl.Text then
            local sec2 = parseMMSS(lbl.Text)
            if sec2 then
                local fn = ""
                pcall(function() fn = lbl:GetFullName() end)
                return sec2, lbl.Text, "REC:" .. fn
            end
        end
        -- 3) Fallback: cari di CoreGui (kalau topbar di CoreGui)
        local lbl2 = findTimerLabel(CoreGui, 0)
        if lbl2 and lbl2.Text then
            local sec3 = parseMMSS(lbl2.Text)
            if sec3 then
                local fn = ""
                pcall(function() fn = lbl2:GetFullName() end)
                return sec3, lbl2.Text, "COREGUI:" .. fn
            end
        end
        return nil, r1, src1 or "MISS"
    end)
    if not ok then return nil, nil, "ERROR" end
    return sec, raw, src
end

