local function processTimerSnapshot(sec, raw, src)
    if raw then lastTimerRaw = raw end
    if src then lastTimerSrc = src end

    if CONFIG.DEBUG_TIMER and (os.clock() - timerDebugAt) > 1.0 then
        timerDebugAt = os.clock()
        print(string.format("[AutoPlaceV15][TIMER] sec=%s raw=%s src=%s",
            tostring(sec), tostring(raw), tostring(src)))
    end

    if not sec then return end

    if CONFIG.AUTO_RESET and CONFIG.DETECT_TIMER_RESET
       and lastTimerSec >= 0
       and sec >= lastTimerSec + (CONFIG.TIMER_RESET_JUMP or 60) then
        print(string.format("[AutoPlaceV15] timer reset %d -> %d, restart!",
            lastTimerSec, sec))
        pendingReset = true
    end

    lastTimerSec = sec

    if CONFIG.UNLOCK_ON_TIMER and sec >= (CONFIG.TIMER_UNLOCK_THRESHOLD or 3590) then
        timerSeenHigh = true
        tryUnlockPlacement("TIMER", "(" .. fmtTimer(sec) .. ")")
    end
end

local function processWaveSnapshot(num, rawText, kind)
    if rawText then lastWaveTextRaw = rawText end

    if kind == "COUNTDOWN" then
        lastCountdownSeen = num
        if CONFIG.UNLOCK_ON_COUNTDOWN then
            tryUnlockPlacement("COUNTDOWN", "(" .. tostring(num) .. ")")
        end
        return
    end

    if kind == "INCOMING" then
        if CONFIG.AUTO_RESET
           and CONFIG.DETECT_INCOMING_AFTER_STOP
           and maxWaveSeen >= CONFIG.STOP_WAVE then
            print("[AutoPlaceV15] 'Enemies incoming!' setelah max wave -> RESTART")
            pendingReset = true
            return
        end
        if not enemiesIncomingSeen then
            enemiesIncomingSeen = true
            print("[AutoPlaceV15] 'Enemies incoming!' detected -> game tracked")
        end
        if CONFIG.UNLOCK_ON_INCOMING then
            tryUnlockPlacement("INCOMING", nil)
        end
        return
    end

    if kind == "WAVE" and num then
        if not (enemiesIncomingSeen or timerSeenHigh) then
            return
        end
        if num ~= lastWaveNum then
            local prev = lastWaveNum
            lastWaveNum = num
            if num > maxWaveSeen then maxWaveSeen = num end

            local restartReason = detectRestartFromWave(prev, num)
            if restartReason then
                print("[AutoPlaceV15] === RESTART DETECTED === " .. restartReason)
                pendingReset = true
                maxWaveSeen = num
                return
            end

            if num == CONFIG.START_WAVE and not isRunning then
                print("[AutoPlaceV15] Reach START_WAVE -> ON")
                setScriptState(true)
            elseif num == CONFIG.STOP_WAVE and isRunning then
                print("[AutoPlaceV15] Reach STOP_WAVE -> OFF")
                setScriptState(false)
            end
        end
    end
end

