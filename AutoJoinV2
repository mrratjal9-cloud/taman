-- ==========================================
-- AUTO JOINER V2 (Compatibility Fix)
-- Perbaikan: 
--   1. Hapus keyword "continue" (tidak didukung sebagian executor)
--   2. Tambah firesignal fallback untuk virtualClick
--   3. Bungkus eksekusi utama dengan pcall pengaman global
--   4. Inisialisasi service & GUI lebih aman
-- ==========================================

-- ==========================================
-- CONFIGURATION
-- ==========================================
local AUTO_START      = true
local TARGET_MAP      = "map_farm"   -- Ganti sesuai id map (contoh: map_graveyard)
local TARGET_DIF      = "dif_easy"   -- dif_easy, dif_normal, dif_hard, dif_insane, dif_impossible, dif_apocalypse
local MAX_PLAYERS     = 1
local LOBBY_PLACE_ID  = 108533757090220

-- Daftar pintu (Sesuaikan RemoteIndex dengan nomor pintunya)
local DOORS = {
    {CF = CFrame.new(84.8885498, 66.4031448, 789.898621),  RemoteIndex = "5"},
    {CF = CFrame.new(96.9751129, 66.0011368, 789.898621),  RemoteIndex = "6"},
    {CF = CFrame.new(109.094376, 66.3031387, 789.898621),  RemoteIndex = "7"},
    {CF = CFrame.new(121.804642, 66.9051361, 789.898621),  RemoteIndex = "8"},
}

-- ==========================================
-- SERVICES
-- ==========================================
local CoreGui            = game:GetService("CoreGui")
