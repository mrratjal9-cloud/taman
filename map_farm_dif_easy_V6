        Color3.fromRGB(255, 165, 0))
    print(string.format("[AutoPlaceV6] BOOT_DELAY: tunggu %.1fs...", CONFIG.BOOT_DELAY))
    task.wait(CONFIG.BOOT_DELAY)

    while true do
        -- Handle pending reset
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...",
                Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end

        -- Pause cooldown
        if os.clock() < pausedUntil then
            task.wait(0.1)
        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)
        elseif hasPendingPriority() then
            -- ===== PHASE 1: PRIORITY =====
            currentPhase = "priority (AWAL)"
            local target = nil
            for i = 1, #SLOTS_PRIORITY do
                if not prioritySatisfied[i]
                   and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                    target = i
                    break
                end
            end
            if target then
                setBanner(string.format("PRIORITY %d/%d  (try %d)",
                    target, #SLOTS_PRIORITY, priorityAttempts[target] + 1),
                    Color3.fromRGB(255, 220, 100))
                pcall(placePrioritySlot, target)
                refreshStats()
                task.wait(CONFIG.PRIORITY_DELAY)
            end
        else
            -- ===== PHASE 2+: MAIN / BACKUP =====
            if isBackupActive() then
                currentPhase = "main+backup"
                setBanner("MAIN + BACKUP (compensating fails)",
                    Color3.fromRGB(120, 180, 240))
            elseif countMainPending() == 0 then
                currentPhase = "main (cycle - all done)"
                setBanner("MAIN cycle (semua slot done)",
                    Color3.fromRGB(120, 220, 120))
            else
                currentPhase = "main"
                setBanner("MAIN PHASE - placing...",
                    Color3.fromRGB(120, 220, 120))
            end

            local ok, err = pcall(placeMainOrBackupOnce)
            if not ok then
                warn("[AutoPlaceV6] Main loop error: " .. tostring(err))
                lastResult = "ERROR: " .. tostring(err)
            end
            refreshStats()

            local base = CONFIG.LOOP_DELAY
            local jit  = CONFIG.LOOP_DELAY_JITTER or 0
            local extra = (jit > 0) and randFloat(-jit, jit) or 0
            task.wait(math.max(0.01, base + extra))
        end
    end
end)

