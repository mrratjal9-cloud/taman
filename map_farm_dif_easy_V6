                            if cur ~= lastWaveNum then
                                local prev = lastWaveNum
                                lastWaveNum = cur
                                if cur > maxWaveSeen then maxWaveSeen = cur end

                                -- Restart detection
                                local restartReason = detectRestart(prev, cur)
                                if restartReason then
                                    print("[AutoPlaceV6] === GAME RESTART DETECTED === " .. restartReason)
                                    pendingReset = true
                                    maxWaveSeen = cur -- reset max tracker
                                end

                                -- Wave start/stop control
                                if cur == CONFIG.START_WAVE and not isRunning then
                                    print("[AutoPlaceV6] Reach START_WAVE -> ON")
                                    setScriptState(true)
                                elseif cur == CONFIG.STOP_WAVE and isRunning then
                                    print("[AutoPlaceV6] Reach STOP_WAVE -> OFF")
                                    setScriptState(false)
                                end
                            end
                        end
                    end
                end
            end)
