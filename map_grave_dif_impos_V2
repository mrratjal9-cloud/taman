local function unlockGateOk()
    if CONFIG.REQUIRE_PLACEMENT_GATE and not placementUnlocked then
        return false, "menunggu TIMER@" .. (CONFIG.TIMER_UNLOCK_AT_SEC or 1) .. "s"
    end
    return true, "ok"
end

local function cashGateOk(unitName)
    if not CONFIG.REQUIRE_CASH_GATE then return true, 0 end
    local ok, need = canAfford(unitName or CONFIG.TARGET_UNIT)
    if not ok then return false, need end
    return true, need
end

local function canStartMainPhase()
    local can, reason = unlockGateOk()
    if not can then return false, reason end
    if CONFIG.MAIN_REQUIRES_PRIORITY_OK and hasPendingPriority() then
        return false, "menunggu priority done"
    end
    if CONFIG.MAIN_REQUIRES_PRIORITY_OK and hasGivenUpPriority() then
        return false, "priority GIVEUP, main locked"
    end
    if lastWaveNum < 0 then return false, "menunggu wave terdeteksi" end
    if lastWaveNum < CONFIG.MAIN_START_WAVE then
        return false, string.format("menunggu wave >= %d (sekarang %d)",
            CONFIG.MAIN_START_WAVE, lastWaveNum)
    end
    local okCash, need = cashGateOk(CONFIG.TARGET_UNIT)
    if not okCash then return false, string.format("cash %d < %d", lastCash, need) end
    return true, "ok"
end


-- ==========================================
-- SHUFFLE-BAG  (priority, main, backup)
-- ==========================================
local function buildBag(n)
    local bag = {}
    for i = 1, n do bag[i] = i end
    for i = n, 2, -1 do
        local j = randInt(1, i)
        bag[i], bag[j] = bag[j], bag[i]
    end
    return bag
end
local function refillMainBag()   mainBag   = buildBag(#SLOTS_MAIN)   end
local function refillBackupBag() backupBag = buildBag(#SLOTS_BACKUP) end
local function refillPriorityBag()
    if CONFIG.PRIORITY_RANDOM_ORDER then
        priorityBag = buildBag(#SLOTS_PRIORITY)
    else
        priorityBag = {}
        for i = 1, #SLOTS_PRIORITY do priorityBag[i] = i end
    end
end

local function selectNextPrioritySlot()
    local n = #SLOTS_PRIORITY
    local tries = 0
    while #priorityBag > 0 and tries <= n do
        tries = tries + 1
        local idx = table.remove(priorityBag, 1)
        if idx and not prioritySatisfied[idx] and not priorityGivenUp[idx]
           and priorityAttempts[idx] < CONFIG.PRIORITY_MAX_TRIES then
            return idx
        end
    end
    if hasPendingPriority() then
        refillPriorityBag()
        while #priorityBag > 0 do
            local idx = table.remove(priorityBag, 1)
            if idx and not prioritySatisfied[idx] and not priorityGivenUp[idx]
               and priorityAttempts[idx] < CONFIG.PRIORITY_MAX_TRIES then
                return idx
            end
        end
    end
    return nil
end


local function initSlotState()
    for i = 1, #SLOTS_PRIORITY do
        prioritySatisfied[i]    = false
        priorityAttempts[i]     = 0
        priorityGivenUp[i]      = false
        priorityGiveupCycles[i] = 0
        priorityGiveupSince[i]  = 0
    end
    for i = 1, #SLOTS_MAIN do mainSatisfied[i] = false end
    refillMainBag()
    refillPriorityBag()
    if #SLOTS_BACKUP > 0 then refillBackupBag() end
    capReached        = false
    lastUITargetCount = 0
    lastUIAllUnits    = 0
end
initSlotState()

local function performReset(reason)
    initSlotState()
    placementUnlocked     = false
    unlockSource          = "-"
    lastWaveNum           = -1
    maxWaveSeen           = -1
    placementsSinceUnlock = 0
    -- (V19+) cache widget timer SENGAJA TIDAK di-invalidate (persistent lintas game)
    if CONFIG.TIMER_PERSIST_CACHE_ACROSS_RESET == false then
        invalidateTimerCache()
        timerEverFound = false
    end
    lastTimerSec = -1
    lastTimerRaw = "-"
    gameCount    = gameCount + 1
    lastResetAt  = os.clock()
    pausedUntil  = os.clock() + CONFIG.RESET_COOLDOWN
    currentPhase = "reset (cooldown)"
    pendingReset = false
    lastResult   = string.format("RESET game #%d: %s", gameCount, tostring(reason))
    print(string.format("[AutoPlaceV21] === RESET === game #%d | reason: %s | timer-cache=%s",
        gameCount, tostring(reason),
        (cachedTimerLabel and ("KEEP("..tostring(cachedTimerName)..")") or "none")))
end


