-- ==========================================
-- parseMMSS dual-format:
--   "M:SS" (mis. "⏱ 1:00", "⏱ 5:23")  ATAU  detik saja (mis. "⏱ 0", "⏱ 56", "⏱ 59").
local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then
            local mm = tonumber(m) or 0
            local ss = tonumber(s) or 0
            if ss <= 99 then return mm * 60 + ss end
        end
        return nil
    end
    -- tanpa ":" -> ambil angka pertama 0-99 sebagai detik
    local n = string.match(t, "(%d+)")
    if n then
        local v = tonumber(n)
        if v and v >= 0 and v <= 99 then return v end
    end
    return nil
end

local function hasClockEmoji(t)
    if type(t) ~= "string" then return false end
    return string.find(t, "⏱", 1, true) ~= nil
end

local function isCachedTimerLabelAlive()
    if not cachedTimerLabel then return false end
    local ok, alive = pcall(function()
        if not cachedTimerLabel.Parent then return false end
        if not cachedTimerLabel:IsA("TextLabel") then return false end
        return true
    end)
    return ok and alive == true
end

local function invalidateTimerCache()
    cachedTimerLabel  = nil
    cachedTimerWidget = nil
    cachedTimerName   = "-"
end


-- Path: PlayerGui.TopbarStandard.Holders.Right.<Widget ⏱>.IconButton.Menu.IconSpot.Contents.IconLabelContainer.IconLabel
-- Iterasi children Holders.Right HANYA sekali. Setelah cache LOCKED tidak akan dipanggil lagi.
local function tryDirectTimerPath(pGui)
    local tbs  = pGui  and pGui:FindFirstChild("TopbarStandard")
    local hold = tbs   and tbs:FindFirstChild("Holders")
    local rgt  = hold  and hold:FindFirstChild("Right")
    if not rgt then return nil, nil, "DIRECT(no-holder-right)" end

    local requireClock = (CONFIG.TIMER_REQUIRE_CLOCK_EMOJI ~= false)
    local bestSec, bestText, bestName, bestScore = nil, nil, nil, -1
    local bestLabel, bestWidget = nil, nil
    for _, widget in ipairs(rgt:GetChildren()) do
        local ib   = widget:FindFirstChild("IconButton")
        local menu = ib    and ib:FindFirstChild("Menu")
        local spot = menu  and menu:FindFirstChild("IconSpot")
        local cnt  = spot  and spot:FindFirstChild("Contents")
        local cont = cnt   and cnt:FindFirstChild("IconLabelContainer")
        local lbl  = cont  and cont:FindFirstChild("IconLabel")
        if lbl and lbl.Text and lbl.Text ~= "" then
            local sec = parseMMSS(lbl.Text)
            if sec and (not requireClock or hasClockEmoji(lbl.Text)) then
                local score = 1
                if hasClockEmoji(lbl.Text) then score = score + 10 end
                local lname = string.lower(widget.Name or "")
                if string.find(lname, "time", 1, true)
                   or string.find(lname, "timer", 1, true)
                   or string.find(lname, "wave", 1, true) then
                    score = score + 2
                end
                if score > bestScore then
                    bestSec    = sec
                    bestText   = lbl.Text
                    bestName   = widget.Name
                    bestScore  = score
                    bestLabel  = lbl
                    bestWidget = widget
                end
            end
        end
    end

    if bestSec then
        if CONFIG.TIMER_USE_WIDGET_CACHE ~= false then
            local wasFirstLock = (cachedTimerLabel == nil)
            cachedTimerLabel  = bestLabel
            cachedTimerWidget = bestWidget
            cachedTimerName   = tostring(bestName)
            timerEverFound    = true
            if wasFirstLock then
                print(string.format(
                    "[AutoPlaceV21] timer-cache LOCKED: widget=%s text=%q sec=%d (selanjutnya tidak ada scanning)",
                    tostring(bestName), tostring(bestText), bestSec))
            end
        end
        return bestSec, bestText, "WIDGET:" .. tostring(bestName)
    end
    if requireClock then return nil, nil, "DIRECT(no-clock-widget)" end
    return nil, nil, "DIRECT(no-mm:ss)"
end


-- Fallback rekursif (cuma dipanggil kalau direct path gagal di game pertama)
local function findTimerLabel(root, depth)
    depth = depth or 0
    if depth > 10 then return nil end
    local requireClock = (CONFIG.TIMER_REQUIRE_CLOCK_EMOJI ~= false)
    local best, bestScore = nil, -1
    local ok, children = pcall(function() return root:GetChildren() end)
    if not ok or not children then return nil end
    for _, c in ipairs(children) do
        local pass, isText = pcall(function() return c:IsA("TextLabel") end)
        if pass and isText and c.Text and c.Text ~= "" then
            local sec = parseMMSS(c.Text)
            if sec and (not requireClock or hasClockEmoji(c.Text)) then
                local score = 0
                if c.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = c:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if hasClockEmoji(c.Text) then score = score + 10 end
                if score > bestScore then best, bestScore = c, score end
            end
        end
        local childBest = findTimerLabel(c, depth + 1)
        if childBest then
            local sec = parseMMSS(childBest.Text)
            if sec and (not requireClock or hasClockEmoji(childBest.Text)) then
                local score = 0
                if childBest.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = childBest:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if hasClockEmoji(childBest.Text) then score = score + 10 end
                if score > bestScore then best, bestScore = childBest, score end
            end
        end
    end
    return best
end


local function readTimerOnce()
    timerScanCount = timerScanCount + 1
    local requireClock = (CONFIG.TIMER_REQUIRE_CLOCK_EMOJI ~= false)

    -- FAST-PATH: cache hit -> baca .Text saja, TIDAK ada scanning
    if CONFIG.TIMER_USE_WIDGET_CACHE ~= false and isCachedTimerLabelAlive() then
        local ok, sec, raw = pcall(function()
            local txt = cachedTimerLabel.Text or ""
            return parseMMSS(txt), txt
        end)
        if ok then return sec, raw, "CACHED:" .. tostring(cachedTimerName) end
        invalidateTimerCache()  -- reference rusak
    end

    -- SLOW-PATH: cache miss -> cari widget pertama kali (biasanya 1x per session)
    local ok, sec, raw, src = pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not pGui then return nil, nil, "NO_GUI" end
        local s1, r1, src1 = tryDirectTimerPath(pGui)
        if s1 then return s1, r1, src1 end
        -- fallback rekursif
        local lbl = findTimerLabel(pGui, 0)
        if lbl and lbl.Text then
            local sec2 = parseMMSS(lbl.Text)
            if sec2 and (not requireClock or hasClockEmoji(lbl.Text)) then
                if CONFIG.TIMER_USE_WIDGET_CACHE ~= false then
                    cachedTimerLabel  = lbl
                    cachedTimerWidget = lbl
                    cachedTimerName   = "REC"
                    timerEverFound    = true
                end
                return sec2, lbl.Text, "REC"
            end
        end
        local lbl2 = findTimerLabel(CoreGui, 0)
        if lbl2 and lbl2.Text then
            local sec3 = parseMMSS(lbl2.Text)
            if sec3 and (not requireClock or hasClockEmoji(lbl2.Text)) then
                if CONFIG.TIMER_USE_WIDGET_CACHE ~= false then
                    cachedTimerLabel  = lbl2
                    cachedTimerWidget = lbl2
                    cachedTimerName   = "COREGUI"
                    timerEverFound    = true
                end
                return sec3, lbl2.Text, "COREGUI"
            end
        end
        return nil, r1, src1 or "MISS"
    end)
    if not ok then return nil, nil, "ERROR" end
    return sec, raw, src
end


