local function randFloat(a, b) return a + (b - a) * math.random() end
local function randInt(a, b)   return math.random(a, b) end
local function strLower(s) if type(s) ~= "string" then return "" end; return string.lower(s) end
local function strContains(s, n) if type(s) ~= "string" or type(n) ~= "string" then return false end; return string.find(s, n, 1, true) ~= nil end
local function startsWith(s, p) if type(s) ~= "string" or type(p) ~= "string" then return false end; return string.sub(s, 1, #p) == p end
local function safeYield(d) if d and d > 0 then task.wait(d) else task.wait() end end

local function inBurstMode()
    return placementUnlocked and placementsSinceUnlock < (CONFIG.FAST_PLACE_FIRST_N or 0)
end

local function hasPendingPriority()
    if not CONFIG.PRIORITY_LOCK then return false end
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] and not priorityGivenUp[i]
           and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
            return true
        end
    end
    return false
end

local function hasGivenUpPriority()
    if not CONFIG.PRIORITY_LOCK then return false end
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i]
           and (priorityGivenUp[i] or priorityAttempts[i] >= CONFIG.PRIORITY_MAX_TRIES) then
            return true
        end
    end
    return false
end

-- Setelah PRIORITY_RETRY_AFTER_GIVEUP_SEC, slot giveup dipulihkan
local function recoverGiveupPrioritySlots()
    local sec = CONFIG.PRIORITY_RETRY_AFTER_GIVEUP_SEC or 0
    if sec <= 0 then return end
    local maxCycles = CONFIG.PRIORITY_MAX_GIVEUP_RETRIES or 0
    local now = os.clock()
    for i = 1, #SLOTS_PRIORITY do
        if priorityGivenUp[i] and not prioritySatisfied[i] then
            if (now - (priorityGiveupSince[i] or 0)) >= sec
               and not (maxCycles > 0 and (priorityGiveupCycles[i] or 0) >= maxCycles) then
                priorityGiveupCycles[i] = (priorityGiveupCycles[i] or 0) + 1
                priorityGivenUp[i]      = false
                priorityAttempts[i]     = 0
                priorityGiveupSince[i]  = 0
                if CONFIG.LOUD_PRIORITY then
                    print(string.format("[AutoPlaceV21] priority P%d giveup-cycle #%d -> retry",
                        i, priorityGiveupCycles[i]))
                end
            end
        end
    end
end


