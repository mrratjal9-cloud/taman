        while not placementUnlocked
              and (os.clock() - startT) < CONFIG.WAVE_BOOT_TIMEOUT do
            local sec, traw, tsrc = readTimerOnce()
            processTimerSnapshot(sec, traw, tsrc)
            local num, raw = readWaveOnce()
            processWaveSnapshot(num, raw)
            refreshStats()
            task.wait(0.03)
        end
        if not placementUnlocked then
            warn(string.format(
                "[AutoPlaceV21] Timer belum nyentuh %ds setelah %.1fs (mid-game fallback armed).",
                CONFIG.TIMER_UNLOCK_AT_SEC or 1, CONFIG.WAVE_BOOT_TIMEOUT))
        else
            print("[AutoPlaceV21] Placement ready (" .. unlockSource .. ")")
        end
        bootCompleted = true
    end


    while true do
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...", Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end
        pcall(refreshUICounts)
        pcall(reconcilePriorityFromUI)
        pcall(recoverGiveupPrioritySlots)

        if os.clock() < pausedUntil then
            task.wait(0.05)

        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)

        elseif capReached then
            currentPhase = "cap-reached"
            local cnt = CONFIG.CAP_COUNT_ONLY_TARGET and lastUITargetCount or lastUIAllUnits
            setBanner(string.format("CAP REACHED: %d/%d", cnt, CONFIG.PlacementUnitMaxCap),
                Color3.fromRGB(120, 220, 120))
            refreshStats()
            task.wait(1.0)

        else
            local unlockOk, gateReason = unlockGateOk()
            if not unlockOk then
                currentPhase = "locked"
                setBanner("LOCKED: " .. gateReason, Color3.fromRGB(255, 100, 100))
                refreshStats()
                task.wait(0.10)
            else
                local pendingP   = hasPendingPriority()
                local waveReady  = (lastWaveNum >= CONFIG.MAIN_START_WAVE)
                local doPriority = false
                if pendingP then
                    if not waveReady then
                        doPriority = true
                    elseif CONFIG.MAIN_REQUIRES_PRIORITY_OK then
                        doPriority = true
                    elseif not CONFIG.MAIN_FORCE_AFTER_WAVE then
                        doPriority = true
                    else
                        local p = CONFIG.PRIORITY_INTERLEAVE_CHANCE or 0.25
                        if p > 0 and math.random() < p then doPriority = true end
                    end
                end


                if doPriority then
                    currentPhase = "priority (RANDOM)"
                    local target = selectNextPrioritySlot()
                    if target then
                        local burst = inBurstMode()
                        setBanner(string.format("PRIORITY P%d  (try %d) [RANDOM]%s",
                            target, priorityAttempts[target] + 1,
                            burst and "  [BURST]" or ""),
                            burst and Color3.fromRGB(255, 240, 80)
                                  or  Color3.fromRGB(255, 220, 100))
                        local pOk = pcall(placePrioritySlot, target)
                        refreshStats()
                        local d
                        if not pOk or not prioritySatisfied[target] then
                            d = CONFIG.PRIORITY_FAIL_DELAY or 0.15
                        elseif burst then
                            d = CONFIG.FAST_PLACE_DELAY or 0
                        else
                            d = CONFIG.PRIORITY_DELAY or 0.1
                        end
                        safeYield(d)
                    else
                        task.wait(0.05)
                    end

                elseif waveReady then
                    local canMain, reason = canStartMainPhase()
                    if not canMain then
                        currentPhase = "waiting-gate"
                        setBanner("WAIT: " .. reason, Color3.fromRGB(255, 200, 100))
                        refreshStats()
                        task.wait(0.15)
                    else
                        local burst = inBurstMode()
                        local pTag  = hasGivenUpPriority() and " (P-giveup)" or ""
                        if isBackupActive() then
                            currentPhase = "main+backup"
                            setBanner("MAIN + BACKUP" .. pTag .. (burst and "  [BURST]" or ""),
                                Color3.fromRGB(120, 180, 240))
                        else
                            currentPhase = "main"
                            setBanner("MAIN PHASE" .. pTag .. (burst and "  [BURST]" or ""),
                                Color3.fromRGB(120, 220, 120))
                        end
                        local ok, err = pcall(placeMainOrBackupOnce)
                        if not ok then
                            warn("[AutoPlaceV21] Main loop error: " .. tostring(err))
                            lastResult = "ERROR: " .. tostring(err)
                        end
                        refreshStats()
                        if burst then
                            safeYield(CONFIG.FAST_PLACE_DELAY or 0)
                        else
                            local base  = CONFIG.LOOP_DELAY
                            local jit   = CONFIG.LOOP_JITTER or 0
                            local extra = (jit > 0) and randFloat(-jit, jit) or 0
                            safeYield(math.max(0.01, base + extra))
                        end
                    end
                else
                    currentPhase = "waiting-wave"
                    setBanner(string.format("WAIT WAVE >=%d (now=%s)",
                        CONFIG.MAIN_START_WAVE,
                        (lastWaveNum >= 0 and tostring(lastWaveNum) or "-")),
                        Color3.fromRGB(255, 200, 100))
                    refreshStats()
                    task.wait(0.15)
                end
            end
        end
    end
end)


