-- V20 punya branch INCOMING & COUNTDOWN; V21 hapus karena tidak dipakai unlock.
local function readWaveOnce()
    local ok, num, raw = pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local ggn     = pGui    and pGui:FindFirstChild("GameGuiNoInset")
        local screen  = ggn     and ggn:FindFirstChild("Screen")
        local top     = screen  and screen:FindFirstChild("Top")
        local info    = top     and top:FindFirstChild("GameInfo")
        local content = info    and info:FindFirstChild("Content")
        local waves   = content and content:FindFirstChild("Waves")
        local title   = waves   and waves:FindFirstChild("Title")
        if not title or not title.Text or title.Text == "" then return nil, nil end
        local t = title.Text
        local waveNum = string.match(t, "[Ww][Aa][Vv][Ee]%s*(%d+)")
        if waveNum then return tonumber(waveNum), t end
        return nil, t
    end)
    if not ok then return nil, nil end
    return num, raw
end

