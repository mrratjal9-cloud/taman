-- Reconcile priority dari UI count (anti-stuck saat verify lag)
local function reconcilePriorityFromUI()
    if not CONFIG.PRIORITY_RECONCILE_UI then return end
    if not CONFIG.PRIORITY_LOCK then return end
    if #SLOTS_PRIORITY == 0 then return end
    if lastUITargetCount < #SLOTS_PRIORITY then return end
    local changed = false
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] then prioritySatisfied[i] = true; changed = true end
    end
    if changed and CONFIG.LOUD_PRIORITY then
        print(string.format("[AutoPlaceV21] reconcilePriority: UI=%d >= P=%d -> all satisfied",
            lastUITargetCount, #SLOTS_PRIORITY))
    end
end

