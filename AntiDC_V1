local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")

print("Anti-DC: Auto-Rejoin ke Lobby Aktif")

-- Fungsi untuk menangani deteksi error/kick
GuiService.ErrorMessageChanged:Connect(function()
    -- Memberi jeda 2 detik agar client benar-benar siap melakukan teleportasi
