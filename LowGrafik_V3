-- ╚══════════════════════════════════════════════════════════╝
local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then return (tonumber(m) or 0) * 60 + (tonumber(s) or 0) end
        return nil
    end
    local n = string.match(t, "(%d+)")
    if n then return tonumber(n) end
    return nil
end

local function getInGameTimer()
    local ok, text = pcall(function()
        local tbs = PlayerGui:FindFirstChild("TopbarStandard")
        local hold = tbs and tbs:FindFirstChild("Holders")
        local rgt = hold and hold:FindFirstChild("Right")
        if not rgt then return "-" end

        for _, widget in ipairs(rgt:GetChildren()) do
            local lbl = widget:FindFirstChild("IconButton") and widget.IconButton:FindFirstChild("Menu") and widget.IconButton.Menu:FindFirstChild("IconSpot") and widget.IconButton.Menu.IconSpot:FindFirstChild("Contents") and widget.IconButton.Menu.IconSpot.Contents:FindFirstChild("IconLabelContainer") and widget.IconButton.Menu.IconSpot.Contents.IconLabelContainer:FindFirstChild("IconLabel")
            if lbl and lbl.Text and string.find(lbl.Text, "⏱") then
                return lbl.Text
            end
        end
        return "-"
    end)
    return ok and text or "-"
end

local function updateTracker()
    -- 1) Cek Waktu Live (Mencatat rekor tertinggi)
    local sessionTimerText = getInGameTimer()
    local currentSec = parseMMSS(sessionTimerText)

    if currentSec and currentSec > maxSessionSec then
        maxSessionSec = currentSec
    end
    stats.SessionTimerString = (sessionTimerText ~= "-") and string.gsub(sessionTimerText, "⏱%s*", "") or "-"

    -- 2) Cek Status Akhir Game Berdasarkan GameEnd UI
    pcall(function()
        local gameEndUI = PlayerGui:FindFirstChild("GameGui")
            and PlayerGui.GameGui:FindFirstChild("Screen")
            and PlayerGui.GameGui.Screen:FindFirstChild("Middle")
            and PlayerGui.GameGui.Screen.Middle:FindFirstChild("GameEnd")
            
        if gameEndUI then
            if gameEndUI.Visible == true then
                if not gameEndedHandled then
                    -- Layar GameEnd baru saja muncul
                    totalGamesPlayed = totalGamesPlayed + 1
                    lastGameTime = maxSessionSec -- Simpan rekor waktu sebelum mati/menang
                    gameEndedHandled = true
                end
            else
                if gameEndedHandled then
                    -- Layar GameEnd hilang (Masuk ronde baru)
                    gameEndedHandled = false
                    maxSessionSec = 0 -- Reset rekor waktu untuk ronde baru
                end
            end
        end
    end)

    -- 3) Cek Seed Berjalan
    pcall(function()
        local gameGui = PlayerGui:FindFirstChild("GameGui")
        local title = gameGui.Screen.Bottom.CurrencyDisplay.SeedsDisplay.Title
        if title and title.Text ~= "" then
            local num = tonumber((string.gsub(title.Text, "[^%d]", "")))
            if num then stats.SeedNow = num end
        end
    end)

    -- 4) Cek Wave Saat Ini
    pcall(function()
        local gameGuiNoInset = PlayerGui:FindFirstChild("GameGuiNoInset")
        local title = gameGuiNoInset.Screen.Top.GameInfo.Content.Waves.Title
        if title and title.Text ~= "" then
            stats.Wave = title.Text
        end
    end)
end

