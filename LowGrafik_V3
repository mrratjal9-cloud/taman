local function checkLabelText(label, uuid)
    if processedSeeds[uuid] then return end 
    local amountStr = string.match(label.Text, "You got ([%d,]+) Seeds!")
    if amountStr then
        local amount = tonumber((string.gsub(amountStr, ",", "")))
        if amount then
            processedSeeds[uuid] = true 
            lastRoundSeed = amount
            totalEarnedSeed = totalEarnedSeed + amount
        end
    end
end

local function onNotificationAdded(child)
    local label = child:WaitForChild("Label", 5) 
    if label and label:IsA("TextLabel") then
        local uuid = child.Name
        checkLabelText(label, uuid)
        label:GetPropertyChangedSignal("Text"):Connect(function()
            checkLabelText(label, uuid)
        end)
    end
end

