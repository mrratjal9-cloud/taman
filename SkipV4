-- Path: PlayerGui.GameGuiNoInset.Screen.Top.WaveControls.TickSpeed.Items.{1|2|3}
local function getTickSpeedButton(n)
    local gui   = safeChild(PlayerGui, "GameGuiNoInset")
    local scr   = safeChild(gui, "Screen")
    local top   = safeChild(scr, "Top")
