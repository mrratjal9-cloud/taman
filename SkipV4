local function getProtectedParent()
    local ok, hui = pcall(function() return gethui() end)
    if ok and hui then
        dprint("Parent: gethui()")
        return hui
    end
    local ok2 = pcall(function() return CoreGui.Name end)
    if ok2 then
        dprint("Parent: CoreGui")
        return CoreGui
    end
    dprint("Parent: PlayerGui (fallback)")
    return PlayerGui
end


