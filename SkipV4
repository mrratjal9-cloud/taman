-- ╔══════════════════════════════════════════════════════════╗
-- ║          SAFE CLICK (firesignal/getconnections only)      ║
-- ╚══════════════════════════════════════════════════════════╝
-- Klik HANYA via firesignal / getconnections. TIDAK pakai
-- VirtualInputManager (penyebab flag macro di V1/V2/V3).
-- firesignal beroperasi di sisi client, server tidak lihat
-- ini sebagai input fisik dari mouse -> aman dari macro detection.
local function fireSignals(obj, signalNames)
    if not obj then return false end
    local fired = false
    for _, sig in ipairs(signalNames) do
        pcall(function()
            local ev = obj[sig]
            if not ev then return end

            -- Method 1: getconnections + Fire (paling akurat di executor support)
            if typeof(getconnections) == "function" then
                local conns = getconnections(ev)
                if conns then
                    for _, c in ipairs(conns) do
                        local ok = pcall(function() c:Fire() end)
                        if not ok and typeof(firesignal) == "function" then
                            pcall(function() firesignal(c) end)
                        end
                        fired = true
                    end
                end
            end

            -- Method 2: firesignal global event
            if (not fired) and typeof(firesignal) == "function" then
                pcall(function() firesignal(ev) end)
                fired = true
            end
        end)
    end
    return fired
end

local function safeClick(button)
    if not button or not button.Parent then return false end
    local SIGNALS = { "MouseButton1Click", "Activated" }

    local fired = fireSignals(button, SIGNALS)

    -- Klik juga child "Title" (di game ini Title ImageButton/TextLabel
    -- kadang yang punya handler aktif)
    local title = button:FindFirstChild("Title")
    if title and (title:IsA("TextLabel") or title:IsA("ImageLabel")
                  or title:IsA("TextButton") or title:IsA("ImageButton")) then
        if fireSignals(title, SIGNALS) then fired = true end
    end

    return fired
end


