-- ║   APPLY GameSpeed di awal eksekusi (sesuai Config)        ║
-- ╚══════════════════════════════════════════════════════════╝
-- Tidak dipanggil di main loop (anti-spam), cuma sekali di awal
-- saat tombol TickSpeed.Items.N sudah eksis.
task.spawn(function()
    local startedAt = os.clock()
    while isRunning and (os.clock() - startedAt) < SPEED_APPLY_TIMEOUT do
        local btn = getTickSpeedButton(Config.GameSpeed)
        if btn then
            local ok, err = applyGameSpeed(Config.GameSpeed)
            if ok then
                dprint("Initial speed -> " .. Config.GameSpeed .. "x")
                setStatus("Speed " .. Config.GameSpeed .. "x ter-apply.")
                return
            else
                dprint("Initial speed gagal: " .. tostring(err))
            end
        end
        task.wait(1)
    end
    dprint("Initial speed timeout - tombol TickSpeed gak muncul.")
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       MAIN LOOP                           ║
-- ╚══════════════════════════════════════════════════════════╝
math.randomseed(tick() % 1 * 1e7 + os.time())

task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        -- Jeda random tiap iterasi (anti pattern macro detection)
        local jitter = LOOP_INTERVAL_MIN + math.random() * (LOOP_INTERVAL_MAX - LOOP_INTERVAL_MIN)
        task.wait(jitter)

        if not isRunning then break end

        local now = os.clock()
        local statusParts = {}

        -- ── [A] AUTO SKIP ──
        if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AUTOSKIP_COOLDOWN then
            local btn = getAutoSkipButton()
            if btn then
                local titleLabel = btn:FindFirstChild("Title")
                local titleText = (titleLabel and titleLabel:IsA("TextLabel")) and titleLabel.Text or ""
                -- Hanya klik kalau title bilang "Off" (artinya AutoSkip lagi mati)
                if string.find(string.lower(titleText), "off") then
                    if safeClick(btn) then
                        table.insert(statusParts, "AutoSkip -> ON")
                        dprint("AutoSkip clicked. Title was:", titleText)
                        lastAutoSkipClickAt = os.clock()
                    end
                end
            end
        end

        -- ── [B] MANUAL SKIP ──
        if Config.ManualSkip then
            local cooldown = MANUAL_COOLDOWN_MIN
              + math.random() * (MANUAL_COOLDOWN_MAX - MANUAL_COOLDOWN_MIN)
            if (now - lastManualClickAt) >= cooldown then
                local frame = getSkipWaveFrame()
                if frame and frame.Visible then
                    local mbtn = frame:FindFirstChild("Button")
                    if mbtn then
                        if safeClick(mbtn) then
                            table.insert(statusParts, "SkipWave clicked")
                            dprint("SkipWave clicked.")
                            lastManualClickAt = os.clock()
                        end
                    end
                end
            end
        end

        if #statusParts == 0 then
            setStatus("Watching... | AS=" .. tostring(Config.AutoSkip)
                .. " MS=" .. tostring(Config.ManualSkip)
                .. " Speed=" .. Config.GameSpeed .. "x")
        else
            setStatus(table.concat(statusParts, " | "), Color3.fromRGB(255, 220, 120))
        end
    end
    dprint("Main loop berhenti.")
end)

print("[SkipV4] Loaded."
    .. " AutoSkip="   .. tostring(Config.AutoSkip)
    .. " | ManualSkip=" .. tostring(Config.ManualSkip)
    .. " | GameSpeed="  .. Config.GameSpeed .. "x")
