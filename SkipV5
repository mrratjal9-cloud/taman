    ManualSkip = true,    -- true = saat eksekusi, otomatis klik "Skip Wave >>" tiap kali frame SkipWave muncul (loop). false = nonaktif total.

}

-- ── [KATEGORI 2] GAME SPEED (Tick Speed) ───────────────────
-- Speed gameplay yang langsung di-apply saat eksekusi.
-- IMPLEMENTASI: KLIK tombol TickSpeed.Items.{1|2|3} pakai
-- firesignal (BUKAN InvokeServer ChangeTickSpeed). Ini lebih
-- aman -> tidak men-trigger anti-cheat seperti V2.
local SpeedConfig = {

    GameSpeed  = 2,       -- 1 / 2 / 3 (max 3x). Di-apply OTOMATIS sekali di awal + tiap kali round baru dimulai. Kalau diisi >3 akan di-clamp ke 3.

}

-- ── [KATEGORI 3] ANTI-FLAG / ANTI-MACRO ────────────────────
-- Menyamarkan pola klik supaya tidak terdeteksi sebagai macro.
local AntiFlagConfig = {

    LoopIntervalMin     = 0.8,    -- detik. Jeda MIN antar iterasi loop (random antara MIN..MAX biar gak rapi).
    LoopIntervalMax     = 1.4,    -- detik. Jeda MAX antar iterasi loop.
    AutoSkipCooldown    = 3.0,    -- detik. Setelah klik AutoSkip, tunggu sekian detik sebelum cek/klik ulang.
    ManualCooldownMin   = 1.2,    -- detik. Cooldown MIN klik Skip Wave (random).
    ManualCooldownMax   = 2.0,    -- detik. Cooldown MAX klik Skip Wave.
    VerifyDelay         = 0.4,    -- detik. Setelah klik AutoSkip, jeda sebelum verifikasi Title-nya berubah.

}

-- ── [KATEGORI 4] STARTUP / WATCHDOG ────────────────────────
-- Pengaturan retry saat startup dan deteksi path UI.
local WatchdogConfig = {

    SpeedApplyTimeout   = 30,     -- detik. Berapa lama nungguin tombol TickSpeed muncul saat startup.
    PathMissingWarnAt   = 20,     -- jumlah iterasi. Kalau path UI hilang sekian iterasi berturut-turut, panel kasih warning ("path mungkin berubah").

}

