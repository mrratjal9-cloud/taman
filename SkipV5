-- ╔══════════════════════════════════════════════════════════╗
-- ║   AUTO-APPLY GameSpeed di awal eksekusi (sesuai Config)   ║
-- ╚══════════════════════════════════════════════════════════╝
-- Strategi:
--   1) Tunggu tombol TickSpeed.Items.{N} muncul (max SpeedApplyTimeout)
--   2) Apply sekali. Tidak loop spam.
--   3) Loop utama akan re-apply OTOMATIS kalau deteksi
--      WaveControls baru (round baru / round restart) -> ini
--      menangani kasus user load script di lobby lalu masuk
--      gameplay setelah > timeout.
task.spawn(function()
    local startedAt = os.clock()
    while isRunning and (os.clock() - startedAt) < WatchdogConfig.SpeedApplyTimeout do
        if applyGameSpeed(SpeedConfig.GameSpeed) then
            setStatus("Initial Speed -> " .. SpeedConfig.GameSpeed .. "x ter-apply.")
            return
        end
        task.wait(1)
    end
    setStatus("Initial speed timeout. Akan retry saat round mulai.",
        Color3.fromRGB(220, 200, 120))
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       MAIN LOOP                           ║
-- ╚══════════════════════════════════════════════════════════╝
math.randomseed(tick() % 1 * 1e7 + os.time())

task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        -- Jeda random tiap iterasi (anti pattern macro detection)
        local jitter = AntiFlagConfig.LoopIntervalMin
            + math.random() * (AntiFlagConfig.LoopIntervalMax - AntiFlagConfig.LoopIntervalMin)
        task.wait(jitter)

        if not isRunning then break end

        if isPausedByUser then
            -- skip iterasi
        else
            local now = os.clock()
            local statusParts = {}
            local wc = getWaveControls()

            -- ── Deteksi round baru -> re-apply GameSpeed ──
            if wc and wc ~= lastSeenWaveControls then
                if lastSeenWaveControls ~= nil then
                    -- WaveControls instance baru = round baru
                    dprint("Round baru terdeteksi, re-apply speed.")
                    task.spawn(function()
                        task.wait(0.5)
                        applyGameSpeed(SpeedConfig.GameSpeed)
                    end)
                    table.insert(statusParts, "Re-apply " .. SpeedConfig.GameSpeed .. "x")
                end
                lastSeenWaveControls = wc
                pathMissingCounter = 0
            end

            if not wc then
                pathMissingCounter = pathMissingCounter + 1
                if pathMissingCounter >= WatchdogConfig.PathMissingWarnAt then
                    setStatus("Path WaveControls hilang. Game di lobby? atau path UI berubah?",
                        Color3.fromRGB(220, 130, 130))
                else
                    setStatus("Standby (bukan di gameplay).")
                end
            else
                pathMissingCounter = 0

                -- ── [A] AUTO SKIP (verify-after-click) ──
                if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AntiFlagConfig.AutoSkipCooldown then
                    local btn = getAutoSkipButton()
                    local titleLabel = btn and btn:FindFirstChild("Title")
                    local titleText = (titleLabel and titleLabel:IsA("TextLabel")) and titleLabel.Text or ""
                    if btn and string.find(string.lower(titleText), "off") then
                        if safeClick(btn) then
                            lastAutoSkipClickAt = os.clock()
                            -- Verifikasi: tunggu sebentar lalu cek lagi
                            task.spawn(function()
                                task.wait(AntiFlagConfig.VerifyDelay)
                                local t2 = btn:FindFirstChild("Title")
                                local txt2 = (t2 and t2:IsA("TextLabel")) and t2.Text or ""
                                if string.find(string.lower(txt2), "off") then
                                    dprint("Verify: AutoSkip masih Off, akan retry di iterasi berikutnya.")
                                else
                                    dprint("Verify: AutoSkip sudah ON.")
                                end
                            end)
                            table.insert(statusParts, "AutoSkip clicked")
                        end
                    end
                end

                -- ── [B] MANUAL SKIP ──
                if Config.ManualSkip then
                    local cd = AntiFlagConfig.ManualCooldownMin
                        + math.random() * (AntiFlagConfig.ManualCooldownMax - AntiFlagConfig.ManualCooldownMin)
                    if (now - lastManualClickAt) >= cd then
                        local frame = getSkipWaveFrame()
                        if frame and frame.Visible then
                            local mbtn = frame:FindFirstChild("Button")
                            if mbtn then
                                if safeClick(mbtn) then
                                    table.insert(statusParts, "SkipWave clicked")
                                    lastManualClickAt = os.clock()
                                end
                            end
                        end
                    end
                end

                if #statusParts == 0 then
                    setStatus("Watching... | AS=" .. tostring(Config.AutoSkip)
                        .. "  MS=" .. tostring(Config.ManualSkip)
                        .. "  Speed=" .. SpeedConfig.GameSpeed .. "x")
                else
                    setStatus(table.concat(statusParts, " | "), Color3.fromRGB(255, 220, 120))
                end
            end
        end
    end
    dprint("Main loop berhenti.")
end)

print(string.format(
    "[SkipV5] Loaded. AutoSkip=%s | ManualSkip=%s | GameSpeed=%dx",
    tostring(Config.AutoSkip),
    tostring(Config.ManualSkip),
    SpeedConfig.GameSpeed
))
