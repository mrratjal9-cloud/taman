-- ║                  GAMESPEED APPLIER                        ║
-- ╚══════════════════════════════════════════════════════════╝
-- Set GameSpeed dengan KLIK TombolTickSpeed (bukan InvokeServer).
local function applyGameSpeed(n)
    local btn = getTickSpeedButton(n)
    if not btn then return false, "TickSpeed.Items." .. n .. " belum ada" end
    if safeClick(btn) then return true end
    return false, "klik gagal"
end


