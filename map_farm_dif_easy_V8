-- ==========================================
-- HELPERS
-- ==========================================
local function randFloat(a, b) return a + (b - a) * math.random() end
local function randInt(a, b)   return math.random(a, b) end

local function strLower(s)
    if type(s) ~= "string" then return "" end
    return string.lower(s)
end
local function strContains(s, needle)
    if type(s) ~= "string" or type(needle) ~= "string" then return false end
    return string.find(s, needle, 1, true) ~= nil
end

local function countTrue(t, total)
    local n = 0
    for i = 1, total do if t[i] then n = n + 1 end end
    return n
end
local function countPriorityDone() return countTrue(prioritySatisfied, #SLOTS_PRIORITY) end
local function countMainDone()     return countTrue(mainSatisfied,     #SLOTS_MAIN) end
local function countMainPending()  return #SLOTS_MAIN - countMainDone() end

local function hasPendingPriority()
    if not CONFIG.PRIORITY_LOCK then return false end
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
            return true
        end
    end
    return false
end

-- ==========================================
-- WAVE READER (refactored, dipakai sync & periodic)
-- Path: PlayerGui.GameGuiNoInset.Screen.Top.GameInfo.Content.Waves.Title
-- Format yang di-handle: "Wave 15", "Level 1: Wave 15 / 15", dll.
-- ==========================================
local function readWaveOnce()
    local ok, currentWave, rawText = pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local ggn     = pGui    and pGui:FindFirstChild("GameGuiNoInset")
        local screen  = ggn     and ggn:FindFirstChild("Screen")
        local top     = screen  and screen:FindFirstChild("Top")
        local info    = top     and top:FindFirstChild("GameInfo")
        local content = info    and info:FindFirstChild("Content")
        local waves   = content and content:FindFirstChild("Waves")
        local title   = waves   and waves:FindFirstChild("Title")
        if title and title.Text and title.Text ~= "" then
            local m = string.match(title.Text, "[Ww][Aa][Vv][Ee]%s*(%d+)")
            if m then
                return tonumber(m), title.Text
            end
            return nil, title.Text
        end
        return nil, nil
    end)
    if not ok then return nil, nil end
    return currentWave, rawText
end

-- ==========================================
-- MAIN PHASE GATE
-- ==========================================
local function canStartMainPhase()
    if hasPendingPriority() then
        return false, "menunggu priority done"
    end

    local minWave = CONFIG.MAIN_START_WAVE or 1

    if lastWaveNum < 0 then
        if CONFIG.IGNORE_WAVE_GATE_IF_NO_WAVE then
            return true, "wave undetected, gate diabaikan"
        else
            return false, "menunggu wave terdeteksi"
        end
    end

    if lastWaveNum < minWave then
        return false, string.format("menunggu wave >= %d (sekarang %d)", minWave, lastWaveNum)
    end

    return true, "ok"
end

-- ==========================================
-- SHUFFLE-BAG
-- ==========================================
local function buildBag(n)
    local bag = {}
    for i = 1, n do bag[i] = i end
    for i = n, 2, -1 do
        local j = randInt(1, i)
        bag[i], bag[j] = bag[j], bag[i]
    end
    return bag
end
local function refillMainBag()   mainBag   = buildBag(#SLOTS_MAIN)   end
local function refillBackupBag() backupBag = buildBag(#SLOTS_BACKUP) end

-- ==========================================
-- INIT / RESET
-- ==========================================
local function initSlotState()
    for i = 1, #SLOTS_PRIORITY do
        prioritySatisfied[i] = false
        priorityAttempts[i]  = 0
    end
    for i = 1, #SLOTS_MAIN do
        mainSatisfied[i] = false
    end
    refillMainBag()
    if #SLOTS_BACKUP > 0 then refillBackupBag() end
end
initSlotState()

local function performReset(reason)
    initSlotState()
    gameCount    = gameCount + 1
    lastResetAt  = os.clock()
    pausedUntil  = os.clock() + CONFIG.RESET_COOLDOWN
    currentPhase = "reset (cooldown)"
    pendingReset = false
    lastResult   = string.format("RESET game #%d: %s", gameCount, tostring(reason))
    print(string.format("[AutoPlaceV8] === RESET TRIGGERED === game #%d | reason: %s",
        gameCount, tostring(reason)))
end

