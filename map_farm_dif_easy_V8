-- ==========================================
-- ROTATION & ARGS
-- ==========================================
local function pickRotationDeg()
    local m = CONFIG.ROTATION_MODE
    if m == "off"    then return 0 end
    if m == "fixed"  then return CONFIG.FIXED_ROTATION_DEG or 0 end
    if m == "smooth" then return randFloat(0, 360) end
    local steps = { 0, 90, 180, 270 }
    return steps[randInt(1, 4)]
end

local function buildArgs(slotXYZ)
    local off = CONFIG.POSITION_OFFSET or 0
    local dx, dz = 0, 0
    if off > 0 then
        dx = randFloat(-off, off)
        dz = randFloat(-off, off)
    end
    local x = slotXYZ[1] + dx
    local y = slotXYZ[2]
    local z = slotXYZ[3] + dz
    local rotDeg = pickRotationDeg()
    local cf  = CFrame.new(x, y, z) * CFrame.Angles(0, math.rad(rotDeg), 0)
    local pos = Vector3.new(x, y, z)
    local args = {
        CONFIG.TARGET_UNIT,
        { CF = cf, Rotation = rotDeg, Valid = true, Position = pos }
    }
    return args, rotDeg
end

-- ==========================================
-- PLACEMENT REMOTE
-- ==========================================
local placeUnitRemote
local function getPlaceUnitRemote()
    if placeUnitRemote and placeUnitRemote.Parent then return placeUnitRemote end
    local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if rf then placeUnitRemote = rf:FindFirstChild("PlaceUnit") end
    return placeUnitRemote
end

local function isSuccessReturn(ok, ret)
    if not ok then return false end
    if ret == false then return false end
    if type(ret) == "string" and strContains(strLower(ret), "fail") then return false end
    if type(ret) == "table" and ret.success == false then return false end
    return true
end

-- ==========================================
-- PRIORITY PLACEMENT
-- ==========================================
local function placePrioritySlot(idx)
    local remote = getPlaceUnitRemote()
    if not remote then return false, "remote belum ready" end

    priorityAttempts[idx] = priorityAttempts[idx] + 1
    local args, rotDeg = buildArgs(SLOTS_PRIORITY[idx])
    local ok, ret = pcall(function()
        return remote:InvokeServer(_unpack(args))
    end)
    local success = isSuccessReturn(ok, ret)
    local detail  = string.format("[P%d try=%d] rot=%s ret=%s",
        idx, priorityAttempts[idx], tostring(rotDeg), tostring(ret))

    if success then
        prioritySatisfied[idx] = true
        stats.placed_p = stats.placed_p + 1
        stats.ok_p     = stats.ok_p + 1
        lastResult     = "OK " .. detail
        if CONFIG.LOUD_PRIORITY_LOG then
            print("[AutoPlaceV8] [PRIORITY OK] " .. detail)
        end
        return true
    else
        if priorityAttempts[idx] >= CONFIG.PRIORITY_MAX_TRIES then
            stats.placed_p = stats.placed_p + 1
            stats.fail_p   = stats.fail_p + 1
            lastResult     = "FAIL (giveup) " .. detail
            warn("[AutoPlaceV8] [PRIORITY GIVEUP] P" .. idx ..
                " setelah " .. priorityAttempts[idx] .. " tries.")
        else
            lastResult = "fail " .. detail
            if CONFIG.LOUD_PRIORITY_LOG then
                print("[AutoPlaceV8] [priority retry] " .. detail)
            end
        end
        return false
    end
end

-- ==========================================
-- MAIN/BACKUP PLACEMENT
-- ==========================================
local function selectMainOrBackup()
    if isBackupActive() and math.random() < CONFIG.BACKUP_PICK_CHANCE then
        if #backupBag == 0 then refillBackupBag() end
        local idx = table.remove(backupBag, 1)
        return "B", idx, SLOTS_BACKUP[idx]
    end
    local pending = countMainPending()
    if pending > 0 then
        local pendingList = {}
        for i = 1, #SLOTS_MAIN do
            if not mainSatisfied[i] then pendingList[#pendingList + 1] = i end
        end
        local idx = pendingList[randInt(1, #pendingList)]
        return "M", idx, SLOTS_MAIN[idx]
    end
    if #mainBag == 0 then refillMainBag() end
    local idx = table.remove(mainBag, 1)
    return "M", idx, SLOTS_MAIN[idx]
end

local function placeMainOrBackupOnce()
    local remote = getPlaceUnitRemote()
    if not remote then return false, "remote belum ready" end

    local phaseTag, slotIdx, slotXYZ = selectMainOrBackup()
    local args, rotDeg = buildArgs(slotXYZ)
    local ok, ret = pcall(function()
        return remote:InvokeServer(_unpack(args))
    end)
    local success = isSuccessReturn(ok, ret)
    local detail  = string.format("[%s%d] rot=%s ret=%s",
        phaseTag, slotIdx, tostring(rotDeg), tostring(ret))

    if success then
        if phaseTag == "M" then
            mainSatisfied[slotIdx] = true
            stats.placed_m = stats.placed_m + 1
            stats.ok_m     = stats.ok_m + 1
        else
            stats.placed_b = stats.placed_b + 1
            stats.ok_b     = stats.ok_b + 1
        end
    else
        if phaseTag == "M" then
            stats.placed_m = stats.placed_m + 1
            stats.fail_m   = stats.fail_m + 1
        else
            stats.placed_b = stats.placed_b + 1
            stats.fail_b   = stats.fail_b + 1
        end
    end

    lastResult = (success and "OK " or "FAIL ") .. detail
    if CONFIG.VERBOSE then
        if success then print("[AutoPlaceV8] " .. lastResult)
        else            warn("[AutoPlaceV8] " .. lastResult) end
    end
    return success
end

-- ==========================================
-- WAVE OBSERVER (process detected wave)
-- ==========================================
local function detectRestart(prev, cur)
    if not CONFIG.AUTO_RESET_ON_RESTART then return nil end
    if prev <= 0 then return nil end
    if CONFIG.DETECT_WAVE_DECREASE and cur < prev and prev >= 2 then
        return string.format("wave decrease %d -> %d", prev, cur)
    end
    if CONFIG.DETECT_WAVE_CYCLE
       and maxWaveSeen >= CONFIG.STOP_WAVE
       and cur <= CONFIG.START_WAVE
       and prev > cur then
        return string.format("wave cycle (max=%d, %d -> %d)", maxWaveSeen, prev, cur)
    end
    return nil
end

local function processWaveSnapshot(cur, rawText)
    if rawText then lastWaveTextRaw = rawText end
    if cur == nil then return end

    if cur ~= lastWaveNum then
        local prev = lastWaveNum
        lastWaveNum = cur
        if cur > maxWaveSeen then maxWaveSeen = cur end

        local restartReason = detectRestart(prev, cur)
        if restartReason then
            print("[AutoPlaceV8] === GAME RESTART DETECTED === " .. restartReason)
            pendingReset = true
            maxWaveSeen = cur
        end

        if cur == CONFIG.START_WAVE and not isRunning then
            print("[AutoPlaceV8] Reach START_WAVE -> ON")
            setScriptState(true)
        elseif cur == CONFIG.STOP_WAVE and isRunning then
            print("[AutoPlaceV8] Reach STOP_WAVE -> OFF")
            setScriptState(false)
        end
    end
end

-- ==========================================
-- WAVE PERIODIC LOOP (background, fast at startup)
-- ==========================================
task.spawn(function()
    local readsCount = 0
    while true do
        if CONFIG.WAVE_CONTROL then
            local cur, raw = readWaveOnce()
            processWaveSnapshot(cur, raw)
        end

        readsCount = readsCount + 1
        local interval
        if readsCount < 20 then
            interval = CONFIG.WAVE_FAST_INTERVAL or 0.15
        else
            interval = CONFIG.WAVE_SLOW_INTERVAL or 0.5
        end
        task.wait(interval)
    end
end)

-- ==========================================
-- MAIN ORCHESTRATOR
-- ==========================================
refreshStats()

task.spawn(function()
    -- 1) BOOT DELAY
    setBanner("BOOT DELAY... " .. CONFIG.BOOT_DELAY .. "s",
        Color3.fromRGB(255, 165, 0))
    print(string.format("[AutoPlaceV8] BOOT_DELAY: tunggu %.1fs...", CONFIG.BOOT_DELAY))
    task.wait(CONFIG.BOOT_DELAY)

    -- 2) SYNC WAVE DETECTION (NEW V8): tunggu wave terbaca
    if CONFIG.WAVE_CONTROL and not CONFIG.IGNORE_WAVE_GATE_IF_NO_WAVE then
        setBanner("DETECT WAVE...", Color3.fromRGB(255, 200, 100))
        print(string.format("[AutoPlaceV8] Detecting wave (timeout=%.1fs)...",
            CONFIG.WAVE_BOOT_TIMEOUT))
        local startT = os.clock()
        while lastWaveNum < 0 and (os.clock() - startT) < CONFIG.WAVE_BOOT_TIMEOUT do
            local cur, raw = readWaveOnce()
            processWaveSnapshot(cur, raw)
            refreshStats()
            task.wait(0.1)
        end
        if lastWaveNum < 0 then
            warn(string.format(
                "[AutoPlaceV8] Wave tidak terdeteksi setelah %.1fs. " ..
                "Gate tetap STRICT (no main).",
                CONFIG.WAVE_BOOT_TIMEOUT))
        else
            print(string.format("[AutoPlaceV8] Wave detected: %d (txt='%s')",
                lastWaveNum, tostring(lastWaveTextRaw)))
        end
    end

    -- 3) MAIN LOOP
    while true do
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...", Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end

        if os.clock() < pausedUntil then
            task.wait(0.1)
        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)
        elseif hasPendingPriority() then
            currentPhase = "priority (AWAL)"
            local target = nil
            for i = 1, #SLOTS_PRIORITY do
                if not prioritySatisfied[i]
                   and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                    target = i
                    break
                end
            end
            if target then
                setBanner(string.format("PRIORITY %d/%d  (try %d)",
                    target, #SLOTS_PRIORITY, priorityAttempts[target] + 1),
                    Color3.fromRGB(255, 220, 100))
                pcall(placePrioritySlot, target)
                refreshStats()
                task.wait(CONFIG.PRIORITY_DELAY)
            end
        else
            local canMain, reason = canStartMainPhase()
            if not canMain then
                currentPhase = "waiting-wave-gate"
                setBanner("WAIT: " .. reason, Color3.fromRGB(255, 200, 100))
                refreshStats()
                task.wait(0.4)
            else
                if isBackupActive() then
                    currentPhase = "main+backup"
                    setBanner("MAIN + BACKUP", Color3.fromRGB(120, 180, 240))
                elseif countMainPending() == 0 then
                    currentPhase = "main (cycle - all done)"
                    setBanner("MAIN cycle (all done)", Color3.fromRGB(120, 220, 120))
                else
                    currentPhase = "main"
                    setBanner("MAIN PHASE", Color3.fromRGB(120, 220, 120))
                end

                local ok, err = pcall(placeMainOrBackupOnce)
                if not ok then
                    warn("[AutoPlaceV8] Main loop error: " .. tostring(err))
                    lastResult = "ERROR: " .. tostring(err)
                end
                refreshStats()

                local base  = CONFIG.LOOP_DELAY
                local jit   = CONFIG.LOOP_DELAY_JITTER or 0
                local extra = (jit > 0) and randFloat(-jit, jit) or 0
                task.wait(math.max(0.01, base + extra))
            end
        end
    end
end)

