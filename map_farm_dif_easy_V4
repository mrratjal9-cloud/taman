-- ==========================================
-- SHUFFLE-BAG (Fisher-Yates)
-- ==========================================
local function buildBag(n)
    local bag = {}
    for i = 1, n do bag[i] = i end
    for i = n, 2, -1 do
        local j = randInt(1, i)
        bag[i], bag[j] = bag[j], bag[i]
    end
    return bag
end

local function refillMainBag()
    mainBag = buildBag(#SLOTS_MAIN)
end
local function refillBackupBag()
    backupBag = buildBag(#SLOTS_BACKUP)
end

-- ==========================================
-- ROTATION GENERATOR
-- ==========================================
local function pickRotationDeg()
    local m = CONFIG.ROTATION_MODE
    if m == "off" then
        return 0
    elseif m == "fixed" then
        return CONFIG.FIXED_ROTATION_DEG or 0
    elseif m == "smooth" then
        return randFloat(0, 360)
    else
        local steps = { 0, 90, 180, 270 }
        return steps[randInt(1, 4)]
    end
end

-- ==========================================
-- BUILD PLACEMENT ARGS
-- ==========================================
local function buildArgs(slotXYZ)
    local off = CONFIG.POSITION_OFFSET or 0
    local dx, dz = 0, 0
    if off > 0 then
        dx = randFloat(-off, off)
        dz = randFloat(-off, off)
    end

    local x = slotXYZ[1] + dx
    local y = slotXYZ[2]
    local z = slotXYZ[3] + dz

    local rotDeg = pickRotationDeg()
    local cf = CFrame.new(x, y, z) * CFrame.Angles(0, math.rad(rotDeg), 0)
    local pos = Vector3.new(x, y, z)

    local args = {
        CONFIG.TARGET_UNIT,
        {
            CF       = cf,
            Rotation = rotDeg,
            Valid    = true,
            Position = pos,
        }
    }
    return args, rotDeg
end

