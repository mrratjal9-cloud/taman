local placeUnitRemote
local function getPlaceUnitRemote()
    if placeUnitRemote and placeUnitRemote.Parent then return placeUnitRemote end
    local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if rf then placeUnitRemote = rf:FindFirstChild("PlaceUnit") end
    return placeUnitRemote
end

local function isSuccessReturn(ok, ret)
    if not ok then return false end
    if ret == false then return false end
    if type(ret) == "string" and strContains(strLower(ret), "fail") then
        return false
    end
    if type(ret) == "table" and ret.success == false then
        return false
    end
    return true
end

-- ==========================================
-- SLOT SELECTOR (PHASE LOGIC)
-- ==========================================
-- Return: phaseTag ("P"/"M"/"B"), slotIdx, slotXYZ
local function selectSlot()
    -- ===== PHASE 1: PRIORITY (selalu duluan kalau belum semua sukses) =====
    if CONFIG.PRIORITY_LOCK then
        for i = 1, #SLOTS_PRIORITY do
            if not prioritySatisfied[i] then
                if priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                    return "P", i, SLOTS_PRIORITY[i]
                end
            end
        end
    end

    -- ===== PHASE 3: BACKUP (probabilistik, hanya saat aktif) =====
    if isBackupActive() and math.random() < CONFIG.BACKUP_PICK_CHANCE then
        if #backupBag == 0 then refillBackupBag() end
        local idx = table.remove(backupBag, 1)
        return "B", idx, SLOTS_BACKUP[idx]
    end

    -- ===== PHASE 2: MAIN (shuffle bag, prefer slot yang belum sukses) =====
    -- Kalau masih ada main pending, pilih dari pending dulu
    local pending = countMainPending()
    if pending > 0 then
        -- Build pending list
        local pendingList = {}
        for i = 1, #SLOTS_MAIN do
            if not mainSatisfied[i] then
                pendingList[#pendingList + 1] = i
            end
        end
        local idx = pendingList[randInt(1, #pendingList)]
        return "M", idx, SLOTS_MAIN[idx]
    end

    -- ===== PHASE 4: ALL DONE -> continuous main shuffle bag =====
    if #mainBag == 0 then refillMainBag() end
    local idx = table.remove(mainBag, 1)
    return "M", idx, SLOTS_MAIN[idx]
end

local function updatePhaseLabel(phaseTag)
    if phaseTag == "P" then
        currentPhase = "priority (AWAL)"
    elseif phaseTag == "B" then
        currentPhase = "backup"
    elseif phaseTag == "M" then
        if isAllPriorityDone() and countMainPending() == 0 then
            currentPhase = "main (cycle - all done)"
        else
            currentPhase = "main"
        end
    end
end

-- ==========================================
-- TRY PLACE + RETRY
-- ==========================================
local function tryPlaceOnce()
    local remote = getPlaceUnitRemote()
    if not remote then
        return false, nil, nil, "PlaceUnit remote belum ready"
    end
    local phaseTag, slotIdx, slotXYZ = selectSlot()
    updatePhaseLabel(phaseTag)

    -- Track priority attempts
    if phaseTag == "P" then
        priorityAttempts[slotIdx] = priorityAttempts[slotIdx] + 1
    end

    local args, rotDeg = buildArgs(slotXYZ)
    local ok, ret = pcall(function()
        return remote:InvokeServer(_unpack(args))
    end)
    local success = isSuccessReturn(ok, ret)
    local detail = string.format("[%s%d] rot=%s ret=%s",
        phaseTag, slotIdx, tostring(rotDeg), tostring(ret))
    return success, phaseTag, slotIdx, detail
end

local function bumpStats(phaseTag, success)
    if phaseTag == "P" then
        stats.placed_p = stats.placed_p + 1
        if success then stats.ok_p = stats.ok_p + 1 else stats.fail_p = stats.fail_p + 1 end
    elseif phaseTag == "M" then
        stats.placed_m = stats.placed_m + 1
        if success then stats.ok_m = stats.ok_m + 1 else stats.fail_m = stats.fail_m + 1 end
    elseif phaseTag == "B" then
        stats.placed_b = stats.placed_b + 1
        if success then stats.ok_b = stats.ok_b + 1 else stats.fail_b = stats.fail_b + 1 end
    end
end

local function markSatisfied(phaseTag, slotIdx)
    if phaseTag == "P" then
        prioritySatisfied[slotIdx] = true
    elseif phaseTag == "M" then
        mainSatisfied[slotIdx] = true
    end
    -- Backup tidak track satisfaction (cuma compensate failures)
end

local function placeWithRetry()
    local lastDetail   = "-"
    local lastPhaseTag = "?"
    local lastSlotIdx  = 0

    for attempt = 1, CONFIG.MAX_RETRY_PER_LOOP do
        local ok, phaseTag, slotIdx, detail = tryPlaceOnce()
        lastDetail   = detail or "-"
        lastPhaseTag = phaseTag or "?"
        lastSlotIdx  = slotIdx or 0
        if ok then
            markSatisfied(phaseTag, slotIdx)
            bumpStats(phaseTag, true)
            lastResult = string.format("OK try=%d %s", attempt, detail)
            if CONFIG.VERBOSE then print("[AutoPlaceV4] " .. lastResult) end
            return true
        end
        task.wait(0.05)
    end

    bumpStats(lastPhaseTag, false)
    lastResult = string.format("FAIL after %d tries: %s",
        CONFIG.MAX_RETRY_PER_LOOP, lastDetail)
    if CONFIG.VERBOSE then warn("[AutoPlaceV4] " .. lastResult) end
    return false
end

-- ==========================================
-- WAVE DETECTOR
-- ==========================================
task.spawn(function()
    while true do
        task.wait(1)
        if CONFIG.WAVE_CONTROL then
            pcall(function()
                local pGui = LocalPlayer:FindFirstChild("PlayerGui")
                if pGui then
                    local ggn     = pGui:FindFirstChild("GameGuiNoInset")
                    local screen  = ggn and ggn:FindFirstChild("Screen")
                    local top     = screen and screen:FindFirstChild("Top")
                    local info    = top and top:FindFirstChild("GameInfo")
                    local content = info and info:FindFirstChild("Content")
                    local waves   = content and content:FindFirstChild("Waves")
                    local title   = waves and waves:FindFirstChild("Title")

                    if title and title.Text and title.Text ~= "" then
                        local match = string.match(title.Text, "[Ww][Aa][Vv][Ee]%s*(%d+)")
                        if match then
                            local cur = tonumber(match)
                            if cur ~= lastWaveNum then
                                lastWaveNum = cur
                                if cur == CONFIG.START_WAVE and not isRunning then
                                    print("[AutoPlaceV4] Reach START_WAVE -> ON")
                                    setScriptState(true)
                                elseif cur == CONFIG.STOP_WAVE and isRunning then
                                    print("[AutoPlaceV4] Reach STOP_WAVE -> OFF")
                                    setScriptState(false)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- MAIN LOOP
-- ==========================================
refillMainBag()
if #SLOTS_BACKUP > 0 then refillBackupBag() end
refreshStats()

task.spawn(function()
    while true do
        local base = CONFIG.LOOP_DELAY
        local jit  = CONFIG.LOOP_DELAY_JITTER or 0
        local extra = 0
        if jit > 0 then extra = randFloat(-jit, jit) end
        local delay = base + extra
        if delay < 0.01 then delay = 0.01 end
        task.wait(delay)

        if isRunning then
            local ok, err = pcall(placeWithRetry)
            if not ok then
                warn("[AutoPlaceV4] Iterasi error: " .. tostring(err))
                lastResult = "ERROR: " .. tostring(err)
            end
            refreshStats()
        end
    end
end)

print(string.format(
    "[AutoPlaceV4] Loaded OK. Unit=%s | Priority=%d Main=%d Backup=%d | Rot=%s",
    CONFIG.TARGET_UNIT, #SLOTS_PRIORITY, #SLOTS_MAIN, #SLOTS_BACKUP, CONFIG.ROTATION_MODE
))
