task.spawn(function()
    -- Set Game Speed awal
    pcall(function() ReplicatedStorage.RemoteFunctions.ChangeTickSpeed:InvokeServer(Config.GameSpeed) end)

    -- MEMPERBAIKI BUG ZOMBIE PROCESS: Looping hanya jalan jika UI masih utuh (ScreenGui.Parent belum hancur/nil)
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(0.5) 
        
        -- Bypass Auto Skip (Cari tombol yang ada tulisannya "Off")
        if Config.AutoSkip then
            pcall(function()
                local autoSkipBtn = PlayerGui.GameGuiNoInset.Screen.Top.WaveControls:FindFirstChild("AutoSkip")
                local titleLabel = autoSkipBtn and autoSkipBtn:FindFirstChild("Title")
                
                if autoSkipBtn and titleLabel and string.find(titleLabel.Text, "Off") then
                    autoSkipAttempt = autoSkipAttempt + 1
                    if autoSkipAttempt > 3 then autoSkipAttempt = 1 end
                    
                    StatusLbl.Text = "Status: Enabling Auto Skip (Method " .. autoSkipAttempt .. ")"
                    virtualClick(autoSkipBtn, autoSkipAttempt)
                else
                    autoSkipAttempt = 0 -- Reset jika sudah "On" atau tidak ketemu
                end
            end)
        end

        -- Bypass Manual Skip (Jika muncul di layar)
        if Config.ManualSkip then
            pcall(function()
                local skipWaveFrame = PlayerGui.GameGuiNoInset.Screen.Top:FindFirstChild("SkipWave")
                if skipWaveFrame and skipWaveFrame.Visible then
                    local manualSkipBtn = skipWaveFrame:FindFirstChild("Button")
                    if manualSkipBtn then
                        manualSkipAttempt = manualSkipAttempt + 1
                        if manualSkipAttempt > 3 then manualSkipAttempt = 1 end
                        
                        StatusLbl.Text = "Status: Clicking Manual Skip (Method " .. manualSkipAttempt .. ")"
                        virtualClick(manualSkipBtn, manualSkipAttempt)
                        task.wait(0.5) -- Jeda agar tidak spam VIM bertubi-tubi
                    end
                else
                    manualSkipAttempt = 0
                end
            end)
        end
        
        if autoSkipAttempt == 0 and manualSkipAttempt == 0 then
            StatusLbl.Text = "Status: Watching for UI..."
        end
    end
end)
