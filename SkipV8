    AutoJalanBtn.Text = "Auto Jalan: " .. (autoJalanState.enabled and "ON" or "OFF")
    if not autoJalanState.enabled then
        autoJalanState.running = false  -- akan dihentikan di iterasi berikutnya
        setJalanStatus("Stopped by user.")
    end
end)

