-- ║                  AUTO JALAN WORKER                        ║
-- ╚══════════════════════════════════════════════════════════╝
-- Worker terpisah. Cek flag autoJalanState.enabled supaya bisa
-- toggle on/off via GUI tanpa kill seluruh script.
print("Jalan Bos")

task.spawn(function()
    -- Place ID guard (kalau diset > 0)
    if AutoJalanConfig.PlaceIdGuard and AutoJalanConfig.PlaceIdGuard ~= 0 then
        if game.PlaceId ~= AutoJalanConfig.PlaceIdGuard then
            setJalanStatus("PlaceId beda (" .. tostring(game.PlaceId) .. "), Auto Jalan dinonaktifkan.")
            return
        end
    end

    -- Tunggu game loaded
    repeat task.wait() until game:IsLoaded()
    repeat task.wait() until game:GetService("Players")
    repeat task.wait() until game:GetService("Players").LocalPlayer

    -- Startup delay (kasih waktu game/karakter loading)
    setJalanStatus("Tunggu " .. AutoJalanConfig.StartDelay .. "s sebelum mulai...")
    task.wait(AutoJalanConfig.StartDelay)

    print("auto walk")
    setJalanStatus("Siap. Menunggu toggle ON.")

    while isRunning and ScreenGui and ScreenGui.Parent do
        if autoJalanState.enabled and not autoJalanState.running then
            -- Mulai walk loop
            autoJalanState.running = true
            setJalanStatus("Start walking...")

            local lap = 0
            while autoJalanState.enabled and autoJalanState.running and isRunning do
                lap = lap + 1
                local total = #AutoJalanConfig.Waypoints
                for i, waypoint in ipairs(AutoJalanConfig.Waypoints) do
                    if not (autoJalanState.enabled and autoJalanState.running and isRunning) then break end
                    setJalanStatus(string.format("Lap %d: jalan ke waypoint %d/%d", lap, i, total))
                    walkToWaypointSafe(waypoint.Position)
                end

                if not AutoJalanConfig.Loop then
                    setJalanStatus("Selesai 1 putaran (Loop=false). Stop.")
                    autoJalanState.enabled = false
                    autoJalanState.running = false
                    AutoJalanBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                    AutoJalanBtn.Text = "Auto Jalan: OFF"
                    break
                end

                if not autoJalanState.enabled then break end
                setJalanStatus("Lap " .. lap .. " selesai. Lanjut lap berikutnya...")
                task.wait(0.5)
            end

            autoJalanState.running = false
            if not autoJalanState.enabled then
                setJalanStatus("Stopped.")
            end
        end
        task.wait(0.5)
    end
end)


