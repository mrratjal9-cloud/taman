    SwitchBorder.BorderSizePixel  = 0
    SwitchBorder.ZIndex           = 12
    Instance.new("UICorner", SwitchBorder).CornerRadius = UDim.new(1, 0)

    local Switch = Instance.new("Frame")
    Switch.Parent           = SwitchBorder
    Switch.Size             = UDim2.fromScale(0.85, 0.75)
    Switch.AnchorPoint      = Vector2.new(0.5, 0.5)
    Switch.Position         = UDim2.fromScale(0.5, 0.5)
    Switch.BackgroundColor3 = Color3.fromRGB(112, 112, 112)
    Switch.BorderSizePixel  = 0
    Switch.ZIndex           = 13
    Instance.new("UICorner", Switch).CornerRadius = UDim.new(1, 0)

    local SwitchGrad = Instance.new("UIGradient", Switch)
    SwitchGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(140, 140, 140)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(81, 81, 81))
    })
    SwitchGrad.Rotation = 90

    local Knob = Instance.new("Frame")
    Knob.Parent           = Switch
    Knob.Size             = UDim2.fromScale(0.4, 0.9)
    Knob.Position         = toggleState and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05)
    Knob.BackgroundColor3 = toggleState and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    Knob.BorderSizePixel  = 0
    Knob.ZIndex           = 14
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

    local Button = Instance.new("TextButton")
    Button.Parent                 = Switch
    Button.Size                   = UDim2.fromScale(1, 1)
    Button.BackgroundTransparency = 1
    Button.Text                   = ""
    Button.ZIndex                 = 15

    Button.MouseButton1Click:Connect(function()
        toggleState = not toggleState
        TweenService:Create(Knob, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
            Position         = toggleState and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05),
            BackgroundColor3 = toggleState and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        }):Play()
        config.Callback(toggleState)
    end)

    -- DRAG: hanya jalan kalau klik di Main DAN bukan di area Switch
    local dragging, dragStart, frameStart
    local function isInsideSwitch(pos)
        local sAbs  = SwitchBorder.AbsolutePosition
        local sSize = SwitchBorder.AbsoluteSize
        return pos.X >= sAbs.X and pos.X <= sAbs.X + sSize.X
           and pos.Y >= sAbs.Y and pos.Y <= sAbs.Y + sSize.Y
    end

    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if isInsideSwitch(input.Position) then return end
            dragging   = true
            dragStart  = input.Position
            frameStart = MainBorder.Position
        end
    end)
    Main.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainBorder.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)

    return function(v)
        toggleState = v
        Knob.Position         = v and UDim2.fromScale(0.55, 0.05) or UDim2.fromScale(0.05, 0.05)
        Knob.BackgroundColor3 = v and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        config.Callback(toggleState)
    end
end

