local function onNotifAdded(child)
    local lbl = child:WaitForChild("Label", 5)
    if lbl and lbl:IsA("TextLabel") then
        local function check()
            if state.ProcessedSeeds[child.Name] then return end
            local amtStr = string.match(lbl.Text, "You got ([%d,]+) Seeds!")
            if amtStr then
                local num = tonumber((string.gsub(amtStr, ",", "")))
                if num then
                    state.ProcessedSeeds[child.Name] = true
                    state.LastRoundSeed   = num                                  -- TABLE FIELD WRITE
                    state.TotalEarnedSeed = state.TotalEarnedSeed + num          -- TABLE FIELD WRITE
                end
            end
        end
        check()
        lbl:GetPropertyChangedSignal("Text"):Connect(check)
    end
end

getgenv().AkbarTrackerConn = NotifyClient.ChildAdded:Connect(onNotifAdded)
