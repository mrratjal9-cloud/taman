    -- 1. Baca Seed Now & Wave
    pcall(function()
        local title = PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.SeedsDisplay.Title
        local num = tonumber((string.gsub(title.Text, "[^%d]", "")))
        if num then state.SeedNow = num end
    end)
    pcall(function()
        local title = PlayerGui.GameGuiNoInset.Screen.Top.GameInfo.Content.Waves.Title
        if title and title.Text ~= "" then state.Wave = title.Text end
    end)

    -- 2. Baca timer in-game
    local timerText  = getInGameTimer()
    local currentSec = parseMMSS(timerText)

    -- 3. Deteksi GameEnd UI
    local isGameOver = false
    pcall(function()
        local endUI = PlayerGui.GameGui.Screen.Middle.GameEnd
        isGameOver = (endUI and endUI.Visible)
    end)

    local isLobby = (currentSec == nil or currentSec < 2)

    if isGameOver or isLobby then
        if state.IsMatchRunning then
            state.IsMatchRunning = false
            if state.HighestSecThisMatch > 10 then
                state.LastGameTime     = state.HighestSecThisMatch
                state.TotalGamesPlayed = state.TotalGamesPlayed + 1
            end
            state.LocalMatchSec       = 0
            state.HighestSecThisMatch = 0
        end
        cachedTimerLabel = nil
    else
        if not state.IsMatchRunning then
            if state.TotalGamesPlayed == 0 or (currentSec and currentSec < 15) then
                state.IsMatchRunning = true
            end
        end

        if state.IsMatchRunning and currentSec then
            if currentSec == 3599 and state.HighestSecThisMatch > 0 and state.HighestSecThisMatch < 3500 then
                -- Abaikan glitch 59:59
            else
                state.LocalMatchSec = currentSec
                if currentSec > state.HighestSecThisMatch then
                    state.HighestSecThisMatch = currentSec
                end
            end
        end
    end

    -- 4. Deteksi Flag Macro UI
    pcall(function()
        state.IsFlagged = false
        local boostHolder = PlayerGui:FindFirstChild("GameGui")
            and PlayerGui.GameGui.Screen:FindFirstChild("BottomLeft")
            and PlayerGui.GameGui.Screen.BottomLeft:FindFirstChild("BoostHolder")

        if boostHolder then
            local seedsMult   = boostHolder:FindFirstChild("SeedsMult")
            local gemsMult    = boostHolder:FindFirstChild("SpaceGemsMult")
            local ticketsMult = boostHolder:FindFirstChild("TicketsMult")

            if (seedsMult and seedsMult.Visible) or
               (gemsMult and gemsMult.Visible) or
               (ticketsMult and ticketsMult.Visible) then
                state.IsFlagged = true
            end
        end
    end)
end

