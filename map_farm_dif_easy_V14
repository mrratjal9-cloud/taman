    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
            return true
        end
    end
    return false
end
local function hasGivenUpPriority()
    if not CONFIG.PRIORITY_LOCK then return false end
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i] and priorityAttempts[i] >= CONFIG.PRIORITY_MAX_TRIES then
            return true
        end
    end
    return false
end

-- ==========================================
-- PLAYTIME TIMER READER (V14)
-- ==========================================
-- Path: PlayerGui.TopbarStandard.Holders.Right.Widget.IconButton.Menu
--        .IconSpot.Contents.IconLabelContainer.IconLabel
-- Text contoh: '⏱️ 1:59' atau '⏱️ 60:00' (kadang tanpa emoji)
-- Return: timerSec (number atau nil), rawText
local function readTimerOnce()
    local ok, sec, raw = pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        local tbs  = pGui  and pGui:FindFirstChild("TopbarStandard")
        local hold = tbs   and tbs:FindFirstChild("Holders")
        local rgt  = hold  and hold:FindFirstChild("Right")
        local wid  = rgt   and rgt:FindFirstChild("Widget")
        local ib   = wid   and wid:FindFirstChild("IconButton")
        local menu = ib    and ib:FindFirstChild("Menu")
        local spot = menu  and menu:FindFirstChild("IconSpot")
        local cnt  = spot  and spot:FindFirstChild("Contents")
        local cont = cnt   and cnt:FindFirstChild("IconLabelContainer")
        local lbl  = cont  and cont:FindFirstChild("IconLabel")
        if not lbl or not lbl.Text or lbl.Text == "" then
            return nil, nil
        end
        local t = lbl.Text
        -- ekstrak pola M:SS atau MM:SS dari teks (mis. '⏱️ 1:59')
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if not m or not s then
            return nil, t
        end
        local mm = tonumber(m) or 0
        local ss = tonumber(s) or 0
        return mm * 60 + ss, t
    end)
    if not ok then return nil, nil end
    return sec, raw
end

