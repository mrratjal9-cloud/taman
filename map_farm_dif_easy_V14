-- WAVE / TIMER OBSERVER
-- ==========================================
local function detectRestartFromWave(prev, cur)
    if not CONFIG.AUTO_RESET then return nil end
    if prev <= 0 then return nil end
    if CONFIG.DETECT_WAVE_DECREASE and cur < prev and prev >= 2 then
        return string.format("wave decrease %d -> %d", prev, cur)
    end
    return nil
end

local function tryUnlockPlacement(source, info)
    if placementUnlocked then return end
    placementUnlocked     = true
    placementsSinceUnlock = 0
    unlockSource = source .. (info and (" " .. info) or "")
    print(string.format("[AutoPlaceV14] PLACEMENT UNLOCKED via %s", unlockSource))
end

local function processTimerSnapshot(sec, raw)
    if raw then lastTimerRaw = raw end
    if not sec then return end

    -- restart detection: timer naik tinggi lagi (selisih >= TIMER_RESET_JUMP)
    if CONFIG.AUTO_RESET and CONFIG.DETECT_TIMER_RESET
       and lastTimerSec >= 0
       and sec >= lastTimerSec + (CONFIG.TIMER_RESET_JUMP or 60) then
        print(string.format("[AutoPlaceV14] timer reset %d -> %d, restart!",
            lastTimerSec, sec))
        pendingReset = true
    end

    lastTimerSec = sec

    -- unlock when timer high (game baru mulai)
    if CONFIG.UNLOCK_ON_TIMER and sec >= (CONFIG.TIMER_UNLOCK_THRESHOLD or 3590) then
        timerSeenHigh = true
        tryUnlockPlacement("TIMER", "(" .. fmtTimer(sec) .. ")")
    end

    if CONFIG.DEBUG_TIMER then
        print(string.format("[AutoPlaceV14][TIMER] sec=%d raw=%s", sec, tostring(raw)))
    end
end

local function processWaveSnapshot(num, rawText, kind)
    if rawText then lastWaveTextRaw = rawText end

    if kind == "COUNTDOWN" then
        lastCountdownSeen = num
        if CONFIG.UNLOCK_ON_COUNTDOWN then
            tryUnlockPlacement("COUNTDOWN", "(" .. tostring(num) .. ")")
        end
        return
    end

    if kind == "INCOMING" then
        if CONFIG.AUTO_RESET
           and CONFIG.DETECT_INCOMING_AFTER_STOP
           and maxWaveSeen >= CONFIG.STOP_WAVE then
            print("[AutoPlaceV14] 'Enemies incoming!' setelah max wave -> RESTART")
            pendingReset = true
            return
        end
        if not enemiesIncomingSeen then
            enemiesIncomingSeen = true
            print("[AutoPlaceV14] 'Enemies incoming!' detected -> game tracked")
        end
        if CONFIG.UNLOCK_ON_INCOMING then
            tryUnlockPlacement("INCOMING", nil)
        end
        return
    end

    if kind == "WAVE" and num then
        -- dianggap "in-game" kalau timer sudah tinggi atau enemiesIncomingSeen
        if not (enemiesIncomingSeen or timerSeenHigh) then
            return
        end
        if num ~= lastWaveNum then
            local prev = lastWaveNum
            lastWaveNum = num
            if num > maxWaveSeen then maxWaveSeen = num end

            local restartReason = detectRestartFromWave(prev, num)
            if restartReason then
                print("[AutoPlaceV14] === RESTART DETECTED === " .. restartReason)
                pendingReset = true
                maxWaveSeen = num
                return
            end

            if num == CONFIG.START_WAVE and not isRunning then
                print("[AutoPlaceV14] Reach START_WAVE -> ON")
                setScriptState(true)
            elseif num == CONFIG.STOP_WAVE and isRunning then
                print("[AutoPlaceV14] Reach STOP_WAVE -> OFF")
                setScriptState(false)
            end
        end
    end
end

