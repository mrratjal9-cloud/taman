    if CONFIG.WAVE_CONTROL and CONFIG.REQUIRE_PLACEMENT_GATE then
        setBanner("DETECT timer / countdown / incoming...",
            Color3.fromRGB(255, 200, 100))
        local startT = os.clock()
        while not placementUnlocked
              and (os.clock() - startT) < CONFIG.WAVE_BOOT_TIMEOUT do
            -- aktif baca semua signal di sini supaya unlock secepat mungkin
            local sec, traw = readTimerOnce()
            processTimerSnapshot(sec, traw)
            local num, raw, kind = readWaveOnce()
            processWaveSnapshot(num, raw, kind)
            refreshStats()
            task.wait(0.03)
        end
        if not placementUnlocked then
            warn(string.format(
                "[AutoPlaceV14] Tidak ada timer/countdown/incoming setelah %.1fs. " ..
                "Placement tetap LOCK sampai signal muncul.",
                CONFIG.WAVE_BOOT_TIMEOUT))
        else
            print("[AutoPlaceV14] Placement ready (unlocked via " .. unlockSource .. ")")
        end
    end

    while true do
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...", Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end
        pcall(refreshUICounts)

        if os.clock() < pausedUntil then
            task.wait(0.05)

        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)

        elseif capReached then
            currentPhase = "cap-reached"
            local cnt = CONFIG.CAP_COUNT_ONLY_TARGET and lastUITargetCount or lastUIAllUnits
            setBanner(string.format("CAP REACHED: %d/%d", cnt, CONFIG.PlacementUnitMaxCap),
                Color3.fromRGB(120, 220, 120))
            refreshStats()
            task.wait(1.0)

        else
            local canPlace, gateReason = canPlaceAnything(CONFIG.TARGET_UNIT)
            if not canPlace then
                currentPhase = "locked"
                setBanner("LOCKED: " .. gateReason, Color3.fromRGB(255, 100, 100))
                refreshStats()
                task.wait(0.10)

            elseif hasPendingPriority() then
                currentPhase = "priority (AWAL)"
                local target = nil
                for i = 1, #SLOTS_PRIORITY do
                    if not prioritySatisfied[i]
                       and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                        target = i
                        break
                    end
                end
                if target then
                    local burst = inBurstMode()
                    setBanner(string.format("PRIORITY %d/%d  (try %d)%s",
                        target, #SLOTS_PRIORITY, priorityAttempts[target] + 1,
                        burst and "  [BURST]" or ""),
                        burst and Color3.fromRGB(255, 240, 80)
                              or  Color3.fromRGB(255, 220, 100))
                    pcall(placePrioritySlot, target)
                    refreshStats()
                    local d = burst
                        and (CONFIG.FAST_PLACE_DELAY or 0)
                        or  (CONFIG.PRIORITY_DELAY or 0.1)
                    if d > 0 then task.wait(d) end
                end

            else
                local canMain, reason = canStartMainPhase()
                if not canMain then
                    currentPhase = "waiting-gate"
                    setBanner("WAIT: " .. reason, Color3.fromRGB(255, 200, 100))
                    refreshStats()
                    task.wait(0.15)
                else
                    local burst = inBurstMode()
                    if isBackupActive() then
                        currentPhase = "main+backup"
                        setBanner("MAIN + BACKUP" .. (burst and "  [BURST]" or ""),
                            Color3.fromRGB(120, 180, 240))
                    else
                        currentPhase = "main"
                        setBanner("MAIN PHASE" .. (burst and "  [BURST]" or ""),
                            Color3.fromRGB(120, 220, 120))
                    end
                    local ok, err = pcall(placeMainOrBackupOnce)
                    if not ok then
                        warn("[AutoPlaceV14] Main loop error: " .. tostring(err))
                        lastResult = "ERROR: " .. tostring(err)
                    end
                    refreshStats()
                    if burst then
                        local d = CONFIG.FAST_PLACE_DELAY or 0
                        if d > 0 then task.wait(d) end
                    else
                        local base  = CONFIG.LOOP_DELAY
                        local jit   = CONFIG.LOOP_JITTER or 0
                        local extra = (jit > 0) and randFloat(-jit, jit) or 0
                        task.wait(math.max(0.01, base + extra))
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.4)
        pcall(refreshStats)
    end
end)

