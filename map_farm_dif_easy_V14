-- Path: PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.CashDisplay.Title
local function parseCashText(t)
    if type(t) ~= "string" then return nil end
    local cleaned = string.gsub(t, "[%s,$]", "")
    -- support 1.5K / 2M
    local numStr, suf = string.match(cleaned, "^([%d%.]+)([KkMmBb]?)")
    if not numStr then return nil end
    local n = tonumber(numStr)
    if not n then return nil end
    if suf == "K" or suf == "k" then n = n * 1e3
    elseif suf == "M" or suf == "m" then n = n * 1e6
    elseif suf == "B" or suf == "b" then n = n * 1e9
    end
    return math.floor(n)
end

local function readCashOnce()
    local ok, n, raw = pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local gameGui = pGui    and pGui:FindFirstChild("GameGui")
        local screen  = gameGui and gameGui:FindFirstChild("Screen")
        local bottom  = screen  and screen:FindFirstChild("Bottom")
        local curr    = bottom  and bottom:FindFirstChild("CurrencyDisplay")
        local cash    = curr    and curr:FindFirstChild("CashDisplay")
        local title   = cash    and cash:FindFirstChild("Title")
        if not title or not title.Text then return nil, nil end
        return parseCashText(title.Text), title.Text
    end)
    if not ok then return nil, nil end
    return n, raw
end

local function getUnitPrice(unitName)
    if not CONFIG.UNIT_PRICES then return 0 end
    return CONFIG.UNIT_PRICES[unitName] or 0
end

local function canAfford(unitName)
    if not CONFIG.REQUIRE_CASH_GATE then return true, 0 end
    local price = getUnitPrice(unitName)
    if price <= 0 then return true, 0 end
    local need = price + (CONFIG.CASH_SAFETY_BUFFER or 0)
    if lastCash < 0 then
        -- belum ke-baca cash; jangan gate (biar gak deadlock)
        return true, need
    end
    return (lastCash >= need), need
end

-- ==========================================
-- WAVE READER (COUNTDOWN/INCOMING/WAVE)
-- ==========================================
local function readWaveOnce()
    local ok, num, raw, kind = pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local ggn     = pGui    and pGui:FindFirstChild("GameGuiNoInset")
        local screen  = ggn     and ggn:FindFirstChild("Screen")
        local top     = screen  and screen:FindFirstChild("Top")
        local info    = top     and top:FindFirstChild("GameInfo")
        local content = info    and info:FindFirstChild("Content")
        local waves   = content and content:FindFirstChild("Waves")
        local title   = waves   and waves:FindFirstChild("Title")
        if title and title.Text and title.Text ~= "" then
            local t   = title.Text
            local low = string.lower(t)

            if string.find(low, "enemies", 1, true)
               and string.find(low, "incoming", 1, true) then
                return nil, t, "INCOMING"
            end

            local waveNum = string.match(t, "[Ww][Aa][Vv][Ee]%s*(%d+)")
            if waveNum then
                return tonumber(waveNum), t, "WAVE"
            end

            local trimmed = trim(t)
            local cdNum = string.match(trimmed, "^(%d+)$")
            if cdNum then
                local n = tonumber(cdNum)
                if n
                   and n >= (CONFIG.COUNTDOWN_MIN or 1)
                   and n <= (CONFIG.COUNTDOWN_MAX or 10) then
                    return n, t, "COUNTDOWN"
                end
            end

            return nil, t, "OTHER"
        end
        return nil, nil, "EMPTY"
    end)
    if not ok then return nil, nil, "ERROR" end
    return num, raw, kind
end

-- UI READER (placement count)
local function readPlacedUnits()
    local ok, allUnits, target = pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local gameGui = pGui    and pGui:FindFirstChild("GameGui")
        local screen  = gameGui and gameGui:FindFirstChild("Screen")
        local middle  = screen  and screen:FindFirstChild("Middle")
        local unitMgr = middle  and middle:FindFirstChild("UnitManager")
        local items1  = unitMgr and unitMgr:FindFirstChild("Items")
        local frame   = items1  and items1:FindFirstChild("Frame")
        local items2  = frame   and frame:FindFirstChild("Items")
        local items3  = items2  and items2:FindFirstChild("Items")
        local scroll  = items3  and items3:FindFirstChild("ScrollingFrame")
        if not scroll then return 0, 0 end
        local au, tg = 0, 0
        for _, child in ipairs(scroll:GetChildren()) do
            if startsWith(child.Name, "unit_") then
                au = au + 1
                if child.Name == CONFIG.TARGET_UNIT then tg = tg + 1 end
            end
        end
        return au, tg
    end)
    if not ok then return 0, 0 end
    return allUnits or 0, target or 0
end

local function refreshUICounts()
    local au, tg = readPlacedUnits()
    lastUIAllUnits    = au
    lastUITargetCount = tg
    local cnt = CONFIG.CAP_COUNT_ONLY_TARGET and tg or au
    capReached = cnt >= CONFIG.PlacementUnitMaxCap
end

local function checkCapBeforePlacement()
    refreshUICounts()
    return capReached
end

