local lastRandomDif  = nil                    -- difficulty hasil random terakhir (utk avoid-repeat)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                  HELPERS: DIFFICULTY POOL                 ║
-- ╚══════════════════════════════════════════════════════════╝

-- cek apakah suatu nama valid sebagai difficulty
local function isValidDif(name)
    for _, v in ipairs(DIFFICULTIES) do
        if v == name then return true end
    end
    return false
end

-- bersihkan RANDOMNESS_POOL: ambil hanya yang valid + buang duplikat
local function getCleanPool()
    local seen, out = {}, {}
    for _, v in ipairs(RANDOMNESS_POOL) do
        if isValidDif(v) and not seen[v] then
            seen[v] = true
            table.insert(out, v)
        end
    end
    -- fallback: kalau pool kosong/invalid semua, pakai master list biar gak crash
    if #out == 0 then
        warn("[AutoReplayV5] RANDOMNESS_POOL kosong/invalid, fallback ke semua difficulty")
        for _, v in ipairs(DIFFICULTIES) do
            table.insert(out, v)
        end
    end
    return out
end

-- pilih difficulty random dari pool, hormati RANDOMNESS_AVOID_REPEAT
local function pickRandomDif()
    local pool = getCleanPool()
    if #pool == 1 then return pool[1] end

    if RANDOMNESS_AVOID_REPEAT and lastRandomDif then
        -- buang lastRandomDif dari kandidat
        local candidates = {}
        for _, v in ipairs(pool) do
            if v ~= lastRandomDif then table.insert(candidates, v) end
        end
        if #candidates > 0 then
            return candidates[math.random(1, #candidates)]
        end
    end
    return pool[math.random(1, #pool)]
end

-- tombol "Difficulty: xxx" di GUI cycle ke nama berikut
local function nextDif(cur)
    for i, v in ipairs(DIFFICULTIES) do
        if v == cur then return DIFFICULTIES[(i % #DIFFICULTIES) + 1] end
    end
    return DIFFICULTIES[1]
end

-- tentukan difficulty utk gameplay BERIKUTNYA (dipanggil sebelum vote)
--   - kalau mode random aktif & gameplayCount+1 kelipatan INTERVAL -> random dari pool
--   - selain itu                                                   -> TARGET_DIF
local function decideNextDif()
    if RANDOMNESS_ENABLED
       and RANDOMNESS_INTERVAL > 0
       and ((gameplayCount + 1) % RANDOMNESS_INTERVAL == 0) then
        return pickRandomDif(), true
    end
    return TARGET_DIF, false
end


