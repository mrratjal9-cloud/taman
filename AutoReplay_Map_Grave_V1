    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local gameEnd = safeFindChild(middle, "GameEnd")
    local items1  = safeFindChild(gameEnd, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local actions = safeFindChild(frame, "Actions")
    local items2  = safeFindChild(actions, "Items")
    local again   = safeFindChild(items2, "Again")
    return again, gameEnd
end

local function getDifficultyButtonByName(difName)
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local gameGui = safeFindChild(pGui, "GameGui")
    local screen  = safeFindChild(gameGui, "Screen")
    local middle  = safeFindChild(screen, "Middle")
    local difVote = safeFindChild(middle, "DifficultyVote")
    local items1  = safeFindChild(difVote, "Items")
    local frame   = safeFindChild(items1, "Frame")
    local items2  = safeFindChild(frame, "Items")
    local items3  = safeFindChild(items2, "Items")
    local btn     = safeFindChild(items3, difName)
    return btn, difVote
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║                MAIN LOOP (PRIORITAS GameEnd)              ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    setStatus(isRunning and "Running..." or "Paused")
    refreshPoolUI()
    while true do
        task.wait(LOOP_INTERVAL)

        local ok, err = pcall(function()
            if not isRunning then return end
            local now = os.clock()

            -- ========================================
            -- PRIORITAS 1: GameEnd / Play Again
            -- ========================================
            local againBtn, gameEnd = getAgainButton()
            if gameEnd and gameEnd.Visible == true then
                if (now - lastAgainAt) < COOLDOWN_AGAIN then return end

                if not againBtn then
                    setStatus("GameEnd visible tapi tombol Again belum ready...")
                    return
                end

                clickAttempt = clickAttempt + 1
                if clickAttempt > 3 then clickAttempt = 1 end

                setStatus(string.format("Klik Play Again (method %d)...", clickAttempt))
                print("[AutoReplayV5] Klik Play Again, attempt =", clickAttempt)

                virtualClick(againBtn, clickAttempt)
                lastAgainAt = os.clock()

                task.wait(CLICK_VERIFY_T)
                local _, geAfter = getAgainButton()
                if (not geAfter) or (geAfter.Visible == false) then
                    setStatus("Play Again berhasil di-klik!")
                    clickAttempt = 0
                else
                    setStatus(string.format("Klik gagal (method %d), retry method berikutnya...", clickAttempt))
                end
                return
            end

            -- ========================================
            -- PRIORITAS 2: DifficultyVote
            -- ========================================
            local _, difVote = getDifficultyButtonByName(TARGET_DIF)
            if difVote and difVote.Visible == true then
                if (now - lastVoteAt) < COOLDOWN_VOTE then return end

                local chosenDif, isRandom = decideNextDif()
                local difBtn = getDifficultyButtonByName(chosenDif)

                -- fallback kalau button difficulty random belum muncul
                if not difBtn and chosenDif ~= TARGET_DIF then
                    warn("[AutoReplayV5] Button " .. chosenDif .. " tidak ditemukan, fallback ke " .. TARGET_DIF)
                    chosenDif = TARGET_DIF
                    isRandom  = false
                    difBtn    = getDifficultyButtonByName(chosenDif)
                end

                if isRandom then
                    setStatus("[RANDOM #" .. (gameplayCount + 1) .. "] Vote " .. chosenDif .. " + RestartGame...")
                    print("[AutoReplayV5] RANDOM mode -> dif =", chosenDif)
                    lastRandomDif = chosenDif
                else
                    setStatus("Vote " .. chosenDif .. " + RestartGame...")
                    print("[AutoReplayV5] Vote difficulty:", chosenDif)
                end

                if difBtn then
                    virtualClick(difBtn, 1)
                    task.wait(0.25)
                end

                invokeRemote("PlaceDifficultyVote", chosenDif)
                task.wait(0.4)
                local restartOk = invokeRemote("RestartGame")

                lastVoteAt = os.clock()

                if restartOk then
                    gameplayCount = gameplayCount + 1
                    lastVotedDif  = chosenDif
                    refreshCounterUI()
                end

                setStatus("RestartGame fired (" .. chosenDif .. "). Tunggu game restart...")
                task.wait(1)
                return
            end

            -- IDLE
            setStatus("Running... (menunggu GameEnd / DifficultyVote)")
        end)

        if not ok then
            warn("[AutoReplayV5] Iterasi error: " .. tostring(err))
            setStatus("Error: " .. tostring(err))
        end
    end
end)

print(string.format(
    "[AutoReplayV5] Loaded. TARGET_DIF=%s | Status=%s | Random=%s every %d | Pool=[%s]",
    TARGET_DIF,
    isRunning and "ON" or "OFF",
    RANDOMNESS_ENABLED and "ON" or "OFF",
    RANDOMNESS_INTERVAL,
    table.concat(getCleanPool(), ", ")
))
