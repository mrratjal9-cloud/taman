-- ==========================================
-- AUTO REPLAY V5 (V4 + Randomness Pool & Config Docs)
-- Perubahan dari V4:
--   1) Tambah RANDOMNESS_POOL  -> kamu yang nentuin difficulty
--      apa saja yang boleh di-random. Contoh kalau cuma mau
--      antara hard / insane:
--          RANDOMNESS_POOL = { "dif_hard", "dif_insane" }
--   2) Semua config diberi komentar di sebelah kanan
--      dan dikelompokkan biar gampang dibaca.
--
--   Logika V3+V4 (state machine GameEnd > DifficultyVote,
--   virtualClick 3-method, click verification, counter
--   gameplay, GUI) tetap sama.
-- ==========================================


-- ╔══════════════════════════════════════════════════════════╗
-- ║                       CONFIGURATION                       ║
-- ╚══════════════════════════════════════════════════════════╝

-- ── [1] BEHAVIOR / GENERAL ─────────────────────────────────
-- Pengaturan dasar: script langsung jalan? difficulty default apa?
local AUTO_START          = true              -- true = script langsung "ON" begitu di-load. false = harus toggle manual lewat GUI.
local TARGET_DIF          = "dif_impossible"        -- Difficulty default yang di-vote saat NORMAL (bukan ronde random). Pilihan: dif_easy / dif_normal / dif_hard / dif_insane / dif_impossible / dif_apocalypse.

-- ── [2] LOOP TIMING ────────────────────────────────────────
-- Kontrol seberapa cepat script ngecek state game & cooldown antar aksi.
local LOOP_INTERVAL       = 0.4               -- detik. Jeda antar iterasi loop utama. Kecil = lebih responsif tapi lebih berat.
local COOLDOWN_AGAIN      = 1.5               -- detik. Jeda minimum antar percobaan klik tombol "Play Again". Kecil supaya retry method cepat.
local COOLDOWN_VOTE       = 4                 -- detik. Jeda minimum antar fire vote+RestartGame. Cegah double-fire saat UI kedip.
local CLICK_VERIFY_T      = 0.8               -- detik. Setelah klik Play Again, script tunggu segini lalu cek apakah GameEnd benar-benar hilang.

-- ── [3] RANDOMNESS MODE ────────────────────────────────────
-- Fitur "tiap N kali main, difficulty di-random". Detail:
--   - Saat gameplay ke-N (sesuai INTERVAL), difficulty dipilih
--     ACAK dari RANDOMNESS_POOL (bukan urut).
--   - Gameplay lain pakai TARGET_DIF normal.
local RANDOMNESS_ENABLED  = true              -- true = aktifkan fitur random. false = ronde normal terus, TARGET_DIF dipakai semua.
local RANDOMNESS_INTERVAL = 5                 -- jumlah gameplay. Misal 5 = tiap kelipatan 5 (game ke-5, 10, 15, ...) difficulty di-random. Isi 1 = setiap game random.
local RANDOMNESS_POOL     = {                 -- List difficulty yang BOLEH dipakai saat ronde random. Edit sesuai selera.
    "dif_easy",                               --   easy        | mode termudah
    "dif_normal",                             --   normal      | mode standar
    "dif_hard",                               --   hard        | mode susah
    "dif_insane",                             --   insane      | mode sangat susah
    --"dif_impossible",                         --   impossible  | mode super susah
    --"dif_apocalypse",                         --   apocalypse  | mode tersusah
}                                             -- Contoh kalau cuma mau random antara hard/insane: { "dif_hard", "dif_insane" }
local RANDOMNESS_AVOID_REPEAT = false         -- true = hindari hasil random sama dengan ronde random sebelumnya (kalau pool >= 2). false = boleh sama berulang.

-- ── [4] DIFFICULTY MASTER LIST (jangan diubah kecuali game update) ──
-- Daftar semua difficulty yang dikenali script. Dipakai utk validasi
-- pool, tombol cycle di GUI, dan deteksi tombol di game UI.
local DIFFICULTIES = {                        -- urutan = urutan tombol cycle "Difficulty: ..." di GUI
    "dif_easy",                               --   easy
    "dif_normal",                             --   normal
    "dif_hard",                               --   hard
    "dif_insane",                             --   insane
    "dif_impossible",                         --   impossible
    "dif_apocalypse",                         --   apocalypse
}


