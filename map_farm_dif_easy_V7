                local screen  = ggn     and ggn:FindFirstChild("Screen")
                local top     = screen  and screen:FindFirstChild("Top")
                local info    = top     and top:FindFirstChild("GameInfo")
                local content = info    and info:FindFirstChild("Content")
                local waves   = content and content:FindFirstChild("Waves")
                local title   = waves   and waves:FindFirstChild("Title")

                if title and title.Text and title.Text ~= "" then
                    local match = string.match(title.Text, "[Ww][Aa][Vv][Ee]%s*(%d+)")
                    if match then
                        local cur = tonumber(match)
                        if cur ~= lastWaveNum then
                            local prev = lastWaveNum
                            lastWaveNum = cur
                            if cur > maxWaveSeen then maxWaveSeen = cur end

                            local restartReason = detectRestart(prev, cur)
                            if restartReason then
                                print("[AutoPlaceV7] === GAME RESTART DETECTED === " .. restartReason)
                                pendingReset = true
                                maxWaveSeen = cur
                            end

                            if cur == CONFIG.START_WAVE and not isRunning then
                                print("[AutoPlaceV7] Reach START_WAVE -> ON")
                                setScriptState(true)
                            elseif cur == CONFIG.STOP_WAVE and isRunning then
                                print("[AutoPlaceV7] Reach STOP_WAVE -> OFF")
                                setScriptState(false)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- MAIN ORCHESTRATOR
-- Urutan prioritas:
--   1. pendingReset   -> performReset
--   2. pausedUntil    -> wait
--   3. !isRunning     -> idle
--   4. priority pending -> PRIORITY phase
--   5. !canStartMain  -> WAIT (wave gate)
--   6. else           -> MAIN/BACKUP phase
-- ==========================================
refreshStats()

task.spawn(function()
    setBanner("BOOT DELAY... " .. CONFIG.BOOT_DELAY .. "s",
        Color3.fromRGB(255, 165, 0))
    print(string.format("[AutoPlaceV7] BOOT_DELAY: tunggu %.1fs...", CONFIG.BOOT_DELAY))
    task.wait(CONFIG.BOOT_DELAY)

    while true do
        -- 1. Reset?
        if pendingReset then
            performReset("auto/manual")
            setBanner("RESET cooldown...", Color3.fromRGB(255, 165, 0))
            refreshStats()
            task.wait(CONFIG.RESET_COOLDOWN)
        end

        -- 2. Pause cooldown
        if os.clock() < pausedUntil then
            task.wait(0.1)

        -- 3. Paused
        elseif not isRunning then
            currentPhase = "paused"
            setBanner("PAUSED (Status: OFF)", Color3.fromRGB(180, 180, 180))
            task.wait(0.3)

        -- 4. PRIORITY PHASE
        elseif hasPendingPriority() then
            currentPhase = "priority (AWAL)"
            local target = nil
            for i = 1, #SLOTS_PRIORITY do
                if not prioritySatisfied[i]
                   and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                    target = i
                    break
                end
            end
            if target then
                setBanner(string.format("PRIORITY %d/%d  (try %d)",
                    target, #SLOTS_PRIORITY, priorityAttempts[target] + 1),
                    Color3.fromRGB(255, 220, 100))
                pcall(placePrioritySlot, target)
                refreshStats()
                task.wait(CONFIG.PRIORITY_DELAY)
            end

        -- 5./6. WAVE GATE / MAIN
        else
            local canMain, reason = canStartMainPhase()
            if not canMain then
                currentPhase = "waiting-wave-gate"
                setBanner("WAIT: " .. reason, Color3.fromRGB(255, 200, 100))
                refreshStats()
                task.wait(0.5)
            else
                if isBackupActive() then
                    currentPhase = "main+backup"
                    setBanner("MAIN + BACKUP (compensating fails)",
                        Color3.fromRGB(120, 180, 240))
                elseif countMainPending() == 0 then
                    currentPhase = "main (cycle - all done)"
                    setBanner("MAIN cycle (semua slot done)",
                        Color3.fromRGB(120, 220, 120))
                else
                    currentPhase = "main"
                    setBanner("MAIN PHASE - placing...",
                        Color3.fromRGB(120, 220, 120))
                end

                local ok, err = pcall(placeMainOrBackupOnce)
                if not ok then
                    warn("[AutoPlaceV7] Main loop error: " .. tostring(err))
                    lastResult = "ERROR: " .. tostring(err)
                end
                refreshStats()

                local base  = CONFIG.LOOP_DELAY
                local jit   = CONFIG.LOOP_DELAY_JITTER or 0
                local extra = (jit > 0) and randFloat(-jit, jit) or 0
                task.wait(math.max(0.01, base + extra))
            end
        end
    end
end)

