-- ║   AUTO-APPLY GameSpeed di awal eksekusi (sesuai Config)   ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    local startedAt = os.clock()
    while isRunning and (os.clock() - startedAt) < SPEED_APPLY_TIMEOUT do
        if applyGameSpeed(SpeedConfig.GameSpeed) then
            setSkipStatus("Initial Speed -> " .. SpeedConfig.GameSpeed .. "x ter-apply.")
            return
        end
        task.wait(1)
    end
    setSkipStatus("Initial speed timeout. Akan retry saat round mulai.")
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║                MAIN LOOP - SKIP                           ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(LOOP_INTERVAL_SKIP)
        if not isRunning then break end

        local ok, err = pcall(function()
            local now = os.clock()
            local statusParts = {}
            local wc = getWaveControls()

            -- Re-apply speed saat round baru
            if wc and wc ~= lastSeenWaveControls then
                if lastSeenWaveControls ~= nil then
                    dprint("Round baru, re-apply speed.")
                    task.spawn(function()
                        task.wait(0.5)
                        applyGameSpeed(SpeedConfig.GameSpeed)
                    end)
                    table.insert(statusParts, "Re-apply " .. SpeedConfig.GameSpeed .. "x")
                end
                lastSeenWaveControls = wc
            end

            if not wc then
                setSkipStatus("Standby (bukan di gameplay).")
                return
            end

            -- AUTO SKIP
            if Config.AutoSkip and (now - lastAutoSkipClickAt) >= AUTOSKIP_COOLDOWN then
                local btn = getAutoSkipButton()
                local titleLabel = btn and btn:FindFirstChild("Title")
                local titleText = (titleLabel and titleLabel:IsA("TextLabel")) and titleLabel.Text or ""
                if btn and string.find(string.lower(titleText), "off") then
                    if safeClick(btn) then
                        lastAutoSkipClickAt = os.clock()
                        table.insert(statusParts, "AutoSkip clicked")
                    end
                end
            end

            -- MANUAL SKIP
            if Config.ManualSkip and (now - lastManualClickAt) >= MANUAL_COOLDOWN then
                local frame = getSkipWaveFrame()
                if frame and frame.Visible then
                    local mbtn = frame:FindFirstChild("Button")
                    if mbtn then
                        if safeClick(mbtn) then
                            table.insert(statusParts, "SkipWave clicked")
                            lastManualClickAt = os.clock()
                        end
                    end
                end
            end

            if #statusParts == 0 then
                setSkipStatus("Watching... AS=" .. tostring(Config.AutoSkip)
                    .. " MS=" .. tostring(Config.ManualSkip)
                    .. " Speed=" .. SpeedConfig.GameSpeed .. "x")
            else
                setSkipStatus(table.concat(statusParts, " | "))
            end
        end)

        if not ok then
            dprint("Iterasi Skip error:", err)
        end
    end
end)


-- ╔══════════════════════════════════════════════════════════╗
-- ║              MAIN LOOP - AUTO REPLAY                      ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    setReplayStatus(replayRunning and "Running..." or "Paused")
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(ReplayConfig.LoopInterval)

        local ok, err = pcall(function()
            if not replayRunning then return end
            local now = os.clock()

            -- ========================================
            -- PRIORITAS 1: GameEnd / Play Again
            -- ========================================
            local againBtn, gameEnd = getAgainButton()
            if gameEnd and gameEnd.Visible == true then
                if (now - lastAgainAt) < ReplayConfig.CooldownAgain then return end
                if not againBtn then
                    setReplayStatus("GameEnd visible tapi tombol Again belum ready...")
                    return
                end

                clickAttempt = clickAttempt + 1
                if clickAttempt > 3 then clickAttempt = 1 end

                setReplayStatus(string.format("Klik Play Again (method %d)...", clickAttempt))
                dprint("Klik Play Again, attempt =", clickAttempt)

                virtualClick(againBtn, clickAttempt)
                lastAgainAt = os.clock()

                task.wait(ReplayConfig.ClickVerifyT)
                local _, geAfter = getAgainButton()
                if (not geAfter) or (geAfter.Visible == false) then
                    setReplayStatus("Play Again berhasil di-klik!")
                    clickAttempt = 0
                else
                    setReplayStatus(string.format("Klik gagal (method %d), retry method berikutnya...", clickAttempt))
                end
                return
            end

            -- ========================================
            -- PRIORITAS 2: DifficultyVote
            -- ========================================
            local _, difVote = getDifficultyButtonByName(ReplayConfig.TargetDif)
            if difVote and difVote.Visible == true then
                if (now - lastVoteAt) < ReplayConfig.CooldownVote then return end

                local chosenDif, isRandom = decideNextDif()
                local difBtn = getDifficultyButtonByName(chosenDif)

                -- Fallback kalau button difficulty random belum muncul
                if not difBtn and chosenDif ~= ReplayConfig.TargetDif then
                    dprint("Button " .. chosenDif .. " tidak ditemukan, fallback ke " .. ReplayConfig.TargetDif)
                    chosenDif = ReplayConfig.TargetDif
                    isRandom  = false
                    difBtn    = getDifficultyButtonByName(chosenDif)
                end

                if isRandom then
                    setReplayStatus("[RANDOM #" .. (gameplayCount + 1) .. "] Vote " .. chosenDif .. " + RestartGame...")
                    lastRandomDif = chosenDif
                else
                    setReplayStatus("Vote " .. chosenDif .. " + RestartGame...")
                end

                if difBtn then
                    virtualClick(difBtn, 1)
                    task.wait(0.25)
                end

                invokeRemote("PlaceDifficultyVote", chosenDif)
                task.wait(0.4)
                local restartOk = invokeRemote("RestartGame")

                lastVoteAt = os.clock()

                if restartOk then
                    gameplayCount = gameplayCount + 1
                    lastVotedDif  = chosenDif
                    refreshCounterUI()
                end

                setReplayStatus("RestartGame fired (" .. chosenDif .. "). Tunggu game restart...")
                task.wait(1)
                return
            end

            -- IDLE
            setReplayStatus("Running... (menunggu GameEnd / DifficultyVote)")
        end)

        if not ok then
            dprint("Iterasi Replay error:", err)
            setReplayStatus("Error: " .. tostring(err))
        end
    end
end)


