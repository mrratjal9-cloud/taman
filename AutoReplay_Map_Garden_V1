-- ║                  AUTO JALAN HELPERS                       ║
-- ╚══════════════════════════════════════════════════════════╝
local function getCharacterParts()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart", 10)
    local hum  = char:FindFirstChildOfClass("Humanoid")  or char:WaitForChild("Humanoid", 10)
    return char, hrp, hum
end

local function walkToWaypointSafe(targetPos)
    local char, hrp, hum = getCharacterParts()
    if not (hrp and hum) then return false end
    hum:MoveTo(targetPos)
    local startTime = os.clock()
    while autoJalanState.running and isRunning do
        if not (hrp.Parent and hum.Parent) then return false end
        local dist = (hrp.Position - targetPos).Magnitude
        if dist <= AutoJalanConfig.ArriveDist then return true end
        if (os.clock() - startTime) > AutoJalanConfig.MoveTimeout then
            dprint("Walk timeout di", targetPos)
            return false
        end
        task.wait(0.2)
    end
    return false
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║              REPLAY: DIFFICULTY POOL HELPERS              ║
-- ╚══════════════════════════════════════════════════════════╝
local function isValidDif(name)
    for _, v in ipairs(DIFFICULTIES) do
        if v == name then return true end
    end
    return false
end

local function getCleanPool()
    local seen, out = {}, {}
    for _, v in ipairs(ReplayConfig.RandomnessPool) do
        if isValidDif(v) and not seen[v] then
            seen[v] = true
            table.insert(out, v)
        end
    end
    if #out == 0 then
        dprint("RandomnessPool kosong/invalid, fallback ke semua difficulty")
        for _, v in ipairs(DIFFICULTIES) do
            table.insert(out, v)
        end
    end
    return out
end

local function pickRandomDif()
    local pool = getCleanPool()
    if #pool == 1 then return pool[1] end
    if ReplayConfig.RandomnessAvoidRepeat and lastRandomDif then
        local candidates = {}
        for _, v in ipairs(pool) do
            if v ~= lastRandomDif then table.insert(candidates, v) end
        end
        if #candidates > 0 then
            return candidates[math.random(1, #candidates)]
        end
    end
    return pool[math.random(1, #pool)]
end

local function nextDif(cur)
    for i, v in ipairs(DIFFICULTIES) do
        if v == cur then return DIFFICULTIES[(i % #DIFFICULTIES) + 1] end
    end
    return DIFFICULTIES[1]
end

local function decideNextDif()
    if ReplayConfig.RandomnessEnabled
       and ReplayConfig.RandomnessInterval > 0
       and ((gameplayCount + 1) % ReplayConfig.RandomnessInterval == 0) then
        return pickRandomDif(), true
    end
    return ReplayConfig.TargetDif, false
end


