local function refreshCounterUI()
    CounterLbl.Text = "Gameplay: " .. gameplayCount .. " | Last: " .. lastVotedDif
    if ReplayConfig.RandomnessEnabled and ReplayConfig.RandomnessInterval > 0 then
        local nextNum = gameplayCount + 1
        local untilRand = (ReplayConfig.RandomnessInterval - (gameplayCount % ReplayConfig.RandomnessInterval))
        if untilRand == ReplayConfig.RandomnessInterval then untilRand = ReplayConfig.RandomnessInterval end
        local isRandNext = (nextNum % ReplayConfig.RandomnessInterval == 0)
        if isRandNext then
            NextLbl.Text = "Next (#" .. nextNum .. "): RANDOM (from pool)"
            NextLbl.TextColor3 = Color3.fromRGB(255, 200, 120)
        else
            NextLbl.Text = "Next (#" .. nextNum .. "): " .. ReplayConfig.TargetDif .. " | random in " .. untilRand
            NextLbl.TextColor3 = Color3.fromRGB(180, 220, 180)
        end
    else
        NextLbl.Text = "Next: " .. ReplayConfig.TargetDif .. " (random OFF)"
        NextLbl.TextColor3 = Color3.fromRGB(180, 220, 180)
    end
end
