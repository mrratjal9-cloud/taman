                        Color3.fromRGB(255, 220, 100))
                    pcall(placePrioritySlot, i)
                    refreshStats()
                end
                task.wait(CONFIG.PRIORITY_DELAY)
            end
            if prioritySatisfied[i] then
                print(string.format("[AutoPlaceV5] [PRIORITY DONE] P%d sukses setelah %d try",
                    i, priorityAttempts[i]))
            end
        end

        print("[AutoPlaceV5] === PRIORITY PHASE SELESAI ===")
        print(string.format("[AutoPlaceV5] Hasil: %d/%d priority sukses",
            countPriorityDone(), #SLOTS_PRIORITY))
    end

    -- ===== PHASE 2+: MAIN / BACKUP =====
    setBanner("MAIN PHASE - cycling slots...",
        Color3.fromRGB(120, 220, 120))
    currentPhase = "main"
    print("[AutoPlaceV5] === MULAI PHASE MAIN ===")

    while true do
        local base = CONFIG.LOOP_DELAY
        local jit  = CONFIG.LOOP_DELAY_JITTER or 0
        local extra = (jit > 0) and randFloat(-jit, jit) or 0
        local delay = math.max(0.01, base + extra)
        task.wait(delay)

        if isRunning then
            if hasPendingPriority() then
                setBanner("PRIORITY (re-check)...",
                    Color3.fromRGB(255, 220, 100))
                for i = 1, #SLOTS_PRIORITY do
                    if not prioritySatisfied[i]
                       and priorityAttempts[i] < CONFIG.PRIORITY_MAX_TRIES then
                        pcall(placePrioritySlot, i)
                        task.wait(CONFIG.PRIORITY_DELAY)
                    end
                end
                setBanner("MAIN PHASE - cycling slots...",
                    Color3.fromRGB(120, 220, 120))
            else
                local ok, err = pcall(placeMainOrBackupOnce)
                if not ok then
                    warn("[AutoPlaceV5] Main loop error: " .. tostring(err))
                    lastResult = "ERROR: " .. tostring(err)
                end
                if isBackupActive() then
                    currentPhase = "main+backup"
                elseif countMainPending() == 0 then
                    currentPhase = "main (cycle - all done)"
                else
                    currentPhase = "main"
                end
            end
            refreshStats()
        end
    end
end)

