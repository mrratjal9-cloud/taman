local function addLog(msg, color)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -4, 0, 13)
    lbl.BackgroundTransparency = 1
    lbl.Text = os.date("%H:%M:%S") .. " " .. msg
    lbl.TextColor3 = color or Color3.fromRGB(180, 180, 180)
    lbl.Font = Enum.Font.Code
    lbl.TextSize = 10
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 3
    lbl.Parent = LogScroll
    table.insert(logLines, lbl)
    if #logLines > MAX_LOG then
        logLines[1]:Destroy()
        table.remove(logLines, 1)
    end
    task.defer(function()
        LogScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

local function applyWaveControlVisual()
    if CONFIG.WaveControl then
        WaveControlToggle.Text       = "Wave Auto: [ON]  " .. CONFIG.StartWave .. " -> " .. CONFIG.StopWave
        WaveControlToggle.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        WaveControlToggle.Text       = "Wave Auto: [OFF]"
        WaveControlToggle.TextColor3 = Color3.fromRGB(200, 100, 100)
    end
end
applyWaveControlVisual()

