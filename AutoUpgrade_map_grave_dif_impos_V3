local function getWaveText()
    local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
    local ggn     = pGui    and pGui:FindFirstChild("GameGuiNoInset")
    local screen  = ggn     and ggn:FindFirstChild("Screen")
    local top     = screen  and screen:FindFirstChild("Top")
    local info    = top     and top:FindFirstChild("GameInfo")
    local content = info    and info:FindFirstChild("Content")
    local waves   = content and content:FindFirstChild("Waves")
    local title   = waves   and waves:FindFirstChild("Title")
    return title and title.Text or nil
end

task.spawn(function()
    while task.wait(1) do
        if not ScreenGui.Parent then break end
        local curWaveText = getWaveText()
        if curWaveText and curWaveText ~= "" then
            WaveTextDisplay.Text = "Wave: " .. curWaveText
            local extractedNumStr = string.match(curWaveText, "Wave%s*(%d+)")
            if extractedNumStr then
                local currentWaveNum = tonumber(extractedNumStr)
                if currentWaveNum ~= lastWaveNum then
                    lastWaveNum = currentWaveNum
                    if CONFIG.WaveControl then
                        if currentWaveNum >= CONFIG.StartWave and currentWaveNum < CONFIG.StopWave
                           and not isRunning and not hasAutoStarted then
                            hasAutoStarted = true
                            addLog("Wave " .. currentWaveNum .. " >= StartWave " .. CONFIG.StartWave
                                   .. " : Auto-Start ON", Color3.fromRGB(100, 255, 100))
                            toggleScript()
                        elseif currentWaveNum >= CONFIG.StopWave and isRunning and not hasAutoStopped then
                            hasAutoStopped = true
                            addLog("Wave " .. currentWaveNum .. " >= StopWave " .. CONFIG.StopWave
                                   .. " : Auto-Stop ON", Color3.fromRGB(255, 100, 100))
                            toggleScript()
                        end
                    end
                end
            end
        end
    end
end)


-- ================================================================
-- KATEGORI 11 : CORE LOGIC (TARGET & MAX-LEVEL CHECKER)
-- ================================================================
local UpgradeRemote = ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("UpgradeUnit")

runUpgrader = function()
    addLog("Sistem Upgrade #" .. instanceEntry.slot .. " dimulai!", Color3.fromRGB(100, 255, 100))

    while isRunning do
        local mapFolder      = workspace:FindFirstChild("Map")
        local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
        local sfUI           = getUnitScrollingFrame()

        if not entitiesFolder or not sfUI then
            task.wait(CONFIG.UpgradeInterval)
            continue
        end

        local totalMaxFiltered = 0
        local totalNeedUpgrade = 0

        for _, targetName in ipairs(CONFIG.TargetUnits) do
            if not isRunning then break end

            local wsUnits = {}
            for _, unit in pairs(entitiesFolder:GetChildren()) do
                if unit.Name == targetName then
                    local id = unit:GetAttribute("ID")
                    if id then table.insert(wsUnits, id) end
                end
            end

            local uiFrames = {}
            for _, child in ipairs(sfUI:GetChildren()) do
                if child.Name == targetName then
                    table.insert(uiFrames, child)
                end
            end

            local toUpgradeIDs = {}
            for i = 1, #wsUnits do
                local isMax = false
                if uiFrames[i] then isMax = isUIMaxLevel(uiFrames[i]) end
                if isMax then
                    totalMaxFiltered = totalMaxFiltered + 1
                else
                    table.insert(toUpgradeIDs, wsUnits[i])
                end
            end

            totalNeedUpgrade = totalNeedUpgrade + #toUpgradeIDs

            if #toUpgradeIDs > 0 then
                addLog("Upgrading [" .. targetName .. "] (" .. #toUpgradeIDs .. " unit)",
                       Color3.fromRGB(100, 200, 255))
                for _, id in ipairs(toUpgradeIDs) do
                    if not isRunning then break end
                    task.spawn(function()
                        pcall(function() UpgradeRemote:InvokeServer(id) end)
                    end)
                end
            end
        end

        CountText.Text = "Butuh Upg: " .. totalNeedUpgrade .. " | Selesai (Max): " .. totalMaxFiltered
        task.wait(CONFIG.UpgradeInterval)
    end
end

toggleScript = function()
    if isRunning then
        -- ====== BERHENTI ======
        isRunning = false
        instanceEntry.isRunning = false
        StatusDot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        StatusText.Text  = "Status: Mati"
        StatusText.TextColor3 = Color3.fromRGB(200, 200, 200)
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 60)
        ToggleBtn.Text = "MULAI UPGRADE"
        BadgeStatusDot.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
        addLog("Script #" .. instanceEntry.slot .. " dihentikan.", Color3.fromRGB(255, 100, 100))
    else
        -- ====== MULAI ======
        if #CONFIG.TargetUnits == 0 then
            addLog("Pilih minimal 1 Target Unit di Dropdown!", Color3.fromRGB(255, 100, 100))
            return
        end
        isRunning = true
        instanceEntry.isRunning = true
        StatusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
        StatusText.Text  = "Status: Upgrading..."
        StatusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        ToggleBtn.Text = "HENTIKAN UPGRADE"
        BadgeStatusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
        scriptThread = task.spawn(runUpgrader)
    end
end
ToggleBtn.MouseButton1Click:Connect(function() toggleScript() end)


