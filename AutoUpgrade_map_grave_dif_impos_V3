local function refreshTargetBtnText()
    local count = #CONFIG.TargetUnits
    if count == 0 then
        TargetDropdownBtn.Text = "Pilih Unit Target (0 Terpilih)"
    elseif count == 1 then
        TargetDropdownBtn.Text = "Target: " .. CONFIG.TargetUnits[1]
    else
        TargetDropdownBtn.Text = "Target: " .. count .. " Unit Terpilih"
    end
    updateBadgeText()
end

local function updateDropdownList()
    for _, child in ipairs(DropdownMenuScroll:GetChildren()) do
        if child:IsA("GuiButton") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    local uniqueUnits = {}
    local sf          = getUnitScrollingFrame()
    if sf then
        for _, child in ipairs(sf:GetChildren()) do
            if child:IsA("Frame") and child.Name ~= "Template" and child.Visible
               and not uniqueUnits[child.Name] then
                uniqueUnits[child.Name] = true
            end
        end
    end

    local count = 0
    for unitName, _ in pairs(uniqueUnits) do
        count = count + 1
        local isSelected = table.find(CONFIG.TargetUnits, unitName) ~= nil

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 25)
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(60, 120, 60) or Color3.fromRGB(40, 40, 55)
        btn.Text = "  " .. unitName
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 11
        btn.BorderSizePixel = 0
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.ZIndex = 51
        btn.Parent = DropdownMenuScroll

        btn.MouseButton1Click:Connect(function()
            local idx = table.find(CONFIG.TargetUnits, unitName)
            if idx then
                table.remove(CONFIG.TargetUnits, idx)
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
            else
                table.insert(CONFIG.TargetUnits, unitName)
                btn.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
            end
            refreshTargetBtnText()
        end)
    end

    if count == 0 then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 25)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Tidak ada unit di dalam UI!"
        lbl.TextColor3 = Color3.fromRGB(255, 100, 100)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 11
        lbl.ZIndex = 51
        lbl.Parent = DropdownMenuScroll
    end

    task.delay(0.05, function()
        DropdownMenuScroll.CanvasSize =
            UDim2.new(0, 0, 0, DropdownMenuLayout.AbsoluteContentSize.Y + 5)
    end)
end

TargetDropdownBtn.MouseButton1Click:Connect(function()
    DropdownMenuScroll.Visible = not DropdownMenuScroll.Visible
    if DropdownMenuScroll.Visible then
        updateDropdownList()
    end
end)

task.spawn(function()
    while task.wait(2) do
        if not ScreenGui.Parent then break end
        if DropdownMenuScroll.Visible then
