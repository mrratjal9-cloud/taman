local MainCorner = Instance.new("UICorner", MainFrame)
MainCorner.CornerRadius = UDim.new(0, 10)

-- Helper hitung posisi Y badge berdasar slot
local function calcBadgePos(slot)
    return UDim2.new(
        0, CONFIG.BadgeAnchorX,
        CONFIG.BadgeAnchorYScale, (slot - 1) * CONFIG.BadgeStackGap
    )
end

-- Set ukuran & posisi awal sesuai mode
local function applyMode(animated)
    if isMinimized then
        local size = UDim2.new(0, CONFIG.BadgeSize, 0, CONFIG.BadgeSize)
        local pos  = calcBadgePos(instanceEntry.slot)
        if animated then
            TweenService:Create(MainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quart),
                {Size = size, Position = pos}):Play()
        else
            MainFrame.Size = size
            MainFrame.Position = pos
        end
    else
        local size = UDim2.new(0, CONFIG.PanelSize.W, 0, CONFIG.PanelSize.H)
        -- saat expand, posisi tetap mulai dari titik badge supaya tidak "loncat" ke tengah
        local pos  = calcBadgePos(instanceEntry.slot)
        if animated then
            TweenService:Create(MainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quart),
                {Size = size, Position = pos}):Play()
        else
            MainFrame.Size = size
            MainFrame.Position = pos
        end
    end
end


