-- ====== Tombol Close: bersihkan registry & re-layout ======
local function destroySelf()
    isRunning = false
    -- hapus dari registry
    for i, inst in ipairs(Registry.instances) do
        if inst.id == MY_ID then
            table.remove(Registry.instances, i)
            break
        end
    end
    -- minta sisa instance re-layout (slot mereka maju 1)
    relayoutAllInstances()
    -- minta sisa instance refresh header total
    for _, inst in ipairs(Registry.instances) do
        if inst.onSlotChanged then
            pcall(inst.onSlotChanged, inst.slot)
        end
    end
    if ScreenGui and ScreenGui.Parent then
        ScreenGui:Destroy()
    end
end
instanceEntry.destroy = destroySelf

CloseBtn.MouseButton1Click:Connect(destroySelf)

