--          AUTO UPGRADE TOWER - V3 (TOP-LEFT + DefaultStateMinimize)
--          Game: GARDEN TOWER DEFENCE
-- ================================================================
-- BARU dari V2:
--   [REV 1] Posisi badge digeser ke ATAS KIRI (BadgeAnchorYScale 0.28 -> 0.05)
--           sesuai request: "kurang keatas, jadi atas kiri".
--   [REV 2] Config baru `DefaultStateMinimize` (mengganti `StartMinimized`).
--           - true  = saat eksekusi pertama GUI ON (minimize, badge kecil).
--           - false = saat eksekusi pertama GUI OFF minimize (panel lebar).
-- ----------------------------------------------------------------
-- Tetap dari V2:
--   [NEW 1] Mendukung paralel: jalankan script ini berkali-kali dengan
--           CONFIG.TargetUnits berbeda. Tiap eksekusi = 1 instance terpisah.
--   [NEW 2] Badge angka instance (1,2,3,...). Auto stack vertical.
--   [NEW 3] Saat ada instance ditutup, sisa instance otomatis re-layout.
--   [NEW 4] Total instance aktif & nomor instance ditampilkan di header.
--   [NEW 5] Setiap config diberi penjelasan format
--           "[KATEGORI] guna: ... | nilai: ... | efek: ..."
-- ================================================================


-- ================================================================
-- KATEGORI 1 : KONFIGURASI UTAMA (silakan diubah per-instance)
-- ================================================================
-- Setiap kali kamu execute script ini, CONFIG di bawah dipakai untuk
-- INSTANCE itu saja. Mau jalankan paralel dengan unit beda? Tinggal
-- ubah TargetUnits, lalu execute lagi. Tidak akan timpa instance lama.
-- ================================================================
local CONFIG = {

    -- ====== [A] PENGATURAN UPGRADE (kategori: CORE) ======
    AutoStart       = true,                     -- [CORE]   guna: auto mulai saat script di-load.                          | nilai: true / false.                              | efek: true = langsung jalan tanpa klik tombol; false = nunggu user klik MULAI.
    UpgradeInterval = 0.01,                     -- [PERF]   guna: jeda antar siklus upgrade (detik).                       | nilai: angka > 0 (rekomendasi 0.01 - 1.0).        | efek: makin kecil makin cepat upgrade tapi makin boros CPU/network.
    MaxLevel        = 2,                        -- [CORE]   guna: batas level max; unit yg sudah di level ini di-skip.    | nilai: integer >= 1 sesuai max unit di game.       | efek: hemat coin & traffic, mencegah upgrade percuma.

    -- ====== [B] TARGET UNIT (kategori: CORE - WAJIB BEDA per-instance) ======
    TargetUnits     = {"unit_log_roller"},      -- [CORE]   guna: daftar nama internal unit yg akan di-upgrade.            | nilai: list string case-sensitive (contoh {"unit_tomato_plant"}). | efek: tiap instance paralel sebaiknya pakai unit BEDA agar tidak saling tabrak request server.

    -- ====== [C] PENGATURAN AUTO WAVE (kategori: WAVE) ======
    WaveControl     = true,                     -- [WAVE]   guna: aktif/non-aktif kontrol otomatis berdasar wave.          | nilai: true / false.                              | efek: true = script otomatis hidup di StartWave & mati di StopWave.
    StartWave       = 6,                        -- [WAVE]   guna: nomor wave script auto-MULAI.                            | nilai: integer >= 1.                              | efek: jika wave saat ini >= angka ini -> script aktif (sekali per ronde).
    StopWave        = 9,                        -- [WAVE]   guna: nomor wave script auto-BERHENTI.                         | nilai: integer > StartWave.                       | efek: jika wave saat ini >= angka ini -> script mati otomatis.

    -- ====== [D] GUI MULTI-INSTANCE (kategori: GUI - khusus V2/V3) ======
    DefaultStateMinimize = true,                -- [GUI]    guna: state GUI saat eksekusi pertama (kondisi default).      | nilai: true = ON minimize (badge kecil) / false = OFF minimize (panel lebar). | efek: true (default) = hemat tempat saat banyak instance; false = panel langsung kebuka penuh.
    BadgeAnchorX      = 15,                     -- [GUI]    guna: jarak X badge dari sisi kiri layar (pixel).              | nilai: integer >= 0.                              | efek: makin besar = badge makin ke kanan dari tepi kiri.
    BadgeAnchorYScale = 0.05,                   -- [GUI]    guna: posisi Y badge dalam skala tinggi layar.                | nilai: 0.0 (paling atas) - 1.0 (paling bawah).    | efek: 0.05 = ATAS KIRI (V3 default); naikkan/turunkan utk geser vertikal.
    BadgeStackGap     = 58,                     -- [GUI]    guna: jarak vertikal antar badge bila ada banyak instance.    | nilai: integer >= ukuran badge (>= 50).           | efek: makin besar = badge tidak saling tumpang tindih.
    BadgeSize         = 50,                     -- [GUI]    guna: ukuran sisi (px) badge persegi saat minimized.           | nilai: integer 40-80.                             | efek: makin besar = nomor instance lebih jelas tapi makan tempat.
    PanelSize         = {W = 340, H = 480},     -- [GUI]    guna: ukuran panel saat di-MAXIMIZE.                           | nilai: tabel {W=lebar, H=tinggi} pixel.           | efek: ubah jika layar kecil/besar; W >= 300 disarankan.
}


