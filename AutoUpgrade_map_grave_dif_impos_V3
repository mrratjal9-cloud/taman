    InstanceInfoText.Text = "Instance #" .. instanceEntry.slot .. " / Total: " .. total
    TitleLabel.Text       = "Auto Upgrade V3  #" .. instanceEntry.slot .. " (of " .. total .. ")"
    LogTitle.Text         = " Console Log  (instance #" .. instanceEntry.slot .. ")"
end

updateBadgeText = function()
    BadgeNumber.Text  = tostring(instanceEntry.slot)
    BadgeSubText.Text = (CONFIG.TargetUnits[1] or "?"):sub(1, 9)
end

relayoutAllInstances = function()
    -- panggil setiap instance untuk re-apply posisi badge sesuai slot baru
    for newSlot, inst in ipairs(Registry.instances) do
        inst.slot = newSlot
        if inst.onSlotChanged then
            -- jangan biarkan satu instance jelek bikin yg lain crash
            pcall(inst.onSlotChanged, newSlot)
        end
    end
end

